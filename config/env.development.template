# Development Environment Variables Template for Vantura
# Copy this file to .env.development (or set in your shell)
# NEVER commit actual secrets to version control!

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Gmail SMTP Configuration
# Get App Password: https://support.google.com/accounts/answer/185833
# Steps: Google Account → Security → 2-Step Verification → App passwords → Generate
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=okky.mstafford@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_DOMAIN=gmail.com

# Mailer Configuration
MAILER_FROM=okky.mstafford@gmail.com
MAILER_HOST=localhost:3000

# =============================================================================
# NOTES
# =============================================================================
# 1. Create .env.development file in project root (or use shell environment)
# 2. Replace 'your_gmail_app_password_here' with your actual Gmail App Password
# 3. Ensure .env.development is in .gitignore (never commit passwords!)
# 4. Restart Rails server after setting environment variables

