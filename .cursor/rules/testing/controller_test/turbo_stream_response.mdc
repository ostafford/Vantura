## Testing Turbo Stream Responses

```ruby
test "creates article with turbo stream" do
  sign_in_as @user
  
  post articles_url, params: {
    article: {
      title: "New Article",
      body: "Body"
    }
  }, as: :turbo_stream
  
  assert_response :success
  assert_match "turbo-stream", response.body
end

test "updates article with turbo stream" do
  sign_in_as @article.user
  
  patch article_url(@article), params: {
    article: { title: "Updated" }
  }, as: :turbo_stream
  
  assert_response :success
  assert_match "turbo-stream", response.body
end
```

