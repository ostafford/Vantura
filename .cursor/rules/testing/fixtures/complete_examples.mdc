## Complete Examples

### Users

```yaml
# test/fixtures/users.yml

john:
  email: john@example.com
  password_digest: <%= BCrypt::Password.create('password') %>
  first_name: John
  last_name: Doe
  admin: false
  active: true
  birth_date: <%= 30.years.ago.to_date %>
  created_at: <%= 6.months.ago %>
  updated_at: <%= 1.week.ago %>

jane:
  email: jane@example.com
  password_digest: <%= BCrypt::Password.create('password') %>
  first_name: Jane
  last_name: Smith
  admin: true
  active: true
  birth_date: <%= 25.years.ago.to_date %>
  created_at: <%= 1.year.ago %>
  updated_at: <%= 1.day.ago %>

inactive:
  email: inactive@example.com
  password_digest: <%= BCrypt::Password.create('password') %>
  first_name: Inactive
  last_name: User
  admin: false
  active: false
  created_at: <%= 2.years.ago %>
  updated_at: <%= 2.years.ago %>
```

### Articles

```yaml
# test/fixtures/articles.yml

published:
  user: john
  title: Published Article
  slug: published-article
  body: This is a published article with enough content to be valid
  excerpt: Short excerpt
  status: published
  published_at: <%= 1.week.ago %>
  views_count: 100
  likes_count: 10
  created_at: <%= 2.weeks.ago %>
  updated_at: <%= 1.week.ago %>

draft:
  user: john
  title: Draft Article
  slug: draft-article
  body: This is a draft article
  status: draft
  published_at: nil
  views_count: 0
  likes_count: 0
  created_at: <%= 1.day.ago %>
  updated_at: <%= 1.day.ago %>

featured:
  user: jane
  title: Featured Article
  slug: featured-article
  body: This is a featured article with important content
  excerpt: Featured content
  status: published
  featured: true
  published_at: <%= 3.days.ago %>
  views_count: 500
  likes_count: 50
  created_at: <%= 1.month.ago %>
  updated_at: <%= 3.days.ago %>

archived:
  user: jane
  title: Archived Article
  slug: archived-article
  body: This is an archived article
  status: archived
  published_at: <%= 1.year.ago %>
  views_count: 1000
  likes_count: 100
  created_at: <%= 2.years.ago %>
  updated_at: <%= 1.year.ago %>
```

### Comments

```yaml
# test/fixtures/comments.yml

one:
  article: published
  user: jane
  body: Great article! Very informative.
  approved: true
  created_at: <%= 5.days.ago %>
  updated_at: <%= 5.days.ago %>

two:
  article: published
  user: john
  parent: one  # Reply to comment one
  body: Thank you for your feedback!
  approved: true
  created_at: <%= 4.days.ago %>
  updated_at: <%= 4.days.ago %>

pending:
  article: featured
  user: inactive
  body: This comment is awaiting moderation
  approved: false
  created_at: <%= 1.hour.ago %>
  updated_at: <%= 1.hour.ago %>
```

