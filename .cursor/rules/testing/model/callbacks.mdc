## Testing Callbacks

```ruby
test "generates slug before save" do
  article = Article.create(title: "My New Article", body: "Body")
  
  assert_equal "my-new-article", article.slug
end

test "updates slug when title changes" do
  article = articles(:one)
  article.update(title: "Updated Title")
  
  assert_equal "updated-title", article.slug
end

test "sends notification after create" do
  assert_enqueued_jobs 1, only: ArticleNotificationJob do
    Article.create(title: "New", body: "Body", user: users(:john))
  end
end
```

