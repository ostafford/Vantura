## Common Testing Patterns

### Testing Associations

```ruby
test "article belongs to user" do
  article = articles(:one)
  assert_respond_to article, :user
  assert_instance_of User, article.user
end

test "user has many articles" do
  user = users(:john)
  assert_respond_to user, :articles
  assert user.articles.count > 0
end
```

### Testing Validations

```ruby
test "requires title" do
  article = Article.new(body: "Body")
  assert_not article.valid?
  assert_includes article.errors[:title], "can't be blank"
end

test "title must be at least 5 characters" do
  article = Article.new(title: "Test")
  assert_not article.valid?
  assert_includes article.errors[:title], "is too short"
end
```

### Testing Scopes

```ruby
test "published scope returns published articles" do
  published = Article.published
  assert_equal 2, published.count
  assert published.all? { |a| a.status == 'published' }
end
```

### Testing Callbacks

```ruby
test "generates slug before save" do
  article = Article.create(title: "My Article", body: "Body")
  assert_equal "my-article", article.slug
end
```

