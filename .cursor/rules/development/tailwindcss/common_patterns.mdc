## Common Patterns

### Buttons

```html
<!-- Primary button -->
<button class="bg-blue-600 text-white font-semibold px-6 py-2 rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
  Primary Action
</button>

<!-- Secondary button -->
<button class="bg-gray-200 text-gray-800 font-semibold px-6 py-2 rounded-lg hover:bg-gray-300 focus:ring-2 focus:ring-gray-400 transition-colors">
  Secondary Action
</button>

<!-- Danger button -->
<button class="bg-red-600 text-white font-semibold px-6 py-2 rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-500 transition-colors">
  Delete
</button>

<!-- Outline button -->
<button class="border-2 border-blue-600 text-blue-600 font-semibold px-6 py-2 rounded-lg hover:bg-blue-50 focus:ring-2 focus:ring-blue-500 transition-colors">
  Outline Button
</button>

<!-- Disabled button -->
<button class="bg-gray-400 text-gray-200 font-semibold px-6 py-2 rounded-lg cursor-not-allowed" disabled>
  Disabled
</button>

<!-- Button with icon -->
<button class="flex items-center gap-2 bg-blue-600 text-white font-semibold px-6 py-2 rounded-lg hover:bg-blue-700">
  <svg class="w-5 h-5"><!-- icon --></svg>
  <span>Button Text</span>
</button>
```

### Cards

```html
<!-- Basic card -->
<div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
  <h3 class="text-xl font-bold text-gray-900 mb-2">Card Title</h3>
  <p class="text-gray-600 leading-relaxed mb-4">Card content goes here.</p>
  <a href="#" class="text-blue-600 hover:text-blue-800 font-semibold">
    Read more →
  </a>
</div>

<!-- Card with image -->
<div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
  <img src="image.jpg" alt="Card image" class="w-full h-48 object-cover">
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2">Card Title</h3>
    <p class="text-gray-600 mb-4">Card content.</p>
  </div>
</div>

<!-- Card with border -->
<div class="bg-white border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 transition-colors">
  <h3 class="text-xl font-bold mb-2">Card Title</h3>
  <p class="text-gray-600">Card content.</p>
</div>
```

### Forms

```html
<!-- Text input -->
<div class="mb-4">
  <label for="email-input" class="block text-gray-700 font-semibold mb-2">
    Email Address
  </label>
  <input type="email"
         id="email-input"
         class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
         placeholder="you@example.com">
</div>

<!-- Textarea -->
<div class="mb-4">
  <label for="message-textarea" class="block text-gray-700 font-semibold mb-2">
    Message
  </label>
  <textarea id="message-textarea"
            rows="4"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Your message..."></textarea>
</div>

<!-- Select dropdown -->
<div class="mb-4">
  <label for="category-select" class="block text-gray-700 font-semibold mb-2">
    Category
  </label>
  <select id="category-select"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
    <option>Select a category</option>
    <option>Technology</option>
    <option>Design</option>
  </select>
</div>

<!-- Checkbox -->
<div class="flex items-center mb-4">
  <input type="checkbox"
         id="terms-checkbox"
         class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-2 focus:ring-blue-500">
  <label for="terms-checkbox" class="ml-2 text-gray-700">
    I agree to the terms and conditions
  </label>
</div>

<!-- Radio buttons -->
<div class="mb-4">
  <p class="text-gray-700 font-semibold mb-2">Visibility</p>
  <div class="space-y-2">
    <label class="flex items-center">
      <input type="radio" name="visibility" value="public"
             class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-2 focus:ring-blue-500">
      <span class="ml-2 text-gray-700">Public</span>
    </label>
    <label class="flex items-center">
      <input type="radio" name="visibility" value="private"
             class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-2 focus:ring-blue-500">
      <span class="ml-2 text-gray-700">Private</span>
    </label>
  </div>
</div>

<!-- Input with error -->
<div class="mb-4">
  <label for="email-error-input" class="block text-gray-700 font-semibold mb-2">
    Email Address
  </label>
  <input type="email"
         id="email-error-input"
         class="w-full px-4 py-2 border-2 border-red-500 rounded-lg focus:ring-2 focus:ring-red-500"
         placeholder="you@example.com"
         aria-invalid="true">
  <p class="text-red-600 text-sm mt-1">Please enter a valid email address</p>
</div>
```

### Alerts

```html
<!-- Success alert -->
<div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
  <p class="font-bold">Success</p>
  <p>Your changes have been saved successfully.</p>
</div>

<!-- Error alert -->
<div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
  <p class="font-bold">Error</p>
  <p>Something went wrong. Please try again.</p>
</div>

<!-- Warning alert -->
<div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 mb-4" role="alert">
  <p class="font-bold">Warning</p>
  <p>This action cannot be undone.</p>
</div>

<!-- Info alert -->
<div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 mb-4" role="alert">
  <p class="font-bold">Information</p>
  <p>Your account will expire in 7 days.</p>
</div>

<!-- Alert with dismiss button -->
<div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
  <span class="block sm:inline">Your changes have been saved.</span>
  <button type="button"
          class="absolute top-0 bottom-0 right-0 px-4 py-3"
          aria-label="Close">
    <span class="text-2xl">&times;</span>
  </button>
</div>
```

### Badges

```html
<!-- Default badge -->
<span class="bg-gray-100 text-gray-800 text-xs font-semibold px-2.5 py-0.5 rounded">
  Default
</span>

<!-- Success badge -->
<span class="bg-green-100 text-green-800 text-xs font-semibold px-2.5 py-0.5 rounded">
  Published
</span>

<!-- Warning badge -->
<span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2.5 py-0.5 rounded">
  Draft
</span>

<!-- Error badge -->
<span class="bg-red-100 text-red-800 text-xs font-semibold px-2.5 py-0.5 rounded">
  Archived
</span>

<!-- Large badge -->
<span class="bg-blue-100 text-blue-800 text-sm font-semibold px-3 py-1 rounded-full">
  New
</span>
```

