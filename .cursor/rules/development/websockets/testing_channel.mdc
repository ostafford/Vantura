## Testing Channels

### Channel Tests

```ruby
# test/channels/notification_channel_test.rb

require "test_helper"

class NotificationChannelTest < ActionCable::Channel::TestCase
  test "subscribes to stream" do
    user = users(:john)
    
    stub_connection current_user: user
    subscribe
    
    assert subscription.confirmed?
    assert_has_stream "notifications_#{user.id}"
  end
  
  test "broadcasts notification" do
    user = users(:john)
    notification = notifications(:one)
    
    assert_broadcasts("notifications_#{user.id}", 1) do
      ActionCable.server.broadcast(
        "notifications_#{user.id}",
        { message: "Test" }
      )
    end
  end
end
```

