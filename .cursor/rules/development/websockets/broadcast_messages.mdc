## Broadcasting Messages

### From Models (Callbacks)

```ruby
# app/models/notification.rb

class Notification < ApplicationRecord
  belongs_to :user
  
  after_create_commit :broadcast_notification
  
  private
  
  def broadcast_notification
    broadcast_to_user
  end
  
  def broadcast_to_user
    ActionCable.server.broadcast(
      "notifications_#{user.id}",
      {
        id: id,
        html: ApplicationController.render(
          partial: 'notifications/notification',
          locals: { notification: self }
        )
      }
    )
  end
end
```

### From Controllers

```ruby
# app/controllers/comments_controller.rb

class CommentsController < ApplicationController
  def create
    @article = Article.find(params[:article_id])
    @comment = @article.comments.build(comment_params)
    @comment.user = Current.user
    
    if @comment.save
      # Broadcast new comment to article subscribers
      ActionCable.server.broadcast(
        "article_#{@article.id}_comments",
        {
          comment: ApplicationController.render(
            partial: 'comments/comment',
            locals: { comment: @comment }
          )
        }
      )
      
      redirect_to @article, notice: "Comment added."
    else
      render :new, status: :unprocessable_entity
    end
  end
end
```

### From Jobs

```ruby
# app/jobs/notification_broadcast_job.rb

class NotificationBroadcastJob < ApplicationJob
  queue_as :default
  
  def perform(user_id, notification_data)
    ActionCable.server.broadcast(
      "notifications_#{user_id}",
      notification_data
    )
  end
end

# Usage
NotificationBroadcastJob.perform_later(
  user.id,
  { message: "New article published!", html: rendered_html }
)
```

