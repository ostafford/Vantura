## Job Patterns

### Chain Jobs

```ruby
# Job 1: Process data
class ProcessDataJob < ApplicationJob
  def perform(data_id)
    data = Data.find(data_id)
    result = process(data)
    
    # Enqueue next job in chain
    NotifyUsersJob.perform_later(result.id)
  end
end

# Job 2: Notify users
class NotifyUsersJob < ApplicationJob
  def perform(result_id)
    result = Result.find(result_id)
    notify_users(result)
  end
end
```

### Batch Jobs

```ruby
# Parent job enqueues child jobs
class BatchProcessJob < ApplicationJob
  def perform(item_ids)
    item_ids.each do |id|
      ProcessItemJob.perform_later(id)
    end
  end
end
```

### Idempotent Jobs

```ruby
# Job can be run multiple times safely
class UpdateStatsJob < ApplicationJob
  def perform(article_id)
    article = Article.find(article_id)
    
    # Idempotent: recalculating doesn't cause issues
    article.update(
      comments_count: article.comments.count,
      views_count: article.views.count
    )
  end
end
```

