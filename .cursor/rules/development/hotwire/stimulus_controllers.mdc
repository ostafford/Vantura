### Stimulus Actions

```javascript
// Action format: event->controller#method
// Examples:

// Click event
<button data-action="click->form#submit">

// Multiple actions
<input data-action="keyup->search#filter blur->search#save">

// Window/document events
<div data-action="resize@window->layout#adjust">

// Custom events
<div data-action="custom:event->handler#process">

// Keyboard events
<input data-action="keydown.enter->form#submit">

// Prevent default
<form data-action="submit->form#save:prevent">

// Stop propagation
<button data-action="click->modal#close:stop">
```

### Real-World Examples

#### Modal Controller

```javascript
// app/javascript/controllers/modal_controller.js

import { Controller } from "@hotwired/stimulus"

export default class extends Controller {
  static targets = ["dialog", "backdrop"]
  
  open() {
    this.dialogTarget.showModal()
    document.body.style.overflow = 'hidden'
  }
  
  close() {
    this.dialogTarget.close()
    document.body.style.overflow = ''
  }
  
  closeOnBackdropClick(event) {
    if (event.target === this.dialogTarget) {
      this.close()
    }
  }
  
  closeOnEscape(event) {
    if (event.key === 'Escape') {
      this.close()
    }
  }
}
```

```html
<div data-controller="modal">
  <button data-action="click->modal#open">Open Modal</button>
  
  <dialog data-modal-target="dialog"
          data-action="click->modal#closeOnBackdropClick keydown->modal#closeOnEscape">
    <div id="modal-content">
      <button data-action="click->modal#close">Close</button>
      <p>Modal content here</p>
    </div>
  </dialog>
</div>
```

#### Autosave Controller

```javascript
// app/javascript/controllers/autosave_controller.js

import { Controller } from "@hotwired/stimulus"

export default class extends Controller {
  static values = {
    url: String,
    interval: { type: Number, default: 30000 }
  }
  
  static classes = ["saving", "saved"]
  
  connect() {
    this.save = this.save.bind(this)
    this.startAutosave()
  }
  
  disconnect() {
    this.stopAutosave()
  }
  
  startAutosave() {
    this.timer = setInterval(this.save, this.intervalValue)
  }
  
  stopAutosave() {
    if (this.timer) {
      clearInterval(this.timer)
    }
  }
  
  async save() {
    this.element.classList.add(this.savingClass)
    
    try {
      const formData = new FormData(this.element)
      const response = await fetch(this.urlValue, {
        method: 'PATCH',
        body: formData,
        headers: {
          'X-CSRF-Token': this.csrfToken
        }
      })
      
      if (response.ok) {
        this.element.classList.remove(this.savingClass)
        this.element.classList.add(this.savedClass)
        
        setTimeout(() => {
          this.element.classList.remove(this.savedClass)
        }, 2000)
      }
    } catch (error) {
      console.error('Autosave failed:', error)
      this.element.classList.remove(this.savingClass)
    }
  }
  
  get csrfToken() {
    return document.querySelector('meta[name="csrf-token"]').content
  }
}
```

```erb
<%= form_with model: @article,
              data: {
                controller: "autosave",
                autosave_url_value: article_path(@article),
                autosave_interval_value: 5000,
                autosave_saving_class: "opacity-50",
                autosave_saved_class: "border-green-500"
              },
              id: "article-edit-form" do |f| %>
  <%= f.text_field :title %>
  <%= f.text_area :body %>
<% end %>
```

### Stimulus Rules

**1. One Controller Per Behavior**
- `dropdown_controller.js` - handles dropdowns
- `modal_controller.js` - handles modals
- `autosave_controller.js` - handles autosave

**2. Keep Controllers Focused**
- Under 200 lines
- Single responsibility
- Reusable across the app

**3. Use Lifecycle Hooks**
```javascript
connect() {
  // Setup when element appears
}

disconnect() {
  // Cleanup when element removed
}

[target]TargetConnected(element) {
  // When target appears
}

[target]TargetDisconnected(element) {
  // When target removed
}
```

**4. Naming Conventions**
```javascript
// File: snake_case with _controller.js suffix
dropdown_controller.js
autosave_controller.js

// HTML: kebab-case
data-controller="dropdown"
data-controller="autosave"
```

