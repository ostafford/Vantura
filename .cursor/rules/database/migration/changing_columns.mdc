### Change Column Type

```ruby
class ChangeArticleStatusToInteger < ActiveRecord::Migration[8.0]
  def change
    # Safely change column type with data migration
    reversible do |dir|
      dir.up do
        add_column :articles, :status_new, :integer, default: 0
        
        # Migrate data
        Article.find_each do |article|
          status_int = case article.status
                      when 'draft' then 0
                      when 'published' then 1
                      when 'archived' then 2
                      else 0
                      end
          article.update_column(:status_new, status_int)
        end
        
        remove_column :articles, :status
        rename_column :articles, :status_new, :status
      end
      
      dir.down do
        add_column :articles, :status_old, :string
        
        Article.find_each do |article|
          status_str = case article.status
                      when 0 then 'draft'
                      when 1 then 'published'
                      when 2 then 'archived'
                      else 'draft'
                      end
          article.update_column(:status_old, status_str)
        end
        
        remove_column :articles, :status
        rename_column :articles, :status_old, :status
      end
    end
  end
end
```

### Change Column Attributes

```ruby
class ChangeArticleTitleAttributes < ActiveRecord::Migration[8.0]
  def change
    # Change null constraint
    change_column_null :articles, :title, false
    
    # Change default value
    change_column_default :articles, :published, from: false, to: true
    
    # Change string limit
    change_column :articles, :title, :string, limit: 200
  end
end
