## Complete Table Examples

### Users Table

```ruby
create_table :users do |t|
  # Authentication
  t.string :email, null: false, limit: 100
  t.string :password_digest, null: false
  
  # Profile
  t.string :first_name, null: false, limit: 50
  t.string :last_name, null: false, limit: 50
  t.date :birth_date
  
  # Settings
  t.boolean :admin, default: false, null: false
  t.boolean :active, default: true, null: false
  
  # Metadata
  t.inet :last_sign_in_ip
  t.datetime :last_sign_in_at
  
  t.timestamps
end

add_index :users, :email, unique: true
```

### Articles Table

```ruby
create_table :articles do |t|
  # Relationships
  t.references :user, null: false, foreign_key: true
  t.references :category, foreign_key: true
  
  # Content
  t.string :title, null: false, limit: 200
  t.string :slug, null: false, limit: 220
  t.text :body, null: false
  t.text :excerpt
  
  # Status
  t.string :status, default: "draft", null: false
  t.datetime :published_at
  
  # Stats
  t.integer :views_count, default: 0, null: false
  t.integer :likes_count, default: 0, null: false
  
  # SEO
  t.string :meta_title, limit: 60
  t.text :meta_description
  
  t.timestamps
end

add_index :articles, :slug, unique: true
add_index :articles, :status
add_index :articles, :published_at
add_index :articles, [:user_id, :status]
```

### Comments Table

```ruby
create_table :comments do |t|
  # Relationships
  t.references :article, null: false, foreign_key: { on_delete: :cascade }
  t.references :user, null: false, foreign_key: true
  t.references :parent, foreign_key: { to_table: :comments }
  
  # Content
  t.text :body, null: false
  
  # Moderation
  t.boolean :approved, default: false, null: false
  t.boolean :flagged, default: false, null: false
  
  t.timestamps
end

add_index :comments, [:article_id, :created_at]
add_index :comments, :parent_id
```

### Join Table (Many-to-Many)

```ruby
create_table :article_tags do |t|
  t.references :article, null: false, foreign_key: { on_delete: :cascade }
  t.references :tag, null: false, foreign_key: { on_delete: :cascade }
  
  t.timestamps
end

# Prevent duplicate associations
add_index :article_tags, [:article_id, :tag_id], unique: true
```

