### has_many (One-to-Many)

Model has multiple associated records.

```ruby
# app/models/user.rb
class User < ApplicationRecord
  has_many :articles
  # User has many Articles
  # Articles have user_id foreign key
end

# app/models/article.rb
class Article < ApplicationRecord
  belongs_to :user
end
```

**Usage:**
```ruby
user = User.first
user.articles              # Returns ActiveRecord::Relation
user.articles.count        # Count articles
user.articles.create(...)  # Create new article for user
user.articles << article   # Add existing article to user
user.articles.destroy_all  # Delete all user's articles
```

**has_many Options:**
```ruby
class User < ApplicationRecord
  # Dependent destroy (delete articles when user deleted)
  has_many :articles, dependent: :destroy
  
  # Dependent delete_all (faster, skips callbacks)
  has_many :articles, dependent: :delete_all
  
  # Dependent nullify (set article.user_id to NULL)
  has_many :articles, dependent: :nullify
  
  # Custom foreign key
  has_many :articles, foreign_key: 'author_id'
  
  # Custom class name
  has_many :authored_articles, class_name: 'Article', foreign_key: 'author_id'
  
  # Order
  has_many :articles, -> { order(created_at: :desc) }
  
  # Scoped association
  has_many :published_articles, 
           -> { where(status: 'published') }, 
           class_name: 'Article'
  
  # Inverse of (optimization)
  has_many :articles, inverse_of: :user
end
```

