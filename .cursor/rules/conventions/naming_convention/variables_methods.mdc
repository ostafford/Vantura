# Constants: SCREAMING_SNAKE_CASE
MAX_LOGIN_ATTEMPTS = 3
DEFAULT_STATUS = 'draft'
API_BASE_URL = 'https://api.example.com'
ALLOWED_ROLES = ['admin', 'editor', 'viewer'].freeze

# Boolean methods: end with ?
def active?
  status == 'active'
end

def published?
  published_at.present? && published_at <= Time.current
end

def expired?
  expires_at < Time.current
end

# Dangerous methods (raise exceptions): end with !
def save!
  # raises exception if fails
end

def publish!
  # raises exception if can't publish
  update!(status: 'published', published_at: Time.current)
end

def delete_all_data!
  # destructive action, raises on error
end

# Private methods (convention): can use underscore prefix
private

def _internal_calculation
  # private implementation detail
end
```

