<%= turbo_stream.replace "project-members-section" do %>
  <%= turbo_frame_tag "project-members-section" do %>
    <div>
      <div class="flex items-center justify-between mb-2">
        <div class="text-overlay-subtle text-xs font-medium uppercase tracking-wider">Members</div>
        <% if can_manage_members?(@project) %>
          <button type="button" data-action="click->modal#open" class="btn-overlay-text text-xs font-medium uppercase tracking-wider">
            + Add Member
          </button>
        <% end %>
      </div>
      <% if @project.members.any? %>
        <div id="project-members-list" class="flex flex-wrap gap-2">
          <% membership_by_user = @project.project_memberships.index_by(&:user_id) %>
          <% @project.members.each do |member| %>
            <% membership = membership_by_user[member.id] %>
            <% level = membership&.access_level || 'limited' %>
            <div id="<%= dom_id(membership || member) %>" class="inline-flex items-center gap-2 px-3 py-1.5 surface-member-card">
              <div class="w-7 h-7 rounded-full surface-member-avatar flex items-center justify-center text-white font-medium text-xs">
                <%= user_display_name(member).first.upcase %>
              </div>
              <span class="text-member-name text-sm"><%= user_display_name(member) %></span>
              <span class="ml-2 text-[10px] uppercase tracking-wide px-2 py-0.5 rounded badge-member-level">
                <%= level == 'full' ? 'Full' : 'Limited' %>
              </span>
              <% if can_manage_members?(@project) && membership %>
                <%= button_to project_membership_path(@project, membership), method: :delete, form: { data: { turbo: true }, class: "ml-2" }, class: "btn-overlay-action", title: "Remove member" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div id="project-members-empty" class="text-overlay-empty">
          No additional members
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>

<%= turbo_stream.replace "add-member-form" do %>
  <%= render "projects/add_member_form", project: @project %>
<% end %>

<%= turbo_stream.append "notifications-container" do %>
  <div data-controller="notification"
       data-notification-type-value="success"
       data-notification-auto-dismiss-value="true"
       data-notification-dismiss-after-value="5000"
       class="w-96 surface-notification rounded-xl shadow-deep pointer-events-auto overflow-hidden transform translate-x-full opacity-0 transition-all duration-300 ease-out">
    <div class="p-4">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 icon-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-3 w-0 flex-1 pt-0.5">
          <p class="status-success-text text-sm font-medium">
            Member added successfully
          </p>
        </div>
        <div class="ml-4 flex-shrink-0 flex">
          <button type="button" 
                  data-action="click->notification#dismiss"
                  class="icon-success hover-success">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

