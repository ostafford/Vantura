<% active_filters = current_filters.to_h.reject { |k, v| v.blank? } %>
<% if active_filters.present? %>
  <div class="flex flex-wrap gap-2 items-center">
    <span class="text-xs font-medium text-gray-600 dark:text-gray-400">Active:</span>
    <% active_filters.each do |key, value| %>
      <% filter_label = case key.to_s
           when "category_id"
             categories.find_by(id: value)&.name || 'Unknown'
           when "account_id"
             accounts.find_by(id: value)&.display_name || 'Unknown'
           when "transaction_type"
             value.capitalize
           else
             value
         end %>
      <span class="inline-flex items-center px-2 py-1 text-xs font-medium text-blue-800 bg-blue-100 rounded-full dark:bg-blue-900 dark:text-blue-300">
        <%= filter_label %>
        <button type="button"
            class="ml-1.5 inline-flex items-center text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-500"
            data-action="click->transaction-filter#removeFilter"
            data-filter-name="<%= key %>">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </span>
    <% end %>
    <%= link_to "Clear All", transactions_path,
        class: "inline-flex items-center px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600",
        data: { turbo_frame: "_top", turbo_action: "advance" } %>
  </div>
<% end %>
