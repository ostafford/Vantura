<%
  transactions_data = local_assigns.fetch(:transactions_data)
  frame_id = local_assigns.fetch(:frame_id, "transactions_content")
  filter_additional_params = local_assigns.fetch(:filter_additional_params, {})

  date = transactions_data[:date]
  filter_type = transactions_data[:filter_type]
  filter_url_params = {
    year: transactions_data[:year],
    month: transactions_data[:month]
  }.merge(filter_additional_params)
%>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 px-4 py-4 sm:px-6 sm:py-5"
     data-controller="frame-navigation"
     data-frame-navigation-frame-id-value="<%= frame_id %>">
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <div id="transactions-month-navigation" class="flex items-center justify-center gap-2 px-2 py-2">
      <% prev_month = date.prev_month %>
      <%= link_to transactions_path(year: prev_month.year, month: prev_month.month, filter: filter_type),
                  class: "inline-flex items-center px-3 py-1.5 sm:px-4 sm:py-2 text-sm sm:text-base bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors",
                  data: { turbo_frame: frame_id, action: "click->transactions-scroll#remember click->frame-navigation#navigate" },
                  aria: { label: "Navigate to previous month: #{prev_month.strftime('%B %Y')}" } do %>
        <svg class="w-4 h-4 sm:w-5 sm:h-5 mr-1.5 sm:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Previous
      <% end %>

      <% next_month = date.next_month %>
      <%= link_to transactions_path(year: next_month.year, month: next_month.month, filter: filter_type),
                  class: "inline-flex items-center px-3 py-1.5 sm:px-4 sm:py-2 text-sm sm:text-base bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors",
                  data: { turbo_frame: frame_id, action: "click->transactions-scroll#remember click->frame-navigation#navigate" },
                  aria: { label: "Navigate to next month: #{next_month.strftime('%B %Y')}" } do %>
        Next
        <svg class="w-4 h-4 sm:w-5 sm:h-5 ml-1.5 sm:ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col gap-1 items-center text-center">
    <h2 id="transactions-current-month-heading" class="text-xl font-bold text-gray-900 dark:text-white md:text-2xl">
      <%= date.strftime("%B %Y") %>
    </h2>
    <p id="transactions-table-heading" class="text-sm font-medium text-gray-600 dark:text-gray-300">
      <%= case filter_type
          when "expenses" then "Expense Transactions"
          when "income" then "Income Transactions"
          when "hypothetical" then "Hypothetical Transactions"
          when "search" then "Search Results"
          else "All Transactions"
          end %>
    </p>
  </div>

  <div class="flex flex-col items-center sm:flex-row sm:items-center gap-3 w-full sm:w-auto px-2 py-2">
    <div class="relative w-full sm:w-auto">
      <label for="transaction-filter-select" class="sr-only">Filter transactions</label>
      <select id="transaction-filter-select" name="filter"
              data-action="change->transactions-scroll#remember change->filter#change"
              data-filter-url-value="<%= transactions_path(filter_url_params) %>"
              data-filter-turbo-frame-value="<%= frame_id %>"
              class="block w-full sm:w-auto px-4 py-2 pr-10 text-sm sm:text-base text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent cursor-pointer">
        <option value="all" <%= 'selected' if filter_type == 'all' %>>All Transactions</option>
        <option value="expenses" <%= 'selected' if filter_type == 'expenses' %>>Expenses Only</option>
        <option value="income" <%= 'selected' if filter_type == 'income' %>>Income Only</option>
        <option value="hypothetical" <%= 'selected' if filter_type == 'hypothetical' %>>Hypothetical Only</option>
      </select>
    </div>

    <% if block_given? %>
      <%= yield %>
    <% end %>
  </div>
</div>

