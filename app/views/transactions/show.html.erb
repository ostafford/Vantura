<div class="max-w-4xl mx-auto mt-8 p-6 bg-white dark:bg-gray-800 rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Transaction</h1>

  <div class="space-y-4">
    <div>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Description:</span>
      <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.description %></span>
    </div>

    <div>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Amount:</span>
      <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.amount < 0 ? "-" : "+" %>$<%= number_with_precision(@transaction.amount.abs, precision: 2) %></span>
    </div>

    <div>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Date:</span>
      <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.transaction_date.strftime("%b %d, %Y") if @transaction.transaction_date %></span>
    </div>

    <% if @transaction.category.present? %>
      <div>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Category:</span>
        <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.category %></span>
      </div>
    <% end %>

    <% if @transaction.merchant.present? %>
      <div>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Merchant:</span>
        <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.merchant %></span>
      </div>
    <% end %>

    <div>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Status:</span>
      <span class="ml-2 text-gray-900 dark:text-gray-100"><%= @transaction.status.humanize %></span>
    </div>

    <div class="mt-6">
      <%= link_to "Edit", edit_transaction_path(@transaction), class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
      <%= link_to "Back to List", transactions_path, class: "ml-2 px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium" %>
    </div>
  </div>
</div>

