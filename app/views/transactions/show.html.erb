<% if request.headers["Turbo-Frame"] == "transaction-detail" %>
  <!-- Modal Content -->
  <%= turbo_frame_tag "transaction-detail" do %>
    <div class="grid grid-cols-3 gap-6">
      <!-- Left Panel (2/3 width) -->
      <div class="col-span-2 p-6">
        <% if flash[:notice] %>
          <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg dark:bg-green-900 dark:border-green-700 dark:text-green-200" role="alert">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg dark:bg-red-900 dark:border-red-700 dark:text-red-200" role="alert">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <div class="flex justify-between items-start mb-6">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= @transaction.description || @transaction.raw_text %>
          </h3>
          <button type="button"
              class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
              data-action="click->transaction-modal#close">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="space-y-6">
          <!-- Amount and Category -->
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Amount</p>
            <p class="text-3xl font-bold <%= @transaction.amount_cents < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
              <%= @transaction.amount_cents < 0 ? '-' : '+' %><%= number_to_currency(@transaction.amount_cents.abs / 100.0, unit: "$") %>
            </p>
          </div>

          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Category</p>
            <p class="text-lg text-gray-900 dark:text-white">
              <%= @transaction.category&.name || "Uncategorized" %>
            </p>
          </div>

          <!-- Date & Time -->
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Date & Time</p>
            <p class="text-lg text-gray-900 dark:text-white">
              <%= @transaction.created_at_up&.strftime("%b %d, %Y at %I:%M %p") || @transaction.created_at.strftime("%b %d, %Y at %I:%M %p") %>
            </p>
          </div>

          <!-- Account -->
          <% if @transaction.account.present? %>
            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Account</p>
              <p class="text-lg text-gray-900 dark:text-white">
                <%= @transaction.account.display_name %>
              </p>
            </div>
          <% end %>

          <!-- Status -->
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Status</p>
            <span class="px-3 py-1 rounded <%= 
              @transaction.status == 'settled' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 
              @transaction.status == 'held' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200' : 
              'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200' 
            %>">
              <%= @transaction.status.capitalize %>
            </span>
          </div>

          <!-- Raw Text -->
          <% if @transaction.raw_text.present? %>
            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Raw Text</p>
              <p class="text-sm text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-700 p-3 rounded">
                <%= @transaction.raw_text %>
              </p>
            </div>
          <% end %>

          <!-- Tags -->
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Tags</p>
            <% if @transaction.tags.any? %>
              <div class="flex flex-wrap gap-2">
                <% @transaction.tags.each do |tag| %>
                  <span class="px-3 py-1 text-sm bg-blue-100 text-blue-800 rounded-full dark:bg-blue-900 dark:text-blue-300">
                    <%= tag.name %>
                  </span>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-gray-400 dark:text-gray-500">No tags</p>
            <% end %>
          </div>

          <!-- Notes -->
          <div>
            <%= form_with model: @transaction, 
                data: { 
                  turbo_frame: "transaction-detail",
                  controller: "form"
                } do |f| %>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Notes</p>
              <%= f.text_area :notes,
                  rows: 3,
                  class: "w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                  placeholder: "Add a note..." %>
              <%= f.submit "Save Note",
                  class: "mt-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Right Panel (1/3 width) - Insights Placeholder -->
      <div class="col-span-1 p-6 bg-gray-50 dark:bg-gray-900">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Insights</h3>
        <div class="space-y-6 text-sm text-gray-500 dark:text-gray-400">
          <div>
            <p class="font-medium text-gray-700 dark:text-gray-300 mb-2">💡 Spending Pattern</p>
            <p>Insights coming in Phase 3</p>
          </div>
          <div>
            <p class="font-medium text-gray-700 dark:text-gray-300 mb-2">📊 Budget Impact</p>
            <p>Insights coming in Phase 3</p>
          </div>
          <div>
            <p class="font-medium text-gray-700 dark:text-gray-300 mb-2">🏷️ Similar Transactions</p>
            <p>Insights coming in Phase 3</p>
          </div>
          <div>
            <p class="font-medium text-gray-700 dark:text-gray-300 mb-2">🗓️ Recurring Pattern</p>
            <p>Insights coming in Phase 3</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal Footer -->
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 flex justify-between">
      <button type="button"
          class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700"
          data-action="click->transaction-modal#close">
        Close
      </button>
      <div class="flex gap-2">
        <!-- Previous/Next navigation placeholder -->
        <button type="button"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700"
            disabled
            title="Navigation coming soon">
          ← Previous
        </button>
        <button type="button"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700"
            disabled
            title="Navigation coming soon">
          Next →
        </button>
      </div>
    </div>
  <% end %>
<% else %>
  <!-- Regular page view (fallback) -->
  <h1>Transaction</h1>
  <p><%= @transaction.description %></p>
<% end %>
