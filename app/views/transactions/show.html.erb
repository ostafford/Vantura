<% content_for :title, "Transaction Details - Vantura" %>
<% content_for :page_header_title, "Transaction Details" %>
<% content_for :page_header_subtitle, "View transaction information" %>

<main>
  <%= content_wrapper class: "py-6" do %>
    <article id="transaction-<%= @transaction.id %>-container" 
             class="mx-auto max-w-4xl bg-white dark:bg-neutral-800 shadow-deep rounded-2xl border border-neutral-200 dark:border-neutral-700 overflow-hidden"
             <%= 'aria-label="Hypothetical transaction: ' + @transaction.description + '"' if @transaction.is_hypothetical %>>
      
      <!-- Header Section -->
      <header id="transaction-<%= @transaction.id %>-header" 
              class="px-8 py-6 border-b border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900">
        <h1 id="transaction-<%= @transaction.id %>-title" 
            class="text-2xl font-bold text-neutral-base">
          Transaction Details
        </h1>
        <p id="transaction-<%= @transaction.id %>-subtitle" 
           class="mt-2 text-sm text-neutral-label">
          <%= @transaction.description %>
        </p>
      </header>

      <!-- Transaction Details Section -->
      <section id="transaction-<%= @transaction.id %>-details-section" 
               class="px-8 py-6" 
               aria-labelledby="transaction-<%= @transaction.id %>-details-heading">
        <h2 id="transaction-<%= @transaction.id %>-details-heading" 
            class="sr-only">
          Transaction Information
        </h2>

        <dl id="transaction-<%= @transaction.id %>-details-list" 
            class="space-y-4">
          
          <!-- Description -->
          <div class="flex flex-col sm:flex-row sm:items-start gap-2">
            <dt id="transaction-<%= @transaction.id %>-description-label" 
                class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
              Description
            </dt>
            <dd id="transaction-<%= @transaction.id %>-description" 
                class="text-base text-neutral-base">
              <%= @transaction.description %>
            </dd>
          </div>

          <!-- Amount -->
          <div class="flex flex-col sm:flex-row sm:items-start gap-2">
            <dt id="transaction-<%= @transaction.id %>-amount-label" 
                class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
              Amount
            </dt>
            <dd id="transaction-<%= @transaction.id %>-amount" 
                class="text-lg font-bold <%= amount_color_class(@transaction.amount) %>">
              <%= formatted_transaction_amount(@transaction) %>
            </dd>
          </div>

          <!-- Date -->
          <div class="flex flex-col sm:flex-row sm:items-start gap-2">
            <dt id="transaction-<%= @transaction.id %>-date-label" 
                class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
              Date
            </dt>
            <dd id="transaction-<%= @transaction.id %>-date" 
                class="text-base text-neutral-base">
              <% if @transaction.transaction_date %>
                <time datetime="<%= @transaction.transaction_date.iso8601 %>">
                  <%= @transaction.transaction_date.strftime("%B %d, %Y") %>
                </time>
              <% else %>
                <span class="text-neutral-muted">Not set</span>
              <% end %>
            </dd>
          </div>

          <!-- Category -->
          <% if @transaction.category.present? %>
            <div class="flex flex-col sm:flex-row sm:items-start gap-2">
              <dt id="transaction-<%= @transaction.id %>-category-label" 
                  class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
                Category
              </dt>
              <dd id="transaction-<%= @transaction.id %>-category" 
                  class="text-base text-neutral-base">
                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium rounded-md bg-neutral-100 dark:bg-neutral-700 text-neutral-label">
                  <%= @transaction.category.humanize %>
                </span>
              </dd>
            </div>
          <% end %>

          <!-- Merchant -->
          <% if @transaction.merchant.present? %>
            <div class="flex flex-col sm:flex-row sm:items-start gap-2">
              <dt id="transaction-<%= @transaction.id %>-merchant-label" 
                  class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
                Merchant
              </dt>
              <dd id="transaction-<%= @transaction.id %>-merchant" 
                  class="text-base text-neutral-base">
                <%= @transaction.merchant %>
              </dd>
            </div>
          <% end %>

          <!-- Status -->
          <div class="flex flex-col sm:flex-row sm:items-start gap-2">
            <dt id="transaction-<%= @transaction.id %>-status-label" 
                class="text-sm font-semibold text-neutral-label sm:w-32 flex-shrink-0">
              Status
            </dt>
            <dd id="transaction-<%= @transaction.id %>-status" 
                class="text-base">
              <div class="flex items-center gap-1.5">
                <%= transaction_status_badge(@transaction) %>
                <%= transaction_recurring_badge(@transaction) %>
              </div>
            </dd>
          </div>

        </dl>
      </section>

      <!-- Actions Section -->
      <footer id="transaction-<%= @transaction.id %>-actions-section" 
              class="px-8 py-6 border-t border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900">
        <nav id="transaction-<%= @transaction.id %>-actions-nav" 
             aria-label="Transaction actions">
          <div class="flex items-center gap-4">
            <%= link_to edit_transaction_path(@transaction),
                id: "transaction-<%= @transaction.id %>-edit-button",
                class: "inline-flex items-center justify-center px-5 py-3 text-sm font-semibold action-primary",
                aria: { label: "Edit transaction: #{@transaction.description}" } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit
            <% end %>

            <%= link_to transactions_path,
                id: "transaction-<%= @transaction.id %>-back-button",
                class: "btn-secondary px-5 py-3 text-sm",
                aria: { label: "Back to transactions list" } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Back to List
            <% end %>
          </div>
        </nav>
      </footer>
    </article>
  <% end %>
</main>

