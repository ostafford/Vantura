<%
  transactions_data = local_assigns.fetch(:transactions_data)
  transactions = transactions_data[:transactions]
  table_body_partial = local_assigns.fetch(:table_body_partial, "transactions/table_body")
  table_body_locals = local_assigns.fetch(:table_body_locals, { transactions: transactions })
  empty_state_title = local_assigns.fetch(:empty_state_title, "No transactions")
  empty_state_message = local_assigns.fetch(:empty_state_message, "No transactions found for the selected filter.")
  frame_id = local_assigns.fetch(:frame_id, "transactions_content")
  filter_additional_params = local_assigns.fetch(:filter_additional_params, {})
  filters_partial = local_assigns[:filters_partial]
  filters_locals = local_assigns.fetch(:filters_locals, {})
%>

<section class="bg-white dark:bg-neutral-800 rounded-2xl shadow-deep overflow-hidden" aria-label="Transaction list">
  <header id="transactions-table-header" class="px-4 py-4 sm:px-6 sm:py-5 border-b bg-table-header border-table-divider">
    <%= render "transactions/navigation_controls",
          transactions_data: transactions_data,
          frame_id: frame_id,
          filter_additional_params: filter_additional_params do %>
      <% if block_given? %>
        <div class="flex-shrink-0">
          <%= yield %>
        </div>
      <% end %>
    <% end %>
  </header>

  <% if filters_partial.present? %>
    <div id="transactions-table-filters" class="px-4 py-3 sm:px-6 sm:py-4 border-b border-table-divider bg-white dark:bg-neutral-800">
      <%= render filters_partial, filters_locals %>
    </div>
  <% end %>

  <!-- Mobile Card View -->
  <div class="block md:hidden">
    <%= render 'transactions/transaction_cards', 
        transactions: transactions,
        empty_state_title: empty_state_title,
        empty_state_message: empty_state_message %>
  </div>

  <!-- Desktop Table View -->
  <div class="hidden md:block overflow-x-auto">
    <table class="min-w-full divide-y divide-table-divider">
      <thead class="bg-table-header">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-neutral-muted uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-neutral-muted uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="transactions-table-body" class="bg-white dark:bg-neutral-800 divide-table-divider">
        <%= render partial: table_body_partial, locals: table_body_locals %>
      </tbody>
    </table>
  </div>
</section>

