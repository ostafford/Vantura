<%
  transactions_data = local_assigns.fetch(:transactions_data)
  transactions = transactions_data[:transactions]
  table_body_partial = local_assigns.fetch(:table_body_partial, "transactions/table_body")
  table_body_locals = local_assigns.fetch(:table_body_locals, { transactions: transactions })
  empty_state_title = local_assigns.fetch(:empty_state_title, "No transactions")
  empty_state_message = local_assigns.fetch(:empty_state_message, "No transactions found for the selected filter.")
  frame_id = local_assigns.fetch(:frame_id, "transactions_content")
  filter_additional_params = local_assigns.fetch(:filter_additional_params, {})
  filters_partial = local_assigns[:filters_partial]
  filters_locals = local_assigns.fetch(:filters_locals, {})
%>

<section class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-deep overflow-hidden" aria-label="Transaction list">
  <header id="transactions-table-header" class="px-6 py-5 border-b bg-gray-50 dark:bg-gray-900 border-gray-200 dark:border-gray-700">
    <%= render "transactions/navigation_controls",
          transactions_data: transactions_data,
          frame_id: frame_id,
          filter_additional_params: filter_additional_params do %>
      <% if block_given? %>
        <div class="flex-shrink-0">
          <%= yield %>
        </div>
      <% end %>
    <% end %>
  </header>

  <% if filters_partial.present? %>
    <div id="transactions-table-filters" class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
      <%= render filters_partial, filters_locals %>
    </div>
  <% end %>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-900">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="transactions-table-body" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
        <%= render partial: table_body_partial, locals: table_body_locals %>
      </tbody>
    </table>
  </div>

  <% if transactions.empty? %>
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900"><%= empty_state_title %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= empty_state_message %></p>
    </div>
  <% end %>
</section>

