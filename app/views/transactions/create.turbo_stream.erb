<%# Update the Combined Cash Flow Card %>
<%= turbo_stream.replace "dashboard-cash-flow-card" do %>
  <%= render "shared/bento_cards/cash_flow_card",
      income_total: @dashboard_data[:income_total],
      expense_total: @dashboard_data[:expense_total],
      income_count: @dashboard_data[:income_count],
      expense_count: @dashboard_data[:expense_count],
      projected_income_total: @dashboard_data[:projected_income_total] || 0,
      projected_expense_total: @dashboard_data[:projected_expense_total] || 0,
      projected_income_count: @dashboard_data[:projected_income_count] || 0,
      projected_expense_count: @dashboard_data[:projected_expense_count] || 0,
      current_date: @dashboard_data[:current_date],
      top_income_merchants: @dashboard_data[:top_income_merchants] || [],
      top_expense_merchants: @dashboard_data[:top_expense_merchants] || [],
      top_income_categories: @dashboard_data[:top_income_categories] || [],
      top_expense_categories: @dashboard_data[:top_expense_categories] || [],
      account: @account %>
<% end %>

<%# Update the End of Month Projection %>
<%= turbo_stream.replace "dashboard-projection-card" do %>
  <%= render "dashboard/projection_card",
      income_total: @dashboard_data[:income_total],
      expense_total: @dashboard_data[:expense_total],
      end_of_month_balance: @dashboard_data[:end_of_month_balance],
      current_date: @dashboard_data[:current_date],
      upcoming_recurring_expenses: @dashboard_data[:upcoming_recurring_expenses],
      upcoming_recurring_income: @dashboard_data[:upcoming_recurring_income],
      current_balance: @account.current_balance,
      upcoming_recurring_total: @dashboard_data[:upcoming_recurring_total] %>
<% end %>

<%# Prepend the new transaction to Recent Transactions %>
<%= turbo_stream.prepend "dashboard-recent-transactions-table-body" do %>
  <%= render "dashboard/transaction_row", transaction: @transaction %>
<% end %>

<%# Show success notification %>
<% transaction_type = @transaction.amount > 0 ? 'income' : 'expense' %>
<%= turbo_stream.append "notifications-container" do %>
  <div data-controller="notification" 
       data-notification-type="success"
       data-notification-auto-dismiss-value="true"
       data-notification-dismiss-after-value="5000"
       class="w-96 bg-white/95 dark:bg-primary-700/95 backdrop-blur-sm rounded-xl shadow-deep pointer-events-auto overflow-hidden transform translate-x-full opacity-0 transition-all duration-300 ease-out">
    <div class="p-4">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-success-500 dark:text-success-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-3 w-0 flex-1 pt-0.5">
          <p class="text-success-700 dark:text-success-300 text-sm font-medium">
            <%= transaction_type.capitalize %> transaction added!
          </p>
          <p class="text-success-600 dark:text-success-400 text-xs mt-1">
            <%= number_to_currency(@transaction.amount.abs) %> • <%= @transaction.description %>
          </p>
        </div>
        <div class="ml-4 flex-shrink-0 flex">
          <button type="button" 
                  data-action="click->notification#dismiss"
                  class="text-success-500 dark:text-success-300 hover:text-success-700 dark:hover:text-success-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# Refresh calendar if it's open - dispatch a reload event %>
<script>
  console.log('Transaction created Turbo Stream executed');
  // Refresh calendar if it's open
  const calendarFrame = document.getElementById('calendar_content');
  console.log('Calendar frame found:', calendarFrame);
  if (calendarFrame) {
    const currentUrl = window.location.href;
    console.log('Current URL:', currentUrl);
    if (currentUrl.includes('/calendar')) {
      console.log('Dispatching transaction:created event');
      // Dispatch a custom event that will trigger the calendar to reload
      window.dispatchEvent(new CustomEvent('transaction:created', { 
        detail: { transaction: { id: '<%= @transaction.id %>', date: '<%= @transaction.transaction_date %>' } } 
      }));
    }
  }
</script>

<%# Close the modal drawer %>
<%= turbo_stream.replace "transaction-modal" do %>
  <%= render "shared/transaction_drawer", default_transaction_date: Date.today %>
<% end %>

