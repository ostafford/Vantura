<% content_for :title, "Edit Transaction - Vantura" %>
<% content_for :page_header_title, "Edit Transaction" %>
<% content_for :page_header_subtitle, "Update the transaction details below" %>

<main>
  <%= content_wrapper class: "py-6" do %>
    <div class="mx-auto max-w-4xl bg-white dark:bg-neutral-800 shadow-deep rounded-2xl border border-neutral-200 dark:border-neutral-700">
      <div class="px-8 py-6 border-b border-neutral-200 dark:border-neutral-700">
        <h1 class="text-2xl font-bold text-neutral-base">Transaction Details</h1>
        <p class="mt-2 text-sm text-neutral-label">
          Make sure the information reflects the actual transaction. Fields marked with
          <span class="text-form-required" aria-hidden="true">*</span>
          are required.
        </p>
      </div>

      <%= form_with model: @transaction, class: "px-8 py-8 space-y-8" do |form| %>
        <section aria-labelledby="transaction-summary-section">
          <h2 id="transaction-summary-section" class="text-lg font-semibold text-neutral-base mb-4">
            Summary
          </h2>

          <div class="grid grid-cols-2 gap-6 md:grid-cols-1">
            <div>
              <%= form.label :description,
                  "Description",
                  class: "block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2",
                  for: "transaction-description-input" %>
              <%= form.text_field :description,
                  id: "transaction-description-input",
                  class: "w-full input-base input-focus",
                  placeholder: "e.g., Grocery store purchase",
                  required: true,
                  autocomplete: "off" %>
            </div>

            <div>
              <label for="transaction-amount-input" class="block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2">
                Amount <span class="text-form-required" aria-hidden="true">*</span>
              </label>
              <div class="relative">
                <span class="absolute inset-y-0 left-3 flex items-center text-neutral-muted font-semibold">$</span>
                <%= form.number_field :amount,
                    id: "transaction-amount-input",
                    step: 0.01,
                    required: true,
                    class: "w-full pl-8 pr-4 input-base input-focus",
                    aria: { describedby: "transaction-amount-help" } %>
              </div>
              <p id="transaction-amount-help" class="mt-2 text-xs text-neutral-muted">
                Use a negative amount for expenses and positive for income.
              </p>
            </div>
          </div>
        </section>

        <section aria-labelledby="transaction-meta-section">
          <h2 id="transaction-meta-section" class="text-lg font-semibold text-neutral-base mb-4">
            Additional Details
          </h2>

          <div class="grid grid-cols-2 gap-6 md:grid-cols-1">
            <div>
              <%= form.label :transaction_date,
                  "Transaction Date",
                  class: "block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2",
                  for: "transaction-date-input" %>
              <%= form.date_field :transaction_date,
                  id: "transaction-date-input",
                  class: "w-full input-base input-focus",
                  required: true %>
            </div>

            <div>
              <%= form.label :category,
                  "Category",
                  class: "block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2",
                  for: "transaction-category-input" %>
              <%= form.text_field :category,
                  id: "transaction-category-input",
                  class: "w-full input-base input-focus",
                  placeholder: "e.g., Utilities, Dining",
                  autocomplete: "off" %>
            </div>

            <div>
              <%= form.label :merchant,
                  "Merchant",
                  class: "block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2",
                  for: "transaction-merchant-input" %>
              <%= form.text_field :merchant,
                  id: "transaction-merchant-input",
                  class: "w-full input-base input-focus",
                  placeholder: "e.g., Trader Joe’s",
                  autocomplete: "off" %>
            </div>

            <div>
              <%= form.label :status,
                  "Status",
                  class: "block text-sm font-semibold text-neutral-700 dark:text-neutral-200 mb-2",
                  for: "transaction-status-select" %>
              <%= form.select :status,
                  Transaction.statuses.keys.map { |key| [key.humanize, key] },
                  { prompt: "Select status" },
                  id: "transaction-status-select",
                  class: "w-full px-4 py-3 border-2 border-neutral-200 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-900 text-neutral-base rounded-lg focus-ring-primary focus:border-primary-500 transition-all" %>
            </div>
          </div>
        </section>

        <div class="flex items-center justify-between gap-4 pt-6 border-t border-neutral-200 dark:border-neutral-700">
          <%= link_to "Cancel",
              transaction_path(@transaction),
              class: "btn-secondary px-5 py-3 text-sm" %>

          <%= form.submit "Update Transaction",
              class: "action-primary px-5 py-3 text-sm" %>
        </div>
      <% end %>
    </div>
<% end %>
</main>

