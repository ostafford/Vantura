<h1>Edit Transaction</h1>

<%= form_with model: @transaction, local: true do |form| %>
  <%= form.text_field :description %>
  <%= form.number_field :amount, step: 0.01 %>
  <%= form.date_field :transaction_date, value: @transaction.transaction_date&.strftime("%Y-%m-%d") %>
  <%= form.text_field :category %>
  <%= form.text_field :merchant %>
  <%= form.submit "Update Transaction" %>
<% end %>

