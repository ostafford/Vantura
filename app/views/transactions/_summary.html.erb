<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Showing</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white">
        <%= stats[:count] %> <%= 'transaction'.pluralize(stats[:count]) %>
      </p>
    </div>

    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Total Income</p>
      <p class="text-2xl font-bold text-green-600 dark:text-green-400">
        <%= number_to_currency(stats[:income_total] / 100.0, unit: "$") %>
      </p>
    </div>

    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Total Expenses</p>
      <p class="text-2xl font-bold text-red-600 dark:text-red-400">
        <%= number_to_currency(stats[:expenses_total].abs / 100.0, unit: "$") %>
      </p>
    </div>

    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Net</p>
      <p class="text-2xl font-bold <%= stats[:net] >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(stats[:net] / 100.0, unit: "$") %>
      </p>
    </div>

    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Average</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white">
        <%= number_to_currency(stats[:average_amount].abs / 100.0, unit: "$") %>
      </p>
    </div>
  </div>
</div>

