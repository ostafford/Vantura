<% content_for :title, "All Transactions - Vantura" %>
<% content_for :page_header_title, "All Transactions" %>
<% content_for :page_header_subtitle, "View and manage all your transactions" %>
<% content_for :page_header_actions do %>
    <div class="flex gap-3">
      <!-- Expenses Card -->
      <div class="bg-white dark:bg-neutral-800 border amount-negative-border rounded-lg px-4 py-3 shadow-sm">
        <p class="text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1">Expenses</p>
        <p class="text-xl font-bold amount-negative">
          $<%= number_with_precision(@transactions_data[:expense_total], precision: 2) %>
        </p>
      </div>
      
      <!-- Income Card -->
      <div class="bg-white dark:bg-neutral-800 border amount-positive-border rounded-lg px-4 py-3 shadow-sm">
        <p class="text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1">Income</p>
        <p class="text-xl font-bold amount-positive">
          $<%= number_with_precision(@transactions_data[:income_total], precision: 2) %>
        </p>
      </div>
      
      <!-- Transaction Count -->
      <div class="bg-neutral-50 dark:bg-neutral-700 border border-neutral-200 dark:border-neutral-600 rounded-lg px-4 py-3 flex items-center">
        <div class="text-center">
          <p class="text-xl font-bold text-neutral-base"><%= @transactions_data[:transactions].count %></p>
          <p class="text-xs text-neutral-muted">transactions</p>
        </div>
      </div>
    </div>
<% end %>

<main data-controller="filter recurring-modal" data-recurring-modal-target="content">
  <%= content_wrapper class: "py-6" do %>
    <%= turbo_frame_tag "transactions_content",
          data: {
            controller: "transactions-scroll",
            transactions_scroll_storage_key_value: "transactions_content_scroll",
            turbo_preserve_scroll: true
          } do %>
      <% if @account %>
        <section class="mb-6" aria-label="Transaction summary statistics">
          <div id="transactions-bento-cards-container" class="bento-grid">
            <%= render partial: "transactions/bento_cards" %>
          </div>
        </section>

        <%= render "transactions/table_section",
              transactions_data: @transactions_data,
              filters_partial: "transactions/table_filters",
              filters_locals: {
                transactions_data: @transactions_data,
                start_date: params[:start_date],
                end_date: params[:end_date],
                search_query: params[:q]
              } %>
      <% end %>
    <% end %>
  <% end %>

  <%= render 'shared/drawers/recurring_drawer' %>
</main>

