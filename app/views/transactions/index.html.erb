<% content_for :title, "All Transactions - Vantura" %>
<% content_for :page_header_title, "Your Transactions" %>
<% content_for :page_header_subtitle, "View and manage all your transactions" %>

<main data-controller="filter recurring-modal" data-recurring-modal-target="content">

  <%= content_wrapper class: "py-6" do %>
    <%# Turbo Frame for partial updates %>
    <%= turbo_frame_tag "transactions_content",
          data: {
            controller: "transactions-scroll",
            transactions_scroll_storage_key_value: "transactions_content_scroll",
            turbo_preserve_scroll: true
          } do %>
      <% if @account %>
        <!-- Transaction Summary Section -->
        <section class="mb-6" aria-label="Transaction summary statistics">
          <div id="transactions-bento-cards-container" class="bento-grid">
            <%= render partial: "transactions/bento_cards" %>
          </div>
        </section>

        <!-- Transaction Table -->
        <%= render "transactions/table_section",
            transactions_data: @transactions_data,
            filter_additional_params: { start_date: params[:start_date], end_date: params[:end_date] },
            filters_partial: "transactions/table_filters",
            filters_locals: {
              transactions_data: @transactions_data,
              start_date: params[:start_date],
              end_date: params[:end_date],
              search_query: params[:q]
            } do %>
          <% calendar_date = @transactions_data[:date] %>
          <% calendar_path = calendar_month_path(calendar_date.year, calendar_date.month) %>
          <%= link_to calendar_path,
              class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-primary-700 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 rounded-lg hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors",
              title: "View this month in calendar",
              aria: { label: "View this month in calendar" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>View in Calendar</span>
          <% end %>
        <% end %>
      <% end %>
    <% end # Close turbo_frame_tag "transactions_content" %>
  <% end %>

  <%= render 'shared/recurring_drawer' %>
</main>

