<%# Update the Bento Cards with current month stats and top merchants %>
<%= turbo_stream.update "transactions-bento-cards-container" do %>
  <%= render partial: "transactions/bento_cards" %>
<% end %>

<%# Replace the entire tbody to avoid nested <tbody> causing header misalignment %>
<%= turbo_stream.replace "transactions-table-body" do %>
  <tbody id="transactions-table-body" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
    <%= render partial: "transactions/table_body", locals: { transactions: @transactions_data[:transactions] } %>
  </tbody>
<% end %>

<%# Update the cards container for mobile view %>
<%= turbo_stream.replace "transactions-cards-container" do %>
  <%= render 'transactions/transaction_cards', transactions: @transactions_data[:transactions] %>
<% end %>

<%# Refresh filters to keep date/search controls in sync with current state %>
<%= turbo_stream.update "transactions-table-filters" do %>
  <%= render "transactions/table_filters",
      transactions_data: @transactions_data,
      start_date: params[:start_date],
      end_date: params[:end_date],
      search_query: params[:q] %>
<% end %>

<%# Re-render the header to keep navigation, heading, and actions in sync %>
<%= turbo_stream.replace "transactions-table-header" do %>
  <header id="transactions-table-header" class="px-4 py-4 sm:px-6 sm:py-5 border-b bg-gray-50 dark:bg-gray-900 border-gray-200 dark:border-gray-700">
    <%= render "transactions/navigation_controls",
          transactions_data: @transactions_data,
          filter_additional_params: { start_date: params[:start_date], end_date: params[:end_date] } do %>
      <% calendar_date = @transactions_data[:date] %>
      <% calendar_path = calendar_month_path(calendar_date.year, calendar_date.month) %>
      <%= link_to calendar_path,
          class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-primary-700 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 rounded-lg hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors",
          title: "View this month in calendar",
          aria: { label: "View this month in calendar" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <span>View in Calendar</span>
      <% end %>
    <% end %>
  </header>
<% end %>

