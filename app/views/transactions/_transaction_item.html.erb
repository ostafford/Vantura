<div id="transaction-<%= transaction.id %>"
     class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors cursor-pointer"
     data-action="click->transaction-modal#open"
     data-transaction-id="<%= transaction.id %>"
     data-controller="transaction-modal">
  <div class="flex items-center justify-between">
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-1">
        <h4 class="text-sm font-medium text-gray-900 dark:text-white truncate">
          <%= transaction.description || transaction.raw_text %>
        </h4>
        <span class="ml-4 text-sm font-semibold flex-shrink-0 <%= transaction.amount_cents < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
          <%= transaction.amount_cents < 0 ? '-' : '+' %><%= number_to_currency(transaction.amount_cents.abs / 100.0, unit: "$") %>
        </span>
      </div>
      <div class="flex items-center space-x-2 text-xs text-gray-500 dark:text-gray-400">
        <span><%= transaction.created_at_up&.strftime("%b %d, %Y") || transaction.created_at.strftime("%b %d, %Y") %></span>
        <% if transaction.category.present? %>
          <span>•</span>
          <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded">
            <%= transaction.category.name %>
          </span>
        <% end %>
        <% if transaction.account.present? %>
          <span>•</span>
          <span><%= transaction.account.display_name %></span>
        <% end %>
        <span class="px-2 py-1 rounded <%= 
          transaction.status == 'settled' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 
          transaction.status == 'held' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200' : 
          'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200' 
        %>">
          <%= transaction.status.capitalize %>
        </span>
      </div>
      <% if transaction.tags.any? %>
        <div class="mt-2 flex flex-wrap gap-1">
          <% transaction.tags.each do |tag| %>
            <span class="px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded dark:bg-blue-900 dark:text-blue-300">
              <%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="ml-4 flex-shrink-0">
      <button type="button"
          class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
          data-action="click->transaction-modal#open"
          data-transaction-id="<%= transaction.id %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </button>
    </div>
  </div>
</div>

