<%= form_with url: transactions_path, method: :get, 
    data: { 
      controller: "auto-submit",
      turbo_frame: "transaction-list,transaction-summary",
      turbo_action: "advance"
    },
    class: "bg-white dark:bg-gray-800 rounded-lg shadow p-6" do |f| %>

  <!-- Basic Filters Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
    <!-- Search -->
    <div>
      <%= f.label :search, "Search", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.text_field :search, 
          value: current_filters[:search],
          placeholder: "Search description...",
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
          data: { action: "input->auto-submit#debouncedSubmit" } %>
    </div>

    <!-- Category -->
    <div>
      <%= f.label :category_id, "Category", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.select :category_id,
          options_from_collection_for_select(categories, :id, :name, current_filters[:category_id]),
          { include_blank: "All Categories" },
          { 
            class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
            data: { action: "change->auto-submit#submit" }
          } %>
    </div>

    <!-- Account -->
    <div>
      <%= f.label :account_id, "Account", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.select :account_id,
          options_from_collection_for_select(accounts, :id, :display_name, current_filters[:account_id]),
          { include_blank: "All Accounts" },
          { 
            class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
            data: { action: "change->auto-submit#submit" }
          } %>
    </div>
  </div>

  <!-- Second Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
    <!-- Transaction Type -->
    <div>
      <%= f.label :transaction_type, "Type", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.select :transaction_type,
          options_for_select([
            ["All", ""],
            ["Income", "income"],
            ["Expenses", "expense"]
          ], current_filters[:transaction_type]),
          {},
          { 
            class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
            data: { action: "change->auto-submit#submit" }
          } %>
    </div>

    <!-- Amount Range -->
    <div>
      <%= f.label :min_amount, "Min Amount", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.number_field :min_amount,
          value: current_filters[:min_amount],
          step: 0.01,
          placeholder: "0.00",
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
          data: { action: "input->auto-submit#debouncedSubmit" } %>
    </div>

    <div>
      <%= f.label :max_amount, "Max Amount", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.number_field :max_amount,
          value: current_filters[:max_amount],
          step: 0.01,
          placeholder: "0.00",
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
          data: { action: "input->auto-submit#debouncedSubmit" } %>
    </div>
  </div>

  <!-- Date Range Row -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <%= f.label :start_date, "Start Date", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.date_field :start_date,
          value: current_filters[:start_date],
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
          data: { action: "change->auto-submit#submit" } %>
    </div>

    <div>
      <%= f.label :end_date, "End Date", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <%= f.date_field :end_date,
          value: current_filters[:end_date],
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
          data: { action: "change->auto-submit#submit" } %>
    </div>
  </div>

  <!-- Active Filters Pills -->
  <% active_filters = current_filters.to_h.reject { |k, v| v.blank? } %>
  <% if active_filters.present? %>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Active Filters:</span>
      <% active_filters.each do |key, value| %>
        <% filter_label = case key.to_s
             when "category_id"
               "Category: #{categories.find_by(id: value)&.name || 'Unknown'}"
             when "account_id"
               "Account: #{accounts.find_by(id: value)&.display_name || 'Unknown'}"
             when "transaction_type"
               "Type: #{value.capitalize}"
             else
               "#{key.to_s.humanize}: #{value}"
           end %>
        <span class="inline-flex items-center px-3 py-1 text-sm font-medium text-blue-800 bg-blue-100 rounded-full dark:bg-blue-900 dark:text-blue-300">
          <%= filter_label %>
          <button type="button"
              class="ml-2 inline-flex items-center text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-500"
              data-action="click->transaction-filter#removeFilter"
              data-filter-name="<%= key %>">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </span>
      <% end %>
      <%= link_to "Clear All", transactions_path,
          class: "inline-flex items-center px-3 py-1 text-sm font-medium text-gray-800 bg-gray-100 rounded-full hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600",
          data: { turbo_frame: "transaction-list,transaction-summary", turbo_action: "advance" } %>
    </div>
  <% end %>

  <!-- Advanced Filters Toggle -->
  <div class="flex justify-between items-center">
    <button type="button"
        class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
        data-action="click->transaction-filter#toggleAdvanced">
      <span data-transaction-filter-target="advancedToggleText">▼ Advanced Filters</span>
    </button>
    
    <!-- Save Filter Preset Placeholder Button -->
    <% if active_filters.present? %>
      <button type="button"
          class="text-sm text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300"
          data-action="click->transaction-filter#savePreset"
          title="Save filter preset (coming soon)">
        💾 Save Filter Preset
      </button>
    <% end %>
  </div>

  <!-- Advanced Filters (hidden by default) -->
  <div class="hidden mt-4 pt-4 border-t border-gray-200 dark:border-gray-700"
       data-transaction-filter-target="advancedFilters">
    <%= render "transactions/advanced_filters", f: f, tags: tags, current_filters: current_filters %>
  </div>
<% end %>

