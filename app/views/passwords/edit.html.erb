<% content_for :title, "Update Password - Vantura" %>

<main id="password-update-page-container" aria-label="Password update page">
  <!-- Breadcrumb Navigation -->
  <nav id="breadcrumb-navigation" class="bg-gradient-to-r from-neutral-100 to-white dark:from-primary-900 dark:to-primary-950 border-b border-primary-700/20 dark:border-primary-900/30" aria-label="Breadcrumb">
    <%= content_wrapper class: "py-2" do %>
      <ol id="breadcrumb-list" class="flex items-center gap-2">
        <% if Current.user.present? %>
          <li>
            <%= link_to settings_path, id: "breadcrumb-settings-link", class: "text-sm text-neutral-600 dark:text-neutral-400 hover-link-primary font-medium" do %>
              Settings
            <% end %>
          </li>
          <li>
            <span class="text-sm text-neutral-400 dark:text-neutral-500" aria-hidden="true">/</span>
          </li>
        <% end %>
        <li>
          <span id="breadcrumb-current-page" class="text-sm text-neutral-900 dark:text-white font-medium">Update Password</span>
        </li>
      </ol>
    <% end %>
  </nav>

  <div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-6 md:min-h-[calc(100vh-6rem)] md:px-4 md:py-12">
  <div class="max-w-md w-full mx-auto">
    <!-- Password Update Card -->
    <section id="user-password-update-container" class="overflow-hidden rounded-2xl bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 shadow-deep">
      <!-- Header -->
      <header id="user-password-update-header" class="px-4 py-4 bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 md:px-8 md:py-6">
        <h1 id="user-password-update-heading" class="text-2xl md:text-3xl font-bold text-white">Update Password</h1>
        <p class="text-xs md:text-sm font-normal text-primary-100 mt-1">Enter your new password below</p>
      </header>

      <!-- Form -->
      <%= form_with model: @user, url: password_path(params[:token]), method: :put, id: "user-password-update-form", aria_labelledby: "user-password-update-heading", class: "p-4 space-y-4 md:p-8 md:space-y-6" do |form| %>
        <!-- Error Messages -->
        <% if @user.errors.any? %>
          <div id="user-password-update-errors-container" 
               class="p-4 mb-4 rounded-lg form-error-border form-error-bg" 
               role="alert">
            <h3 class="text-sm form-error-text mb-2">
              <%= pluralize(@user.errors.count, "error") %> prevented your password from being reset:
            </h3>
            <ul class="text-sm form-error space-y-1 ml-5 list-disc">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Password Field -->
        <div id="user-password-update-password-field">
          <label for="user-password-update-password-input" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">
            New Password
          </label>
          <%= form.password_field :password,
              id: "user-password-update-password-input",
              required: true,
              autocomplete: "new-password",
              placeholder: "Enter new password",
              maxlength: 72,
              aria_required: true,
              aria_invalid: (@user.errors[:password].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:password].any? ? "user-password-update-password-error" : nil),
              class: "w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 text-neutral-900 dark:text-white transition-all focus-ring focus:border-transparent" %>
          <% if @user.errors[:password].any? %>
            <div id="user-password-update-password-error" class="form-error mt-1" role="alert">
              <%= @user.errors[:password].first %>
            </div>
          <% end %>
        </div>

        <!-- Password Confirmation Field -->
        <div id="user-password-update-confirmation-field">
          <label for="user-password-update-confirmation-input" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">
            Confirm New Password
          </label>
          <%= form.password_field :password_confirmation,
              id: "user-password-update-confirmation-input",
              required: true,
              autocomplete: "new-password",
              placeholder: "Repeat new password",
              maxlength: 72,
              aria_required: true,
              aria_invalid: (@user.errors[:password_confirmation].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:password_confirmation].any? ? "user-password-update-confirmation-error" : nil),
              class: "w-full px-4 py-3 rounded-xl border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 text-neutral-900 dark:text-white transition-all focus-ring focus:border-transparent" %>
          <% if @user.errors[:password_confirmation].any? %>
            <div id="user-password-update-confirmation-error" class="form-error mt-1" role="alert">
              <%= @user.errors[:password_confirmation].first %>
            </div>
          <% end %>
        </div>

        <!-- Submit Button -->
        <div id="user-password-update-actions">
          <%= form.submit "Save",
              id: "user-password-update-submit-button",
              class: "btn-primary w-full min-h-[44px]" %>
        </div>
      <% end %>
    </section>
  </div>
</main>
