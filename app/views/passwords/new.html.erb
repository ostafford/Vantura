<% content_for :title, "Reset Password - Vantura" %>

<main id="password-reset-page-container" aria-label="Password reset page">
  <!-- Breadcrumb Navigation -->
  <nav id="breadcrumb-navigation" class="bg-gradient-to-r from-cream-100 to-white dark:from-primary-900 dark:to-primary-950 border-b border-primary-700/20 dark:border-primary-900/30" aria-label="Breadcrumb">
    <%= content_wrapper class: "py-2" do %>
      <ol id="breadcrumb-list" class="flex items-center gap-2">
        <% if Current.user.present? %>
          <li>
            <%= link_to settings_path, id: "breadcrumb-settings-link", class: "text-sm text-gray-600 dark:text-gray-400 hover:text-primary-700 dark:hover:text-primary-400 font-medium transition-colors" do %>
              Settings
            <% end %>
          </li>
          <li>
            <span class="text-sm text-gray-400 dark:text-gray-500" aria-hidden="true">/</span>
          </li>
        <% end %>
        <li>
          <span id="breadcrumb-current-page" class="text-sm text-gray-900 dark:text-white font-medium">Reset Password</span>
        </li>
      </ol>
    <% end %>
  </nav>

  <div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-6 md:min-h-[calc(100vh-6rem)] md:px-4 md:py-12">
  <div class="max-w-md w-full mx-auto">
    <!-- Password Reset Card -->
    <section id="user-password-reset-container" class="overflow-hidden rounded-2xl bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 shadow-deep">
      <!-- Header -->
      <header id="user-password-reset-header" class="px-4 py-4 bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 md:px-8 md:py-6">
        <h1 id="user-password-reset-heading" class="text-2xl md:text-3xl font-bold text-white">Reset Password</h1>
        <p class="text-xs md:text-sm font-normal text-orange-100 mt-1">Enter your email to receive reset instructions</p>
      </header>

      <!-- Form -->
      <%= form_with url: passwords_path, id: "user-password-reset-form", aria_labelledby: "user-password-reset-heading", class: "p-4 space-y-4 md:p-8 md:space-y-6" do |form| %>
        <% if flash[:alert] %>
          <div id="user-password-reset-error-alert" 
               class="p-4 mb-4 rounded-lg border border-red-200 bg-red-50 dark:border-red-800 dark:bg-red-900/20" 
               role="alert">
            <p class="text-sm font-medium text-red-900 dark:text-red-100">
              <%= flash[:alert] %>
            </p>
          </div>
        <% end %>

        <!-- Email Address -->
        <div id="user-password-reset-email-field">
          <label for="user-password-reset-email-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Email Address
          </label>
          <%= form.email_field :email_address,
              id: "user-password-reset-email-input",
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "you@example.com",
              value: params[:email_address],
              aria_required: true,
              aria_invalid: false,
              aria_describedby: nil,
              class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-all focus:ring-2 focus:ring-primary-700 focus:border-transparent" %>
        </div>

        <!-- Submit Button -->
        <div id="user-password-reset-actions">
          <%= form.submit "Email reset instructions",
              id: "user-password-reset-submit-button",
              class: "relative w-full min-h-[44px] px-6 py-3 rounded-xl text-center font-semibold text-white bg-gradient-to-r from-primary-700 to-primary-500 shadow-lg transition-all hover:from-primary-900 hover:to-primary-600" %>
        </div>
      <% end %>
    </section>
  </div>
</main>
