<% content_for :title, "Trends - Vantura" %>

<div>
  <!-- Page Header -->
  <%= render 'shared/page_header', title: "Trends & Insights", subtitle: "Analyze your financial patterns and trends" %>

  <%= content_wrapper class: "py-6" do %>
    <% if @account %>
      <!-- Time Range Selector and View Type Toggle -->
      <div class="mb-6 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
        <!-- Time Range Selector -->
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Time Range:</span>
          <% [3, 6, 12, "all"].each do |months| %>
            <% active = (session[:trends_months] || 6).to_s == months.to_s %>
            <%= link_to trends_path(months: months),
                        class: "px-4 py-2 text-sm font-medium rounded-lg transition-colors #{active ? 'bg-primary-700 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'}" do %>
              <%= months == "all" ? "All" : "#{months}M" %>
            <% end %>
          <% end %>
        </div>

        <!-- View Type Toggle -->
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">View by:</span>
          <% ["category", "merchant"].each do |view_type| %>
            <% active = (session[:trends_view_type] || "category") == view_type %>
            <%= button_to update_preference_trends_path,
                          method: :patch,
                          params: { view_type: view_type },
                          class: "px-4 py-2 text-sm font-medium rounded-lg transition-colors #{active ? 'bg-primary-700 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'}" do %>
              <%= view_type.capitalize %>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Insights Panel -->
      <% if @trends_stats&.dig(:insights)&.present? %>
        <section class="mb-6" aria-label="Financial insights">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Actionable Insights</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch">
            <% @trends_stats[:insights].each do |insight| %>
              <%= render 'shared/insight_card', insight: insight %>
            <% end %>
          </div>
        </section>
      <% end %>

      <!-- Charts Section -->
      <% if trends_historical_data.present? %>
        <section class="mb-6" aria-label="Financial trends charts">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Trends & Visualizations</h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <!-- Spending Trends Chart (Line Chart) -->
            <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Spending Trends</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Income vs Expenses over time</p>
              </div>
              <div data-controller="chart"
                   data-chart-type-value="line"
                   data-chart-series-value="<%= [
                     { name: 'Income', data: trends_historical_data.map { |d| d[:income] } },
                     { name: 'Expenses', data: trends_historical_data.map { |d| d[:expenses] } },
                     { name: 'Net Savings', data: trends_historical_data.map { |d| d[:net_savings] } }
                   ].to_json %>"
                   data-chart-labels-value="<%= trends_historical_data.map { |d| d[:month_name] }.to_json %>"
                   data-chart-colors-value="<%= ['#10B981', '#EF4444', '#3B82F6'].to_json %>"
                   data-chart-height-value="300"
                   id="spending-trends-chart">
              </div>
            </div>

            <!-- Category/Merchant Breakdown Chart (Donut Chart) -->
            <% if trends_category_breakdown.present? %>
              <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
                <div class="mb-4">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top <%= (session[:trends_view_type] || "category").capitalize %> Breakdown</h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Distribution of spending</p>
                </div>
                <div data-controller="chart"
                     data-chart-type-value="donut"
                     data-chart-series-value="<%= trends_category_breakdown.map { |item| item[:amount] }.to_json %>"
                     data-chart-labels-value="<%= trends_category_breakdown.map { |item| item[:name] }.to_json %>"
                     data-chart-colors-value="<%= ['#3B82F6', '#EF4444', '#10B981', '#F59E0B', '#8B5CF6', '#06B6D4', '#84CC16', '#F97316', '#EC4899', '#6B7280'].to_json %>"
                     data-chart-height-value="300"
                     id="category-breakdown-chart">
                </div>
              </div>
            <% end %>
          </div>

          <!-- Savings Rate Trend Chart (Line Chart) -->
          <% if trends_savings_rate_trend.present? %>
            <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Savings Rate Trend</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Percentage of income saved over time</p>
              </div>
              <div data-controller="chart"
                   data-chart-type-value="line"
                   data-chart-series-value="<%= [{ name: 'Savings Rate', data: trends_savings_rate_trend.map { |d| d[:savings_rate] } }].to_json %>"
                   data-chart-labels-value="<%= trends_savings_rate_trend.map { |d| d[:month_name] }.to_json %>"
                   data-chart-colors-value="<%= ['#10B981'].to_json %>"
                   data-chart-height-value="300"
                   id="savings-rate-chart">
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <!-- Bento Grid Layout -->
      <div class="bento-grid mb-6">
        
        <!-- 1. Key Insights Hub (2x2 Hero Card) -->
        <%= render 'shared/bento_cards/hero_card',
            title: "Financial Insights",
            subtitle: "#{trends_current_date.strftime('%B %Y')}",
            description: "Track your financial trends, compare month-over-month changes, and gain insights into your spending patterns.",
            icon: 'chart',
            size: 'bento-span-2 bento-row-span-2',
            color: 'success' do %>
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between pb-3 border-b border-white/20">
              <span class="text-white/80 text-sm">Net Savings</span>
              <%# White for positive, expense color for negative - both have good contrast on sage green background %>
              <span class="text-2xl font-bold <%= trends_net_savings >= 0 ? 'text-white' : 'text-expense-400 dark:text-expense-200 drop-shadow-md' %>">
                <%= trends_net_savings >= 0 ? "+" : "-" %>$<%= number_with_precision(trends_net_savings.abs, precision: 2) %>
              </span>
            </div>
            <div class="flex items-center justify-between pb-3 border-b border-white/20">
              <span class="text-white/80 text-sm">Active Recurring</span>
              <span class="text-xl font-semibold text-white"><%= trends_active_recurring_count %> patterns</span>
            </div>
          </div>
        <% end %>

        <!-- 2. Net Savings Card (1x1) -->
        <%
          savings_positive = trends_net_savings >= 0
          savings_color = savings_positive ? 'green' : 'red'  # Green for positive, Red for negative
          savings_icon = savings_positive ? 'arrow-up' : 'arrow-down'
          savings_subtitle = savings_positive ? "Surplus" : "Deficit"
        %>
        <%= render 'shared/bento_cards/stat_card',
            title: "Net Savings",
            value: "#{savings_positive ? '+' : '-'}$#{number_with_precision(trends_net_savings.abs, precision: 2)}",
            subtitle: "<span class='font-semibold text-gray-900 dark:text-white'>#{savings_subtitle}</span>".html_safe,
            detail: "#{trends_current_date.strftime('%B %Y')}",
            icon: savings_icon,
            color: savings_color,  # Stat card uses red/green correctly
            size: 'bento-span-1 bento-row-span-1',
            id: 'net_savings_card' %>

        <!-- 3. Active Recurring Card (1x1) - Clickable -->
        <%= render 'shared/bento_cards/stat_card',
            title: "Active Recurring",
            value: trends_active_recurring_count.to_s,
            subtitle: "<span class='font-semibold text-gray-900 dark:text-white'>#{trends_active_recurring_count == 1 ? 'pattern' : 'patterns'}</span>".html_safe,
            detail: "Click to manage",
            icon: 'refresh',
            color: 'blue',
            size: 'bento-span-1 bento-row-span-1',
            link: recurring_transactions_path %>

        <!-- 4. Month Comparison Card (1x1) - Compact Version -->
        <div class="bento-span-1 bento-row-span-1 bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
          <div class="flex flex-col h-full">
            <!-- Header -->
            <div class="mb-3">
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Month Comparison</h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                <%= trends_current_date.strftime('%b') %> vs <%= trends_current_date.prev_month.strftime('%b') %>
              </p>
            </div>

            <!-- Compact Comparison -->
            <div class="flex-1 space-y-2 text-sm">
              <!-- Income -->
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-success-500 dark:bg-success-300"></div>
                  <span class="text-xs text-gray-600 dark:text-gray-400">Income</span>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-xs font-semibold text-success-500 dark:text-success-300">
                    $<%= number_with_precision(trends_current_month_income, precision: 0) %>
                  </span>
                  <% if trends_income_change_pct != 0 %>
                    <span class="text-xs <%= trends_income_change_pct > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                      <%= trends_income_change_pct > 0 ? "↑" : "↓" %><%= trends_income_change_pct.abs %>%
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- Expenses -->
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-expense-500 dark:bg-expense-400"></div>
                  <span class="text-xs text-gray-600 dark:text-gray-400">Expenses</span>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-xs font-semibold text-expense-500 dark:text-expense-400">
                    $<%= number_with_precision(trends_current_month_expenses, precision: 0) %>
                  </span>
                  <% if trends_expense_change_pct != 0 %>
                    <span class="text-xs <%= trends_expense_change_pct > 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                      <%= trends_expense_change_pct > 0 ? "↑" : "↓" %><%= trends_expense_change_pct.abs %>%
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- Net -->
              <div class="flex items-center justify-between pt-2 border-t border-gray-200 dark:border-gray-700">
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-primary-700 dark:bg-primary-500"></div>
                  <span class="text-xs font-semibold text-gray-900 dark:text-white">Net</span>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-xs font-bold <%= trends_net_savings >= 0 ? 'text-success-600 dark:text-success-400' : 'text-expense-600 dark:text-expense-400' %>">
                    <%= trends_net_savings >= 0 ? "+" : "-" %>$<%= number_with_precision(trends_net_savings.abs, precision: 0) %>
                  </span>
                  <% if trends_net_change_pct != 0 %>
                    <span class="text-xs <%= trends_net_change_pct > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                      <%= trends_net_change_pct > 0 ? "↑" : "↓" %><%= trends_net_change_pct.abs %>%
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 5. Top Merchant Card (1x2) - Expanded -->
        <div class="bento-span-1 bento-row-span-2 bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
          <div class="flex flex-col h-full">
            <!-- Header -->
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top <%= (session[:trends_view_type] || "category").capitalize %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                <%= trends_current_date.strftime('%B %Y') %>
              </p>
            </div>

            <!-- Category/Merchant Details -->
            <div class="flex-1 space-y-4">
              <% top_item = trends_category_breakdown.first || { name: "No data", amount: 0, count: 0 } %>
              <!-- Item Name -->
              <div class="pb-3 border-b border-gray-200 dark:border-gray-700">
                <p class="text-xs text-gray-500 dark:text-gray-400 mb-1"><%= (session[:trends_view_type] || "category").capitalize %> Name</p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">
                  <%= truncate(top_item[:name], length: 25) %>
                </p>
              </div>

              <!-- Total Amount -->
              <div class="pb-3 border-b border-gray-200 dark:border-gray-700">
                <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Total Spent</p>
                <p class="text-2xl font-bold text-income-500 dark:text-income-400">
                  $<%= number_with_precision(top_item[:amount], precision: 2) %>
                </p>
              </div>

              <!-- Percentage -->
              <% total_expenses = trends_current_month_expenses %>
              <% if total_expenses > 0 %>
                <% item_pct = ((top_item[:amount] / total_expenses) * 100).round(1) %>
                <div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">of Total Expenses</p>
                  <p class="text-3xl font-bold text-primary-700 dark:text-primary-400">
                    <%= item_pct %>%
                  </p>
                </div>
              <% else %>
                <div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">of Total Expenses</p>
                  <p class="text-3xl font-bold text-primary-700 dark:text-primary-400">
                    N/A
                  </p>
                </div>
              <% end %>
            </div>

            <!-- Footer -->
            <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
              <p class="text-xs text-gray-500 dark:text-gray-400">
                Based on real transactions
              </p>
            </div>
          </div>
        </div>

      </div>

      <!-- Additional Info Section -->
      <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep p-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-success-500/10 dark:bg-success-700/20 rounded-xl">
              <svg class="w-6 h-6 text-success-500 dark:text-success-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">About Trends & Insights</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
              This page provides a quick overview of your financial trends for the current month. All calculations are based on <strong>real transactions only</strong> (hypothetical/projected transactions are excluded).
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-600 dark:text-gray-400">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success-500 dark:text-success-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Month-over-month comparisons</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success-500 dark:text-success-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Real-time data from Up Bank</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success-500 dark:text-success-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Net savings tracking</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success-500 dark:text-success-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Top merchant analysis</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    <% else %>
      <!-- No Account Message -->
      <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-lg shadow-deep p-12 text-center">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">No account found</h2>
        <p class="text-gray-600 dark:text-gray-400">Please sync your Up Bank account first.</p>
        <%= link_to "Go to Settings", settings_path, class: "inline-flex items-center mt-4 px-6 py-3 bg-primary-700 text-white rounded-lg hover:bg-primary-900 transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>
