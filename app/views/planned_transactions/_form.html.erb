<div data-controller="planned-transaction-form" data-planned-transaction-form-target="form">
<%= form_with model: @planned_transaction,
    data: {
      turbo_frame: "planned-transaction-form"
    } do |form| %>

  <% if @planned_transaction.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg dark:bg-red-900/20 dark:border-red-800" role="alert">
      <h4 class="text-sm font-semibold text-red-800 dark:text-red-200 mb-2">
        <%= pluralize(@planned_transaction.errors.count, "error") %> prohibited this planned transaction from being saved:
      </h4>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-300">
        <% @planned_transaction.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <!-- Description -->
    <%= render "shared/form_input",
        form: form,
        field: :description,
        label: "Description",
        type: "text",
        placeholder: "Enter description",
        required: true %>

    <!-- Amount -->
    <div class="mb-4">
      <%= form.label :amount_cents, "Amount (AUD)", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white after:content-['*'] after:ml-0.5 after:text-red-500" %>
      <div class="relative">
        <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500 dark:text-gray-400">$</span>
        <%= form.number_field :amount_dollars,
            step: 0.01,
            min: 0,
            placeholder: "0.00",
            required: true,
            pattern: "[0-9]+(\.[0-9]{1,2})?",
            value: form.object.amount_cents ? (form.object.amount_cents / 100.0) : nil,
            class: "block w-full pl-8 pr-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
            data: {
              planned_transaction_form_target: "amountInput",
              action: "input->planned-transaction-form#updateAmount"
            } %>
        <%= form.hidden_field :amount_cents, data: { planned_transaction_form_target: "amountCents" } %>
      </div>
      <% if form.object.errors[:amount_cents].any? %>
        <p class="mt-2 text-sm text-red-600 dark:text-red-400">
          <%= form.object.errors[:amount_cents].first %>
        </p>
      <% end %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
        Enter amount in dollars (e.g., 50.00 for $50.00)
      </p>
    </div>

    <!-- Transaction Type -->
    <%= render "shared/form_input",
        form: form,
        field: :transaction_type,
        label: "Type",
        type: "select",
        options: [["Expense", "expense"], ["Income", "income"]],
        required: true %>

    <!-- Planned Date -->
    <%= render "shared/form_input",
        form: form,
        field: :planned_date,
        label: "Date",
        type: "date",
        required: true %>

    <!-- Category -->
    <%= render "shared/form_input",
        form: form,
        field: :category_id,
        label: "Category",
        type: "select",
        options: options_from_collection_for_select(Category.all.order(:name), :id, :name, form.object.category_id),
        prompt: "Select category (optional)" %>

    <!-- Recurrence Toggle -->
    <div class="mb-4">
      <label class="relative inline-flex items-center cursor-pointer">
        <%= form.check_box :is_recurring,
            class: "sr-only peer",
            data: {
              planned_transaction_form_target: "recurrenceToggle",
              action: "change->planned-transaction-form#toggleRecurrence"
            } %>
        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600"></div>
        <span class="ml-3 text-sm font-medium text-gray-900 dark:text-gray-300">Recurring Transaction</span>
      </label>
    </div>

    <!-- Recurrence Fields (hidden by default) -->
    <div class="hidden space-y-4"
         data-planned-transaction-form-target="recurrenceFields">
      
      <!-- Recurrence Pattern -->
      <%= render "shared/form_input",
          form: form,
          field: :recurrence_pattern,
          label: "Recurrence Pattern",
          type: "select",
          options: [
            ["Daily", "daily"],
            ["Weekly", "weekly"],
            ["Monthly", "monthly"],
            ["Yearly", "yearly"]
          ],
          prompt: "Select pattern",
          css_class: "recurrence-pattern-select",
          data: {
            planned_transaction_form_target: "recurrencePattern",
            action: "change->planned-transaction-form#updatePreview"
          } %>

      <!-- Recurrence End Date -->
      <%= render "shared/form_input",
          form: form,
          field: :recurrence_end_date,
          label: "End Date (optional)",
          type: "date",
          help_text: "Leave blank for indefinite recurrence",
          css_class: "recurrence-end-date-input",
          data: {
            planned_transaction_form_target: "recurrenceEndDate",
            action: "change->planned-transaction-form#updatePreview"
          } %>

      <!-- Recurrence Preview -->
      <div class="mb-4 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg"
           data-planned-transaction-form-target="recurrencePreview">
        <p class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-2">Next Occurrences:</p>
        <div class="text-xs text-gray-600 dark:text-gray-400">
          <p>Select a recurrence pattern to see preview</p>
        </div>
      </div>
    </div>

    <!-- Hidden field for amount conversion -->
    <%= form.hidden_field :amount_currency, value: "AUD" %>
  </div>

  <!-- Modal Footer -->
  <div class="flex items-center justify-end p-4 md:p-5 border-t border-gray-200 dark:border-gray-700 gap-3">
    <button type="button"
        class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700 dark:focus:ring-gray-700"
        data-action="click->planned-transaction#close">
      Cancel
    </button>
    <%= form.submit (@planned_transaction.new_record? ? "Create" : "Update"),
        class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
  </div>
<% end %>
</div>

