<h1>Planned Transaction</h1>

<p><strong>Description:</strong> <%= @planned_transaction.description %></p>
<p><strong>Amount:</strong> <%= number_to_currency(@planned_transaction.amount_cents / 100.0) %></p>
<p><strong>Date:</strong> <%= @planned_transaction.planned_date %></p>
<p><strong>Type:</strong> <%= @planned_transaction.transaction_type %></p>
<% if @planned_transaction.is_recurring %>
  <p><strong>Recurring:</strong> Yes</p>
  <p><strong>Pattern:</strong> <%= @planned_transaction.recurrence_pattern %></p>
<% end %>

<%= link_to "Edit", edit_planned_transaction_path(@planned_transaction) %>
<%= link_to "Delete", @planned_transaction, method: :delete, data: { confirm: "Are you sure?" } %>
<%= link_to "Back to Planned Transactions", planned_transactions_path %>

