<%= turbo_stream.remove "planned-transaction-form" %>

<%# Close modal after form removal - with debugging %>
<%= turbo_stream.append "body" do %>
  <script>
    console.log('[TurboStream] Script executing for modal close')
    
    // Close modal immediately when this script executes
    setTimeout(function() {
      console.log('[TurboStream] Attempting direct modal close')
      const modal = document.getElementById('planned-transaction-modal');
      if (modal) {
        console.log('[TurboStream] Modal found, closing')
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('overflow-hidden');
        
        // Try Stimulus controller close method
        if (window.Stimulus) {
          const modalElement = document.getElementById('planned-transaction-modal');
          if (modalElement) {
            const controller = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'planned-transaction');
            if (controller) {
              console.log('[TurboStream] Stimulus controller found, calling close')
              if (typeof controller.close === 'function') {
                controller.close();
              } else {
                console.log('[TurboStream] Controller close method not found')
              }
            } else {
              console.log('[TurboStream] Stimulus controller not found for modal element')
            }
          } else {
            console.log('[TurboStream] Modal element not found for Stimulus lookup')
          }
        } else {
          console.log('[TurboStream] window.Stimulus not available')
        }
        
        // Dispatch custom event for other listeners
        console.log('[TurboStream] Dispatching planned-transaction-modal-closed event')
      document.dispatchEvent(new CustomEvent('planned-transaction-modal-closed'));
      } else {
        console.log('[TurboStream] Modal not found by ID')
      }
    }, 100);
  </script>
<% end %>

<%# Update day details frame if the affected day is currently selected %>
<%# Check if there's a selected_date in the URL or if the planned_date matches current selection %>
<% selected_date_param = request.referer&.match(/selected_date=([^&]+)/)&.captures&.first %>
<% if selected_date_param %>
  <% selected_date = Date.parse(selected_date_param) rescue nil %>
  <% if selected_date && selected_date == @planned_transaction.planned_date %>
    <%# Recalculate projection for the selected day %>
    <% result = CalendarProjectionService.calculate(
          user: @planned_transaction.user,
          start_date: selected_date,
          end_date: selected_date
        ) %>
    <% projection = result[:projection_data][selected_date] || {
          balance_cents: 0,
          planned_transactions: [],
          actual_transactions: [],
          actual_count: 0
        } %>
    <% year = selected_date.year %>
    <% month = selected_date.month %>
    <%= turbo_stream.replace "day-details" do %>
      <%= render "calendar/selected_day_frame",
          date: selected_date,
          projection: projection,
          frame_id: "day-details" %>
    <% end %>
  <% end %>
<% end %>

