<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl w-full space-y-8">
    <!-- Step Indicator -->
    <%= render "onboarding/step_indicator", current_step: 1, total_steps: 3 %>

    <!-- Main Card -->
    <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg p-8">
      <div class="text-center mb-8">
        <div class="flex justify-center items-center mb-4">
          <!-- Sign Up Icon -->
          <svg class="w-16 h-16 text-blue-600 dark:text-blue-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM3 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Create Your Account
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Start tracking your finances and managing your projects.
        </p>
      </div>

      <!-- Flash Messages -->
      <%= render "shared/flash_messages" %>

      <!-- Form -->
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), 
          html: { class: "space-y-6", data: { controller: "form" } }) do |f| %>
        
        <%= render "devise/shared/error_messages", resource: resource %>

        <!-- Email Field -->
        <div>
          <%= f.label :email, "Email address", 
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email",
              class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white sm:text-sm",
              placeholder: "you@example.com",
              required: true %>
        </div>

        <!-- Password Field -->
        <div>
          <%= f.label :password, "Password", 
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="relative" data-controller="password-visibility">
            <%= f.password_field :password, 
                autocomplete: "new-password",
                data: { 
                  password_visibility_target: "input"
                },
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white sm:text-sm pr-10",
                placeholder: "••••••••",
                required: true %>
            <button type="button" 
                    data-password-visibility-target="button"
                    data-action="click->password-visibility#toggle"
                    class="absolute inset-y-0 right-0 pr-3 flex items-center">
              <svg data-password-visibility-target="eyeIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              <svg data-password-visibility-target="eyeSlashIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.29 3.29m0 0L3 15.29m3.29-9.29L12 12m0 0l3.29 3.29M12 12l-3.29-3.29m0 0L12 8.71"/>
              </svg>
            </button>
          </div>
          <% if @minimum_password_length %>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              <%= @minimum_password_length %> characters minimum
            </p>
          <% end %>
        </div>

        <!-- Password Confirmation Field -->
        <div>
          <%= f.label :password_confirmation, "Confirm password", 
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="relative" data-controller="password-visibility">
            <%= f.password_field :password_confirmation, 
                autocomplete: "new-password",
                data: { 
                  password_visibility_target: "input"
                },
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white sm:text-sm pr-10",
                placeholder: "••••••••",
                required: true %>
            <button type="button" 
                    data-password-visibility-target="button"
                    data-action="click->password-visibility#toggle"
                    class="absolute inset-y-0 right-0 pr-3 flex items-center">
              <svg data-password-visibility-target="eyeIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              <svg data-password-visibility-target="eyeSlashIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.29 3.29m0 0L3 15.29m3.29-9.29L12 12m0 0l3.29 3.29M12 12l-3.29-3.29m0 0L12 8.71"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Submit Button -->
        <div>
          <%= f.submit "Sign up", 
              class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
        </div>
      <% end %>

      <!-- Sign In Link -->
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Already have an account?
          <%= link_to "Sign in", new_user_session_path, 
              class: "font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300" %>
        </p>
      </div>

      <!-- Info Box -->
      <div class="mt-6 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
        <div class="flex items-start">
          <div class="shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <p class="text-sm text-blue-700 dark:text-blue-300">
              By signing up, you'll be able to track expenses, manage projects, and connect your Up Bank account for automatic transaction syncing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

