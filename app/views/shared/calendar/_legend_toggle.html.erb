<!-- Calendar Legend Toggle -->
<div class="absolute top-2 right-2 z-50 md:top-4 md:right-4" data-controller="calendar-legend">
  <button type="button" 
          id="calendar-legend-toggle-button"
          data-calendar-legend-target="button"
          data-action="click->calendar-legend#toggle"
          class="flex items-center justify-center w-6 h-6 rounded-full bg-neutral-100 dark:bg-neutral-700 transition-colors hover:bg-neutral-200 dark:hover:bg-neutral-600 md:w-5 md:h-5"
          aria-label="Show calendar legend"
          title="What do the colors mean?">
    <svg class="w-4 h-4 text-neutral-600 dark:text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
  </button>
  
  <!-- Legend Dropdown (hidden by default) -->
  <div id="calendar-legend-panel"
       data-calendar-legend-target="panel" 
       class="absolute top-10 right-0 z-40 hidden min-w-[200px] p-4 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 shadow-lg md:top-12 md:right-0 md:min-w-[240px]">
    <h4 class="text-sm font-semibold text-neutral-base mb-3">Calendar Guide</h4>
    <div class="space-y-2 text-xs">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded day-bg-positive border border-income-200 dark:border-income-800 flex-shrink-0"></div>
        <span class="text-neutral-label">Net positive day</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded day-bg-negative border border-expense-200 dark:border-expense-800 flex-shrink-0"></div>
        <span class="text-neutral-label">Net negative day</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-white dark:bg-neutral-800 border-2 border-primary-700/40 dark:border-primary-500/40 flex-shrink-0"></div>
        <span class="text-neutral-label">Today</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full surface-info surface-info-border flex-shrink-0">
          <svg class="w-3 h-3 text-info-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <span class="text-neutral-label">Recurring projections</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border projection-border projection-surface flex-shrink-0">
          <svg class="w-3 h-3 projection-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
        </div>
        <span class="text-neutral-label">Hypothetical transactions</span>
      </div>
      <div class="flex items-center gap-2 mt-3 pt-3 border-t border-neutral-200 dark:border-neutral-700">
        <div class="w-4 h-4 rounded bg-neutral-50/50 dark:bg-neutral-700/20 border border-neutral-200 dark:border-neutral-600 flex-shrink-0"></div>
        <span class="text-neutral-label">Weekend</span>
      </div>
    </div>
  </div>
</div>

