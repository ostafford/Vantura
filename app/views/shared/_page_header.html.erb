<!-- Page Header - Sticky by default for all pages -->
<% padding = local_assigns[:padding] || "py-4" %>
<div id="page-header" class="sticky top-0 z-50 bg-neutral-100 dark:bg-primary-900 shadow-deep <%= padding %>">
  <div class="flex items-center justify-between <%= local_assigns[:flex_wrap] ? 'flex-wrap gap-4' : '' %> px-4 sm:px-6 lg:px-8 xl:px-12 2xl:px-16">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= title %></h1>
        <% if local_assigns[:show_back_link] %>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            <%= link_to "← Back to Dashboard", root_path, class: "text-primary-700 dark:text-primary-500 hover:text-primary-900 dark:hover:text-primary-700 font-medium" %>
          </p>
        <% elsif local_assigns[:subtitle] %>
          <p id="calendar-header-subtitle" class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= subtitle %></p>
        <% end %>
      </div>

      <div class="flex items-center gap-3">
        <% if block_given? %>
          <%= yield %>
        <% end %>
        
        <!-- Dynamic Calendar Week Data (hidden by default, shown when calendar is in viewport) -->
        <div id="calendar-header-week-data" class="hidden bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm rounded-lg px-3 py-2 shadow-deep w-auto min-w-fit max-w-[200px] sm:max-w-none">
          <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:gap-6">
            <!-- Current Balance Line -->
            <div id="calendar-header-current-balance-container" class="flex flex-col gap-1 items-stretch">
              <span class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 text-left">Current Balance:</span>
              <span id="calendar-header-current-balance" class="text-sm sm:text-base font-bold text-right text-green-700 dark:text-green-200"></span>
            </div>
            <!-- End of Period Line -->
            <div id="calendar-header-period-container" class="flex flex-col gap-1 items-stretch">
              <span id="calendar-header-period-label" class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 whitespace-nowrap text-left"></span>
              <span id="calendar-header-period-amount" class="text-sm sm:text-base font-bold text-right text-green-700 dark:text-green-200"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
</div>
