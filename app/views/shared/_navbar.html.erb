<!-- Desktop Navbar - Sticky top navigation -->
<nav id="main-navbar" 
     class="hidden lg:block sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 shadow-sm"
     aria-label="Main navigation">
  <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 2xl:px-16">
    <!-- Navigation Row -->
    <div class="flex items-center justify-between h-16 gap-4">
      <!-- Logo and Main Navigation -->
      <div class="flex items-center gap-6 lg:gap-8 flex-1 min-w-0">
        <!-- Logo -->
        <%= link_to root_path, 
            class: "flex items-center gap-2 text-primary-700 dark:text-primary-500 hover:opacity-80 transition-opacity flex-shrink-0",
            id: "navbar-logo-link" do %>
          <svg class="w-8 h-8 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5zm0 18c-3.84-.95-6.5-4.5-6.5-8.5V8.3l6.5-3.11 6.5 3.11v3.2c0 4-2.66 7.55-6.5 8.5z"/>
          </svg>
          <span class="text-xl font-bold whitespace-nowrap">Vantura</span>
        <% end %>

        <!-- Navigation Links -->
        <div class="flex items-center gap-1 md:gap-2 lg:gap-3 overflow-x-auto scrollbar-hide flex-1 min-w-0">
          <%= navbar_nav_link_to "Dashboard", root_path, icon: "home" %>
          <%= navbar_nav_link_to "Calendar", calendar_path, icon: "calendar" %>
          <%= navbar_nav_link_to "Trends", trends_path, icon: "chart" %>
          <%= navbar_nav_link_to "Transactions", transactions_path, icon: "list" %>
          <%= navbar_nav_link_to "Recurring", recurring_transactions_path, icon: "refresh" %>
          <%= navbar_nav_link_to "Projects", projects_path, icon: "folder" %>
        </div>
      </div>

      <!-- Right Side Actions -->
      <div class="flex items-center gap-2 lg:gap-3 flex-shrink-0">
        <!-- Sync Button (if account exists) -->
        <% if Current.user&.accounts&.any? %>
          <%= button_to sync_path, method: :post, 
              class: "inline-flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium bg-primary-700 text-white rounded-lg hover:bg-primary-900 transition-all shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-700 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900", 
              data: { controller: "sync", action: "submit->sync#submit", disable_with: "Syncing..." },
              title: "Sync with Up Bank",
              id: "navbar-sync-button" do %>
            <svg class="w-5 h-5 flex-shrink-0" data-sync-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <span class="hidden lg:inline">Sync</span>
          <% end %>
        <% end %>
        
        <!-- Theme Toggle -->
        <button type="button" 
                data-action="click->theme#toggle" 
                data-theme-target="button"
                class="inline-flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-700 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900"
                title="Toggle theme"
                id="navbar-theme-toggle-button">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          <span class="hidden lg:inline">Theme</span>
        </button>

        <!-- User Menu Dropdown -->
        <div class="relative" data-controller="dropdown" id="navbar-user-menu">
          <button type="button" 
                  data-action="click->dropdown#toggle"
                  data-dropdown-target="button"
                  class="inline-flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-700 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900"
                  aria-label="User menu"
                  aria-expanded="false"
                  id="navbar-user-menu-button">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
            </svg>
            <span class="hidden lg:inline">Menu</span>
          </button>

          <!-- Dropdown Menu -->
          <div data-dropdown-target="menu"
               class="hidden absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50"
               id="navbar-user-menu-dropdown">
            <!-- Settings Link -->
            <%= link_to settings_path, 
                class: "flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors",
                id: "navbar-settings-link" do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>Settings</span>
            <% end %>

            <!-- Divider -->
            <div class="border-t border-gray-200 dark:border-gray-700 my-1"></div>

            <!-- Sign Out Button -->
            <% if authenticated? %>
              <%= button_to session_path, method: :delete,
                  form: { data: { turbo_confirm: "Are you sure you want to sign out?" } },
                  class: "w-full flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-left",
                  id: "navbar-sign-out-button" do %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                <span>Sign Out</span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

