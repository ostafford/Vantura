<%# Shared transaction row. Locals: transaction:, compact: false, show_date: false %>
<% compact = local_assigns.fetch(:compact, false) %>
<% show_date = local_assigns.fetch(:show_date, false) %>

<tr id="transaction-<%= transaction.id %>-row"
    class="<%= transaction.is_hypothetical ? 'projection-surface' : '' %> hover:bg-neutral-50 dark:hover:bg-neutral-700"
    <%= 'aria-label="Hypothetical transaction: ' + transaction.description + '"' if transaction.is_hypothetical %>>
  <% if show_date %>
    <td id="transaction-<%= transaction.id %>-date" class="px-6 py-4 whitespace-nowrap text-sm text-neutral-900 dark:text-neutral-300">
      <%= transaction.transaction_date.strftime("%b %d, %Y") %>
    </td>
  <% end %>

  <td id="transaction-<%= transaction.id %>-description" class="px-6 py-4 text-sm text-neutral-900 dark:text-neutral-300">
    <%= transaction.description %>
  </td>
  <td id="transaction-<%= transaction.id %>-category" class="px-6 py-4 whitespace-nowrap text-sm text-neutral-muted">
    <%= transaction.category&.humanize || "Uncategorized" %>
  </td>
  <td id="transaction-<%= transaction.id %>-status" class="px-6 py-4 whitespace-nowrap">
    <div class="flex items-center gap-1.5">
      <%= transaction_status_badge(transaction, compact: compact) %>
      <%= transaction_recurring_badge(transaction, compact: compact) %>
    </div>
  </td>
  <td id="transaction-<%= transaction.id %>-amount" class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold">
    <%= formatted_transaction_amount(transaction) %>
  </td>
  <td id="transaction-<%= transaction.id %>-actions" class="px-6 py-4 whitespace-nowrap text-sm text-right">
    <%= transaction_action_buttons(transaction) %>
  </td>
</tr>


