<!-- Mobile Navigation (Bottom Bar + Burger Menu) - Hidden on desktop -->
<div data-controller="mobile-menu" class="lg:hidden">
  <!-- Mobile Bottom Bar -->
  <nav data-controller="navbar-scroll"
       class="fixed bottom-0 left-0 right-0 w-full h-16 bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-800 z-40 shadow-sm transform transition-transform duration-300 ease-in-out translate-y-0 overflow-hidden">
    <div class="flex items-center justify-between h-16 px-4">
      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-2 text-brand hover:opacity-80 transition-opacity" do %>
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5zm0 18c-3.84-.95-6.5-4.5-6.5-8.5V8.3l6.5-3.11 6.5 3.11v3.2c0 4-2.66 7.55-6.5 8.5z"/>
        </svg>
        <span class="text-xl font-bold">Vantura</span>
      <% end %>

      <!-- Burger Button -->
      <button type="button" 
              data-action="click->mobile-menu#toggle" 
              data-mobile-menu-target="button"
              aria-label="Menu"
              aria-expanded="false"
              class="inline-flex items-center justify-center w-10 h-10 rounded-lg text-neutral-label hover:bg-neutral-100 dark:hover:bg-neutral-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-700 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-neutral-900 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Overlay Backdrop -->
  <div data-mobile-menu-target="overlay" 
       data-action="click->mobile-menu#closeOnOverlay"
       class="hidden fixed inset-0 bg-black/50 z-40 opacity-0 transition-opacity duration-300"
       aria-hidden="true">
  </div>

  <!-- Slide-in Drawer -->
  <aside data-mobile-menu-target="drawer"
         role="dialog"
         aria-modal="true"
         aria-label="Navigation menu"
         class="fixed top-0 right-0 h-full w-80 bg-white dark:bg-neutral-900 shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto">
    <div class="flex flex-col h-full">
      <!-- Drawer Header -->
      <div class="flex items-center justify-between p-6 border-b border-neutral-200 dark:border-neutral-800">
        <h2 class="text-lg font-semibold text-neutral-base">Menu</h2>
        <button type="button" 
                data-action="click->mobile-menu#close"
                aria-label="Close menu"
                class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-neutral-muted hover:bg-neutral-100 dark:hover:bg-neutral-800 focus:outline-none transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Navigation Links -->
      <nav class="flex-1 py-4">
        <%= mobile_drawer_nav_link_to "Dashboard", root_path, icon: "home" %>
        <%= mobile_drawer_nav_link_to "Calendar", calendar_path, icon: "calendar" %>
        <%= mobile_drawer_nav_link_to "Trends", trends_path, icon: "chart" %>
        <%= mobile_drawer_nav_link_to "Transactions", transactions_path, icon: "list" %>
        <%= mobile_drawer_nav_link_to "Recurring", recurring_transactions_path, icon: "refresh" %>
        <%= mobile_drawer_nav_link_to "Projects", projects_path, icon: "folder" %>
      </nav>

      <!-- Divider -->
      <div class="border-t border-neutral-200 dark:border-neutral-800"></div>

      <!-- Secondary Actions -->
      <div class="p-4 space-y-2">
        <!-- Sync Button (if account exists) -->
        <% if Current.user&.accounts&.any? %>
          <%= button_to sync_path, method: :post,
              class: "w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium bg-primary-700 text-white hover:bg-primary-900 transition-all shadow-sm",
              data: { controller: "sync", action: "submit->sync#submit", "mobile-menu-target": "sync-button", disable_with: "Syncing..." } do %>
            <svg class="w-5 h-5" data-sync-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <span>Sync with Up Bank</span>
          <% end %>
        <% end %>
        
        <!-- Theme Toggle -->
        <button type="button" 
                data-action="click->theme#toggle" 
                data-theme-target="button"
                class="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-neutral-label bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          <span>Toggle Theme</span>
        </button>

        <!-- Settings Link -->
        <%= link_to settings_path, 
            class: "w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-neutral-label bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Settings</span>
        <% end %>

        <!-- Sign Out Button -->
        <% if authenticated? %>
          <%= button_to session_path, method: :delete,
              form: { data: { turbo_confirm: "Are you sure you want to sign out?" } },
              class: "w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-neutral-label bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
            <span>Sign Out</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </aside>
</div>

