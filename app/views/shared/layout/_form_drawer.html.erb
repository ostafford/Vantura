<!-- Right-side Form Drawer for Desktop -->
<aside id="form-drawer-container"
       data-controller="form-drawer"
       class="hidden lg:block fixed right-0 top-0 h-full w-96 bg-white dark:bg-neutral-900 border-l border-neutral-200 dark:border-neutral-800 z-40 transform transition-transform duration-300 ease-in-out translate-x-full"
       aria-label="Form drawer"
       role="complementary">
  <!-- Form Container -->
  <div id="form-drawer-content" 
       class="h-full overflow-y-auto"
       data-form-drawer-target="content">
    <!-- Form content will be injected here by modal controllers -->
  </div>
</aside>

