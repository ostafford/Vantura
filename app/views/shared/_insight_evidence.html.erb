<%
  # Insight Evidence - Display evidence data in an organized format
  evidence = local_assigns.fetch(:evidence, {})
  insight_type = local_assigns.fetch(:insight_type, "spending_velocity")
%>

<div class="space-y-3 text-sm">
  <% case insight_type
     when "spending_velocity" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:current_daily_rate].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Current Daily Rate</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:current_daily_rate], precision: 2) %>/day</span>
      </div>
    <% end %>
    
    <% if evidence[:historical_daily_rate].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">6-Month Average</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:historical_daily_rate], precision: 2) %>/day</span>
      </div>
    <% end %>
    
    <% if evidence[:change_percentage].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Change</span>
        <span class="font-semibold <%= evidence[:change_percentage] < 0 ? 'text-success-600 dark:text-success-400' : 'text-expense-600 dark:text-expense-400' %>">
          <%= evidence[:change_percentage] > 0 ? '+' : '' %><%= number_with_precision(evidence[:change_percentage], precision: 1) %>%
        </span>
      </div>
    <% end %>
    
    <% if evidence[:projected_month_end].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Projected Month-End Spending</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:projected_month_end], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:potential_savings].present? %>
      <div class="flex items-center justify-between py-2 bg-success-50 dark:bg-success-900/20 rounded-lg px-3">
        <span class="text-success-700 dark:text-success-300 font-medium">Potential Savings</span>
        <span class="font-bold text-success-700 dark:text-success-300">$<%= number_with_precision(evidence[:potential_savings], precision: 0) %></span>
      </div>
    <% end %>
    
  <% when "savings_opportunity", "savings_investment_opportunity" %>
    <% if evidence[:savings_analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:savings_analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:current_income].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Current Month Income</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:current_income], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:projected_spending].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Projected Spending</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:projected_spending], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:projected_savings].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Projected Savings</span>
        <span class="font-semibold text-success-600 dark:text-success-400">$<%= number_with_precision(evidence[:projected_savings], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:potential_additional_savings].present? %>
      <div class="flex items-center justify-between py-2 bg-success-50 dark:bg-success-900/20 rounded-lg px-3">
        <span class="text-success-700 dark:text-success-300 font-medium">Additional Opportunity</span>
        <span class="font-bold text-success-700 dark:text-success-300">$<%= number_with_precision(evidence[:potential_additional_savings], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:investment_analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-t border-gray-200 dark:border-gray-700 mt-2 pt-2">
        <span class="text-gray-600 dark:text-gray-400">Investment Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:investment_analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:months_analyzed].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Months Analyzed</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:months_analyzed] %> months</span>
      </div>
    <% end %>
    
    <% if evidence[:average_monthly_savings].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Average Monthly Savings</span>
        <span class="font-semibold text-success-600 dark:text-success-400">$<%= number_with_precision(evidence[:average_monthly_savings], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:suggested_monthly_investment].present? %>
      <div class="flex items-center justify-between py-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3">
        <span class="text-blue-700 dark:text-blue-300 font-medium">Suggested Investment</span>
        <span class="font-bold text-blue-700 dark:text-blue-300">$<%= number_with_precision(evidence[:suggested_monthly_investment], precision: 0) %>/month</span>
      </div>
    <% end %>
    
    <% if evidence[:remaining_for_expenses].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Remaining for Expenses</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:remaining_for_expenses], precision: 0) %></span>
      </div>
    <% end %>
    
  <% when "investment_suggestion" %>
    <% if evidence[:months_analyzed].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Months Analyzed</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:months_analyzed] %> months</span>
      </div>
    <% end %>
    
    <% if evidence[:average_monthly_savings].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Average Monthly Savings</span>
        <span class="font-semibold text-success-600 dark:text-success-400">$<%= number_with_precision(evidence[:average_monthly_savings], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:suggested_monthly_investment].present? %>
      <div class="flex items-center justify-between py-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3">
        <span class="text-blue-700 dark:text-blue-300 font-medium">Suggested Investment</span>
        <span class="font-bold text-blue-700 dark:text-blue-300">$<%= number_with_precision(evidence[:suggested_monthly_investment], precision: 0) %>/month</span>
      </div>
    <% end %>
    
    <% if evidence[:remaining_for_expenses].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Remaining for Expenses</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:remaining_for_expenses], precision: 0) %></span>
      </div>
    <% end %>
    
  <% when "spending_warning" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:current_month_income].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Current Month Income</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:current_month_income], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:projected_spending].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Projected Spending</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:projected_spending], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:overspend_amount].present? %>
      <div class="flex items-center justify-between py-2 bg-red-50 dark:bg-red-900/20 rounded-lg px-3">
        <span class="text-red-700 dark:text-red-300 font-medium">Overspend Amount</span>
        <span class="font-bold text-red-700 dark:text-red-300">$<%= number_with_precision(evidence[:overspend_amount], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:days_remaining].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Days Remaining in Month</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:days_remaining] %></span>
      </div>
    <% end %>
    
  <% when "negative_savings_pattern" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:negative_months_count].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Months with Negative Savings</span>
        <span class="font-semibold text-red-600 dark:text-red-400"><%= evidence[:negative_months_count] %> out of <%= evidence[:months_analyzed] %></span>
      </div>
    <% end %>
    
    <% if evidence[:average_monthly_savings].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Average Monthly Savings</span>
        <span class="font-semibold text-red-600 dark:text-red-400">-$<%= number_with_precision(evidence[:average_monthly_savings].abs, precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:total_overspend].present? %>
      <div class="flex items-center justify-between py-2 bg-red-50 dark:bg-red-900/20 rounded-lg px-3">
        <span class="text-red-700 dark:text-red-300 font-medium">Total Overspend</span>
        <span class="font-bold text-red-700 dark:text-red-300">$<%= number_with_precision(evidence[:total_overspend], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:monthly_breakdown].present? %>
      <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
        <p class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-2">Monthly Breakdown:</p>
        <% evidence[:monthly_breakdown].each do |month| %>
          <div class="flex items-center justify-between py-1.5 text-xs">
            <span class="text-gray-600 dark:text-gray-400"><%= month[:month] %></span>
            <div class="flex items-center gap-4">
              <span class="text-gray-500 dark:text-gray-500">Income: $<%= number_with_precision(month[:income], precision: 0) %></span>
              <span class="text-gray-500 dark:text-gray-500">Expenses: $<%= number_with_precision(month[:expenses], precision: 0) %></span>
              <span class="font-semibold <%= month[:savings] < 0 ? 'text-red-600 dark:text-red-400' : 'text-success-600 dark:text-success-400' %>">
                Savings: $<%= number_with_precision(month[:savings], precision: 0) %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
    
  <% when "category_merchant" %>
    <% if evidence[:item_name].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400"><%= evidence[:view_type]&.capitalize || "Item" %></span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:item_name] %></span>
      </div>
    <% end %>
    
    <% if evidence[:total_amount].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Total Amount</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:total_amount], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:transaction_count].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Transactions</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:transaction_count] %></span>
      </div>
    <% end %>
    
    <% if evidence[:trend].present? && evidence[:trend][:percentage].present? %>
      <div class="flex items-center justify-between py-2">
        <span class="text-gray-600 dark:text-gray-400">Month-over-Month Change</span>
        <span class="font-semibold <%= evidence[:trend][:direction] == 'up' ? 'text-expense-600 dark:text-expense-400' : 'text-success-600 dark:text-success-400' %>">
          <%= evidence[:trend][:direction] == 'up' ? '↑' : evidence[:trend][:direction] == 'down' ? '↓' : '→' %>
          <%= number_with_precision(evidence[:trend][:percentage].abs, precision: 1) %>%
        </span>
      </div>
    <% end %>
    
  <% when "day_of_week_pattern" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:top_day].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Highest Spending Day</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:top_day] %></span>
      </div>
    <% end %>
    
    <% if evidence[:top_day_average].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Average per Transaction (<%= evidence[:top_day] %>)</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:top_day_average], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:overall_average].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Overall Average per Transaction</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:overall_average], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:monthly_frequency].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Monthly Frequency</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:monthly_frequency] %> times/month</span>
      </div>
    <% end %>
    
    <% if evidence[:top_day_count].present? %>
      <div class="flex items-center justify-between py-2">
        <span class="text-gray-600 dark:text-gray-400">Total Transactions (<%= evidence[:top_day] %>)</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:top_day_count] %></span>
      </div>
    <% end %>
    
  <% when "merchant_habit_pattern" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:merchant_name].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Merchant</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:merchant_name] %></span>
      </div>
    <% end %>
    
    <% if evidence[:monthly_frequency].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Monthly Frequency</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:monthly_frequency] %> times/month</span>
      </div>
    <% end %>
    
    <% if evidence[:average_per_transaction].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Average per Transaction</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:average_per_transaction], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:estimated_monthly_total].present? %>
      <div class="flex items-center justify-between py-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3">
        <span class="text-blue-700 dark:text-blue-300 font-medium">Estimated Monthly Total</span>
        <span class="font-bold text-blue-700 dark:text-blue-300">$<%= number_with_precision(evidence[:estimated_monthly_total], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:transaction_count].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Total Transactions</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:transaction_count] %></span>
      </div>
    <% end %>
    
    <% if evidence[:total_spent].present? %>
      <div class="flex items-center justify-between py-2">
        <span class="text-gray-600 dark:text-gray-400">Total Spent</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:total_spent], precision: 0) %></span>
      </div>
    <% end %>
    
  <% when "budget_coach" %>
    <% if evidence[:analysis_period].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Analysis Period</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:analysis_period] %></span>
      </div>
    <% end %>
    
    <% if evidence[:current_month_income].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Current Month Income</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:current_month_income], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:projected_spending].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Projected Spending</span>
        <span class="font-semibold text-gray-900 dark:text-white">$<%= number_with_precision(evidence[:projected_spending], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:target_spending].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Target Spending</span>
        <span class="font-semibold text-blue-600 dark:text-blue-400">$<%= number_with_precision(evidence[:target_spending], precision: 0) %></span>
      </div>
    <% end %>
    
    <% if evidence[:savings_goal].present? %>
      <%= link_to settings_path(expand_goal: true), 
          class: "flex items-center justify-between py-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3 hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors cursor-pointer group",
          title: "Click to edit your savings goal",
          id: "savings-goal-link-simple" do %>
        <span class="text-blue-700 dark:text-blue-300 font-medium">Savings Goal</span>
        <div class="flex items-center gap-2">
          <span class="font-bold text-blue-700 dark:text-blue-300">$<%= number_with_precision(evidence[:savings_goal], precision: 0) %></span>
          <svg class="w-3 h-3 text-blue-600 dark:text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      <% end %>
    <% end %>
    
    <% if evidence[:days_remaining].present? %>
      <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700">
        <span class="text-gray-600 dark:text-gray-400">Days Remaining</span>
        <span class="font-semibold text-gray-900 dark:text-white"><%= evidence[:days_remaining] %></span>
      </div>
    <% end %>
    
    <% if evidence[:category_budgets].present? && evidence[:category_budgets].is_a?(Array) && evidence[:category_budgets].any? %>
      <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
        <p class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-2">Category Budgets:</p>
        <% evidence[:category_budgets].each do |budget| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-200 dark:border-gray-700 last:border-0">
            <div class="flex-1">
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= budget[:category] %></span>
              <div class="flex items-center gap-4 mt-1 text-xs text-gray-500 dark:text-gray-400">
                <span>Current: $<%= number_with_precision(budget[:current_spent], precision: 0) %></span>
                <span>Target: $<%= number_with_precision(budget[:suggested_budget], precision: 0) %></span>
              </div>
            </div>
            <div class="text-right">
              <span class="text-sm font-semibold text-blue-600 dark:text-blue-400">$<%= number_with_precision(budget[:weekly_target], precision: 0) %>/week</span>
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                Save $<%= number_with_precision(budget[:reduction_amount], precision: 0) %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
    
  <% end %>

  <% if evidence[:projected_savings].present? %>
    <% goal_gap_amount = evidence[:goal_gap_amount] %>
    <% goal_gap_rate = evidence[:goal_gap_rate_percentage] %>
    <% projected_positive = evidence[:projected_savings].to_f >= 0 %>
    <div class="mt-4 pt-4 border-t border-dashed border-gray-200 dark:border-gray-700">
      <p class="text-xs font-semibold text-gray-600 dark:text-gray-300 mb-2 tracking-wide uppercase">Goal Progress</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-3">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Projected Savings</p>
          <p class="text-sm font-semibold <%= projected_positive ? 'text-success-700 dark:text-success-400' : 'text-expense-700 dark:text-expense-400' %>">
            $<%= number_with_precision(evidence[:projected_savings], precision: 0) %>
          </p>
        </div>

        <div class="rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-3">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Projected Savings Rate</p>
          <p class="text-sm font-semibold <%= projected_positive ? 'text-success-700 dark:text-success-400' : 'text-expense-700 dark:text-expense-400' %>">
            <%= number_with_precision(evidence[:projected_savings_rate_percentage] || 0, precision: 1) %>%
          </p>
        </div>
      </div>

      <% if evidence[:goal_set] %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
          <%= link_to settings_path(expand_goal: true), 
              class: "rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 p-3 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:border-blue-300 dark:hover:border-blue-600 transition-colors cursor-pointer group",
              title: "Click to edit your savings goal",
              id: "savings-goal-link" do %>
            <div class="flex items-center justify-between">
              <div class="flex-1">
                <p class="text-xs text-blue-700 dark:text-blue-300 mb-1">Savings Goal</p>
                <% if evidence[:goal_source] == :break_even || evidence[:goal_target_amount].to_f.zero? %>
                  <p class="text-sm font-semibold text-blue-800 dark:text-blue-200">Break even (0%)</p>
                <% elsif evidence[:goal_target_amount].present? %>
                  <p class="text-sm font-semibold text-blue-800 dark:text-blue-200">$<%= number_with_precision(evidence[:goal_target_amount], precision: 0) %></p>
                <% elsif evidence[:goal_target_rate_percentage].present? %>
                  <p class="text-sm font-semibold text-blue-800 dark:text-blue-200"><%= number_with_precision(evidence[:goal_target_rate_percentage], precision: 1) %>% of income</p>
                <% end %>
              </div>
              <svg class="w-4 h-4 text-blue-600 dark:text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          <% end %>

          <% if goal_gap_amount.present? || goal_gap_rate.present? %>
            <% gap_positive = goal_gap_amount.to_f.positive? || goal_gap_rate.to_f.positive? %>
            <div class="rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-3">
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Distance to Goal</p>
              <% if goal_gap_amount.present? %>
                <p class="text-sm font-semibold <%= gap_positive ? 'text-expense-700 dark:text-expense-400' : 'text-success-700 dark:text-success-400' %>">
                  <%= gap_positive ? '$' + number_with_precision(goal_gap_amount.abs, precision: 0) + ' needed' : 'Ahead by $' + number_with_precision(goal_gap_amount.abs, precision: 0) %>
                </p>
              <% elsif goal_gap_rate.present? %>
                <p class="text-sm font-semibold <%= gap_positive ? 'text-expense-700 dark:text-expense-400' : 'text-success-700 dark:text-success-400' %>">
                  <%= gap_positive ? number_with_precision(goal_gap_rate.abs, precision: 1) : number_with_precision(goal_gap_rate.abs, precision: 1) %>% <%= gap_positive ? 'to close' : 'ahead' %>
                </p>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if goal_gap_amount.present? && goal_gap_amount <= 0 %>
          <p class="text-xs font-medium text-success-700 dark:text-success-400 mt-3">
            You're pacing to hit your savings goal this month.
          </p>
        <% elsif goal_gap_amount.present? %>
          <p class="text-xs text-gray-600 dark:text-gray-300 mt-3">
            Small adjustments can close the remaining gap of $<%= number_with_precision(goal_gap_amount, precision: 0) %>.
          </p>
        <% elsif goal_gap_rate.present? && goal_gap_rate <= 0 %>
          <p class="text-xs font-medium text-success-700 dark:text-success-400 mt-3">
            You're pacing to hit your savings goal this month.
          </p>
        <% elsif goal_gap_rate.present? %>
          <p class="text-xs text-gray-600 dark:text-gray-300 mt-3">
            You're within <%= number_with_precision(goal_gap_rate, precision: 1) %>% of your goal—small changes will get you there.
          </p>
        <% end %>
      <% else %>
        <p class="text-xs text-gray-600 dark:text-gray-300 mt-3">
          Create a savings goal to see how your projected savings track over time.
        </p>
      <% end %>
    </div>
  <% end %>
</div>

