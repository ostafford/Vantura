<%
  # Insight Card - Display actionable financial insights with evidence
  insight = local_assigns.fetch(:insight, {})
  return if insight.blank?
  
  title = insight[:title] || "Financial Insight"
  message = insight[:message] || ""
  evidence = insight[:evidence] || {}
  suggested_action = insight[:suggested_action]
  suggested_amount = insight[:suggested_amount]
  suggested_date = insight[:suggested_date]
  priority = insight[:priority] || "medium"
  insight_id = "insight-#{insight[:type]}-#{rand(10000..99999)}"
  
  # Priority and type-based colors
  # Warnings get red/orange colors, opportunities get blue/green
  insight_type = insight[:type] || "spending_velocity"
  is_warning = ["spending_warning", "negative_savings_pattern"].include?(insight_type)
  is_budget_coach = insight_type == "budget_coach"
  
  case priority
  when "high"
    if is_warning
      bg_gradient = "bg-gradient-to-br from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20"
      icon_bg = "bg-red-200 dark:bg-red-900/40"
      icon_text = "text-red-600 dark:text-red-400"
      border_color = "border-red-300 dark:border-red-700"
    elsif is_budget_coach
      bg_gradient = "bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20"
      icon_bg = "bg-blue-200 dark:bg-blue-900/40"
      icon_text = "text-blue-600 dark:text-blue-400"
      border_color = "border-blue-300 dark:border-blue-700"
    else
      bg_gradient = "bg-gradient-to-br from-success-100 to-success-50 dark:from-success-900/30 dark:to-success-800/20"
      icon_bg = "bg-success-200 dark:bg-success-900/40"
      icon_text = "text-success-600 dark:text-success-400"
      border_color = "border-success-300 dark:border-success-700"
    end
  when "medium"
    if is_budget_coach
      bg_gradient = "bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20"
      icon_bg = "bg-blue-200 dark:bg-blue-900/40"
      icon_text = "text-blue-600 dark:text-blue-400"
      border_color = "border-blue-300 dark:border-blue-700"
    else
      bg_gradient = "bg-gradient-to-br from-blue-50 to-white dark:from-blue-900/20 dark:to-gray-800"
      icon_bg = "bg-blue-100 dark:bg-blue-900/30"
      icon_text = "text-primary-700 dark:text-primary-500"
      border_color = "border-blue-200 dark:border-blue-800"
    end
  else # low
    bg_gradient = "bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900"
    icon_bg = "bg-gray-100 dark:bg-gray-800"
    icon_text = "text-gray-600 dark:text-gray-400"
    border_color = "border-gray-200 dark:border-gray-700"
  end
  
  # Icon based on insight type
  icon_paths = {
    "spending_velocity" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />',
    "spending_warning" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />',
    "negative_savings_pattern" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />',
    "savings_opportunity" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
    "savings_investment_opportunity" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
    "investment_suggestion" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
    "category_merchant" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
    "day_of_week_pattern" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
    "merchant_habit_pattern" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
    "budget_coach" => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />'
  }
  
  icon_svg = icon_paths[insight_type] || icon_paths["spending_velocity"]
%>

<div class="insight-card <%= bg_gradient %> rounded-2xl shadow-deep p-6 flex flex-col" 
     id="<%= insight_id %>"
     data-controller="insight-card"
     data-insight-card-id-value="<%= insight_id %>"
     data-insight-card-type-value="<%= insight_type %>">
  <div class="flex flex-col flex-1">
    <!-- Header: Icon and Title -->
    <div class="flex items-start gap-4 mb-3">
      <div class="inline-flex items-center justify-center w-12 h-12 <%= icon_bg %> rounded-xl flex-shrink-0">
        <svg class="w-6 h-6 <%= icon_text %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <%= icon_svg.html_safe %>
        </svg>
      </div>
      
      <div class="flex-1 min-w-0">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= title %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed"><%= message %></p>
      </div>
    </div>
    
    <!-- Evidence Section (Accordion) -->
    <% if evidence.present? %>
      <div class="mt-4" data-insight-card-target="evidenceContainer">
        <button type="button"
                class="flex items-center gap-2 text-sm font-medium text-primary-700 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300 transition-colors"
                data-action="click->insight-card#toggleEvidence"
                data-insight-card-target="evidenceToggle">
          <span>Why?</span>
          <svg class="w-4 h-4 transition-transform" 
               data-insight-card-target="evidenceIcon"
               fill="none" 
               stroke="currentColor" 
               viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div class="hidden mt-3 pt-3 border-t <%= border_color %>" 
             data-insight-card-target="evidenceContent">
          <%= render "shared/insight_evidence", evidence: evidence, insight_type: insight_type %>
        </div>
      </div>
    <% end %>
    
    <!-- Action Buttons -->
    <div class="mt-auto pt-4 border-t <%= border_color %> flex items-center gap-3">
      <% if suggested_action.present? && suggested_amount.present? %>
        <button type="button"
                class="inline-flex items-center px-4 py-2 bg-primary-700 text-white text-sm font-medium rounded-lg hover:bg-primary-900 transition-colors"
                data-action="click->modal#open"
                data-insight-amount="<%= suggested_amount %>"
                data-insight-date="<%= suggested_date&.strftime('%Y-%m-%d') %>"
                data-insight-description="<%= "#{suggested_action}: #{title}" %>">
          <%= suggested_action %>
          <span class="ml-2 font-semibold">$<%= number_with_precision(suggested_amount, precision: 0) %></span>
        </button>
      <% elsif suggested_action.present? %>
        <%= link_to transactions_path,
                    class: "inline-flex items-center px-4 py-2 bg-primary-700 text-white text-sm font-medium rounded-lg hover:bg-primary-900 transition-colors" do %>
          <%= suggested_action %>
        <% end %>
      <% end %>
      
      <button type="button"
              class="ml-auto text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
              data-action="click->insight-card#dismiss">
        Dismiss
      </button>
    </div>
  </div>
</div>

