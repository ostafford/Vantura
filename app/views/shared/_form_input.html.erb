<%# 
  Reusable form input component with Flowbite styling
  Usage:
    render 'shared/form_input', form: form, field: :name, label: 'Name', type: 'text', placeholder: 'Enter name', required: true
    render 'shared/form_input', form: form, field: :email, label: 'Email', type: 'email', help_text: 'We will never share your email'
    render 'shared/form_input', form: form, field: :password, label: 'Password', type: 'password', required: true
%>
<% field_name = local_assigns[:field] %>
<% label_text = local_assigns[:label] || field_name.to_s.humanize %>
<% input_type = local_assigns[:type] || 'text' %>
<% placeholder_text = local_assigns[:placeholder] || "Enter #{label_text.downcase}" %>
<% help_text = local_assigns[:help_text] %>
<% required = local_assigns[:required] || false %>
<% disabled = local_assigns[:disabled] || false %>
<% value = local_assigns[:value] %>
<% css_class = local_assigns[:css_class] || '' %>

<div class="mb-4">
  <%= form.label field_name, label_text, class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white #{'after:content-[\'*\'] after:ml-0.5 after:text-red-500' if required}" %>
  
  <% case input_type %>
  <% when 'textarea' %>
    <% textarea_options = {
        placeholder: placeholder_text,
        required: required,
        disabled: disabled,
        class: "block w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}",
        rows: local_assigns[:rows] || 4
      } %>
    <% textarea_options[:value] = value if value.present? %>
    <%= form.text_area field_name, textarea_options %>
  <% when 'select' %>
    <% select_options = { 
          required: required,
          disabled: disabled,
          class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}"
        } %>
    <% if local_assigns[:data] %>
      <% select_options[:data] = local_assigns[:data] %>
    <% end %>
    <%= form.select field_name, 
        local_assigns[:options] || [],
        { prompt: local_assigns[:prompt] },
        select_options %>
  <% when 'number' %>
    <% number_field_options = {
        placeholder: placeholder_text,
        required: required,
        disabled: disabled,
        step: local_assigns[:step] || 1,
        min: local_assigns[:min],
        max: local_assigns[:max],
        class: "block w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}"
      } %>
    <% number_field_options[:value] = value if value.present? %>
    <%= form.number_field field_name, number_field_options %>
  <% when 'date' %>
    <% date_field_options = {
        required: required,
        disabled: disabled,
        class: "block w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}"
      } %>
    <% date_field_options[:value] = value if value.present? %>
    <%= form.date_field field_name, date_field_options %>
  <% when 'datetime-local' %>
    <%= form.datetime_local_field field_name,
        required: required,
        disabled: disabled,
        value: value,
        class: "block w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}" %>
  <% when 'password' %>
    <div class="relative" data-controller="password-visibility">
      <%= form.password_field field_name,
          placeholder: placeholder_text,
          required: required,
          disabled: disabled,
          value: value,
          class: "block w-full px-3 py-2 pr-10 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}",
          data: { password_visibility_target: 'input' } %>
      <button type="button" 
              class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
              data-action="click->password-visibility#toggle"
              data-password-visibility-target="button">
        <svg class="w-5 h-5" data-password-visibility-target="eyeIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        <svg class="w-5 h-5 hidden" data-password-visibility-target="eyeSlashIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
        </svg>
      </button>
    </div>
  <% else %>
    <% text_field_options = {
        placeholder: placeholder_text,
        required: required,
        disabled: disabled,
        type: input_type,
        class: "block w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 #{css_class}"
      } %>
    <% text_field_options[:value] = value if value.present? %>
    <%= form.text_field field_name, text_field_options %>
  <% end %>
  
  <% if form.object.errors[field_name].any? %>
    <p class="mt-2 text-sm text-red-600 dark:text-red-400">
      <%= form.object.errors[field_name].first %>
    </p>
  <% elsif help_text.present? %>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      <%= help_text %>
    </p>
  <% end %>
</div>

