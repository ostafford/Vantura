<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <% 4.times do %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 animate-pulse">
      <div class="h-4 bg-gray-200 rounded dark:bg-gray-700 w-1/2 mb-4"></div>
      <div class="h-8 bg-gray-200 rounded dark:bg-gray-700 w-3/4"></div>
    </div>
  <% end %>
</div>

