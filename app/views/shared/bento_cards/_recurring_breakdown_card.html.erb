<%
  recurring_data = local_assigns.fetch(:recurring_data, {})
  recurring_total = recurring_data[:recurring_total] || 0
  discretionary_total = recurring_data[:discretionary_total] || 0
  recurring_pct = recurring_data[:recurring_pct] || 0
  discretionary_pct = recurring_data[:discretionary_pct] || 0
  total_expenses = recurring_data[:total_expenses] || 0
%>

<div class="col-span-1 row-span-2 bg-gradient-to-br from-neutral-100 to-white dark:from-neutral-800 dark:to-neutral-900 rounded-2xl shadow-deep p-6">
  <div class="flex flex-col h-full">
    <!-- Header -->
    <div class="mb-4">
      <div class="flex items-center gap-2">
        <h3 class="text-lg font-semibold text-neutral-base">Expense Breakdown</h3>
        <span class="cursor-help"
              data-controller="tooltip"
              data-tooltip-content-value="Recurring expenses are fixed, predictable costs (subscriptions, rent). Discretionary expenses are variable, optional spending (dining out, entertainment)."
              data-tooltip-position-value="top"
              data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
          <svg class="w-4 h-4 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
      </div>
      <p class="text-sm text-neutral-muted mt-1">Recurring vs Discretionary</p>
    </div>

    <!-- Visual Breakdown -->
    <div class="flex-1 space-y-4">
      <!-- Recurring Section -->
      <div class="rounded-xl border border-neutral-200 bg-white/80 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800/60">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-primary-500 dark:bg-primary-400"></div>
            <p class="text-sm font-semibold text-neutral-base">Recurring</p>
          </div>
          <span class="text-sm font-semibold text-brand">
            <%= number_with_precision(recurring_pct, precision: 1) %>%
          </span>
        </div>
        <p class="text-2xl font-bold text-brand mb-2">
          $<%= number_with_precision(recurring_total, precision: 2) %>
        </p>
        <!-- Progress bar -->
        <div class="w-full bg-neutral-200 rounded-full h-2 dark:bg-neutral-700">
          <div class="h-2 rounded-full bg-primary-500" style="width: <%= recurring_pct %>%"></div>
        </div>
      </div>

      <!-- Discretionary Section -->
      <div class="rounded-xl border border-neutral-200 bg-white/80 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800/60">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full dot-expense"></div>
            <p class="text-sm font-semibold text-neutral-base">Discretionary</p>
          </div>
          <span class="text-sm font-semibold amount-negative">
            <%= number_with_precision(discretionary_pct, precision: 1) %>%
          </span>
        </div>
        <p class="text-2xl font-bold amount-negative mb-2">
          $<%= number_with_precision(discretionary_total, precision: 2) %>
        </p>
        <!-- Progress bar -->
        <div class="w-full bg-neutral-200 rounded-full h-2 dark:bg-neutral-700">
          <div class="h-2 rounded-full progress-expense" style="width: <%= discretionary_pct %>%"></div>
        </div>
      </div>

      <!-- Total -->
      <div class="rounded-xl border border-neutral-200 bg-white/80 p-3 shadow-sm dark:border-neutral-700 dark:bg-neutral-800/60">
        <p class="text-xs font-semibold uppercase tracking-wide text-neutral-muted">Total Expenses</p>
        <p class="mt-1 text-xl font-semibold text-neutral-900 dark:text-neutral-100">
          $<%= number_with_precision(total_expenses, precision: 2) %>
        </p>
      </div>
    </div>

    <!-- Footer with Link -->
    <div class="mt-4 pt-4 border-t border-neutral-200 dark:border-neutral-700">
      <%= link_to recurring_transactions_path, 
          class: "inline-flex items-center gap-2 text-sm font-medium link-primary",
          data: { turbo_frame: "_top" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span>Manage Recurring</span>
      <% end %>
    </div>
  </div>
</div>

