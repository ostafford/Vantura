<%
  # Hero Card - Large intro card with decorative elements
  title = local_assigns.fetch(:title, 'Title')
  subtitle = local_assigns.fetch(:subtitle, nil)
  description = local_assigns.fetch(:description, nil)
  icon = local_assigns.fetch(:icon, 'chart')
  size = local_assigns.fetch(:size, 'col-span-1 md:col-span-2 row-span-2')
  color_scheme = local_assigns.fetch(:color, 'primary')
  element_id = local_assigns.fetch(:id, nil)
  status_badge = local_assigns[:status_badge]
  
  # Color scheme mapping
  color_map = {
    'primary' => 'from-primary-700 to-primary-900 dark:from-primary-700 dark:to-primary-950',
    'success' => 'from-success-500 to-success-700 dark:from-success-700 dark:to-success-900',
    'expense' => 'from-expense-500 to-expense-700 dark:from-expense-700 dark:to-expense-900',
    'neutral' => 'from-neutral-100 to-white dark:from-neutral-800 dark:to-neutral-900'
  }

  text_color_map = {
    'primary' => 'text-white',
    'success' => 'text-white',
    'expense' => 'text-white',
    'neutral' => 'text-neutral-base'
  }

  gradient_classes = color_map[color_scheme] || color_map['primary']
  text_color_class = text_color_map[color_scheme] || 'text-white'
  
  # Icon mapping
  icon_map = {
    'chart' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />',
    'wallet' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />',
    'trend' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />',
    'calendar' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />'
  }
  
  # Add icon mapping for month progress
  if icon == 'calendar'
    icon_map['calendar'] = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />'
  end
  
  icon_path = icon_map[icon] || icon_map['chart']
  
  # Determine if this is a compact card (1x2 or smaller)
  is_compact = size.include?('col-span-1')
  padding_class = is_compact ? 'p-6 md:px-6 md:pt-6 md:pb-4' : 'p-6 md:px-8 md:pt-8 md:pb-6'
  title_size_class = is_compact ? 'text-2xl' : 'text-3xl'
  icon_size_class = is_compact ? 'w-10 h-10' : 'w-12 h-12'
  icon_svg_size = is_compact ? 'w-6 h-6' : 'w-7 h-7'
  subtitle_container_classes = 'hero-subtitle text-lg font-semibold mt-0.5'
  subtitle_container_classes += text_color_class.include?('text-white') ? ' text-white/80' : ' text-neutral-label'
  title_container_classes = "hero-title #{title_size_class} font-bold"
  title_container_classes += ' flex items-center gap-2' if status_badge.present?
  description_text_classes = if text_color_class.include?('text-white')
                               'text-white/80'
                             else
                               'text-neutral-label'
                             end
%>

<div<% if element_id.present? %> id="<%= element_id %>"<% end %> class="<%= size %> bg-gradient-to-br <%= gradient_classes %> rounded-2xl shadow-deep <%= padding_class %> <%= text_color_class %> relative overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-32 -mt-32"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -ml-24 -mb-24"></div>
  
  <div class="relative z-10 flex flex-col h-full space-y-3">
    <!-- Section 1: Header Row (Icon, Title, Subtitle) -->
    <div class="hero-header flex items-center gap-3">
      <div class="hero-icon inline-flex items-center justify-center <%= icon_size_class %> bg-white/20 rounded-xl backdrop-blur-sm flex-shrink-0">
        <svg class="<%= icon_svg_size %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <%= icon_path.html_safe %>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <% if subtitle.present? && local_assigns[:inline_subtitle] %>
          <!-- Inline layout: Title and subtitle stacked on mobile, horizontal on desktop -->
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h2 class="<%= title_container_classes %> <%= text_color_class %>">
              <span class="break-words">
                <%= title %>
              </span>
            </h2>
            <div class="shrink-0">
              <%= subtitle %>
            </div>
          </div>
        <% else %>
          <!-- Default layout: Title above subtitle -->
          <h2 class="<%= title_container_classes %> <%= text_color_class %>">
            <span class="break-words">
              <%= title %>
            </span>
            <% if status_badge.present? %>
              <span class="ml-auto shrink-0">
                <%= status_badge %>
              </span>
            <% end %>
          </h2>
          <% if subtitle.present? %>
            <div class="<%= subtitle_container_classes %>">
              <%= subtitle %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    
    <!-- Section 2: Description -->
    <div class="hero-description flex-1 flex items-center">
      <% if description.present? %>
        <p class="<%= description_text_classes %> text-sm leading-relaxed text-glow-sm w-full">
          <%= description %>
        </p>
      <% end %>
    </div>
    
    <!-- Section 3: Progress/Additional Content -->
    <% if block_given? %>
      <div class="hero-content">
        <%= yield %>
      </div>
    <% end %>
  </div>
</div>

