<%
  savings_rate = local_assigns.fetch(:savings_rate, 0)
  savings_rate_trend = local_assigns.fetch(:savings_rate_trend, "stable")
  three_month_avg = local_assigns.fetch(:three_month_avg, 0)
  last_month_rate = local_assigns.fetch(:last_month_rate, 0)
  savings_rate_change = local_assigns.fetch(:savings_rate_change, 0)
  
  # Determine trend arrow and color
  trend_arrow = if savings_rate_change > 0
    "↑"
  elsif savings_rate_change < 0
    "↓"
  else
    "→"
  end
  
  trend_color = if savings_rate_change > 0
    "status-success"
  elsif savings_rate_change < 0
    "amount-negative"
  else
    "text-neutral-600 dark:text-neutral-400"
  end
  
  trend_direction_text = case savings_rate_trend
  when "improving"
    "Improving"
  when "declining"
    "Declining"
  else
    "Stable"
  end
%>

<div class="col-span-1 row-span-1 bg-gradient-to-br from-neutral-100 to-white dark:from-neutral-800 dark:to-neutral-900 rounded-2xl shadow-deep p-6" id="savings-rate-card">
  <div class="flex flex-col h-full">
    <!-- Header -->
    <div class="mb-4">
      <div class="flex items-center gap-2">
        <h3 class="text-base font-semibold text-neutral-base">Savings Rate</h3>
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold badge-success">
          Current
        </span>
        <span class="cursor-help"
              data-controller="tooltip"
              data-tooltip-content-value="Savings rate is the percentage of your income that you save. A positive rate means you're saving money, while a negative rate indicates overspending."
              data-tooltip-position-value="top"
              data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
          <svg class="w-4 h-4 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
      </div>
      <p class="text-xs text-neutral-muted mt-1">Current month</p>
    </div>

    <!-- Main Value -->
    <div class="flex-1 flex items-center justify-between mb-4">
      <div>
        <p class="text-3xl font-bold <%= savings_rate >= 0 ? 'status-success' : 'amount-negative' %>">
          <%= number_with_precision(savings_rate, precision: 1) %>%
        </p>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-xs <%= trend_color %> font-semibold"><%= trend_arrow %></span>
          <span class="text-xs text-neutral-muted">
            <%= savings_rate_change.positive? ? "+" : "" %><%= number_with_precision(savings_rate_change, precision: 1) %>% vs last month
          </span>
        </div>
      </div>
    </div>

    <!-- Goal Progress Indicator -->
    <% 
      goal_rate = local_assigns.fetch(:goal_rate, nil)
      if goal_rate.present? && goal_rate > 0
        # Calculate progress: if savings rate is negative, show 0% progress
        # If positive, calculate percentage of goal achieved (cap at 100%)
        if savings_rate < 0
          goal_progress_pct = 0
        else
          goal_progress_pct = goal_rate > 0 ? [((savings_rate / goal_rate) * 100).round(0), 100].min : 0
        end
        goal_gap = goal_rate - savings_rate
    %>
      <div class="mb-4 pb-4 border-b border-neutral-200 dark:border-neutral-700">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-neutral-600 dark:text-neutral-400">Goal Progress</span>
          <span class="text-xs font-semibold <%= savings_rate >= goal_rate ? 'status-success' : 'text-neutral-600 dark:text-neutral-400' %>">
            <%= number_with_precision(goal_progress_pct, precision: 0) %>% of <%= number_with_precision(goal_rate, precision: 1) %>%
          </span>
        </div>
        <div class="w-full bg-neutral-200 rounded-full h-2 dark:bg-neutral-700">
          <div class="h-2 rounded-full <%= savings_rate >= goal_rate ? 'progress-success' : 'bg-primary-500' %>" 
               style="width: <%= [goal_progress_pct, 100].min %>%"></div>
        </div>
        <% if goal_gap > 0 %>
          <p class="text-xs text-neutral-muted mt-1">
            <%= number_with_precision(goal_gap, precision: 1) %>% away from goal
          </p>
        <% elsif goal_gap < 0 %>
          <p class="text-xs status-success mt-1">
            <%= number_with_precision(goal_gap.abs, precision: 1) %>% above goal
          </p>
        <% end %>
      </div>
    <% end %>

    <!-- Nested Tiles -->
    <div class="space-y-2">
      <div class="rounded-xl bg-white/80 p-3 shadow-deep dark:bg-neutral-800/60">
        <div class="flex items-center gap-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-muted">3-Month Average</p>
          <span class="cursor-help"
                data-controller="tooltip"
                data-tooltip-content-value="Average savings rate over the past 3 months. Helps identify longer-term trends beyond month-to-month fluctuations."
                data-tooltip-position-value="top"
                data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
            <svg class="w-3 h-3 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
        </div>
        <p class="mt-1 text-lg font-semibold text-neutral-900 dark:text-neutral-100">
          <%= number_with_precision(three_month_avg, precision: 1) %>%
        </p>
      </div>

      <div class="rounded-xl bg-white/80 p-3 shadow-deep dark:bg-neutral-800/60">
        <div class="flex items-center gap-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-muted">Trend</p>
          <span class="cursor-help"
                data-controller="tooltip"
                data-tooltip-content-value="Overall direction of your savings rate: Improving (increasing), Declining (decreasing), or Stable (consistent)."
                data-tooltip-position-value="top"
                data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
            <svg class="w-3 h-3 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
        </div>
        <p class="mt-1 text-sm font-semibold <%= trend_color %>">
          <%= trend_direction_text %>
        </p>
      </div>
    </div>
    
    <!-- Footer with Link to Chart -->
    <div class="mt-4 pt-4 border-t border-neutral-200 dark:border-neutral-700">
      <a href="#savings-rate-chart-card" 
         class="text-xs text-primary-600 dark:text-primary-400 hover:underline"
         data-action="click->trends#scrollToCard">
        View Trend Chart →
      </a>
    </div>
  </div>
</div>

