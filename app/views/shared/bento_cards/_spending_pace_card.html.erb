<%
  # Spending Pace Card - Shows daily spending rate, pace indicator, and projected spending
  daily_rate = local_assigns.fetch(:daily_rate, 0.0)
  projected_total = local_assigns.fetch(:projected_total, 0.0)
  velocity_change_pct = local_assigns.fetch(:velocity_change_pct, 0.0)
  spending_rate = local_assigns.fetch(:spending_rate, 0.0)
  size = local_assigns.fetch(:size, 'bento-span-2 bento-row-span-1')
  element_id = local_assigns.fetch(:id, 'calendar-spending-pace-card')
  
  # Calculate spending rate percentage (how far through month's expected spending)
  # spending_rate is already calculated as percentage (0-100+)
  pace_percentage = [spending_rate, 100].min
  
  # Determine pace indicator and colors
  if spending_rate > 100
    pace_status = "Ahead of pace"
    pace_color = "text-red-600 dark:text-red-400"
    bar_color = "bg-red-400"
    indicator_bg = "bg-red-100 dark:bg-red-900/30"
    indicator_text = "text-red-700 dark:text-red-400"
  elsif spending_rate > 75
    pace_status = "On track"
    pace_color = "text-yellow-600 dark:text-yellow-400"
    bar_color = "bg-yellow-400"
    indicator_bg = "bg-yellow-100 dark:bg-yellow-900/30"
    indicator_text = "text-yellow-700 dark:text-yellow-400"
  else
    pace_status = "Behind pace"
    pace_color = "text-green-600 dark:text-green-400"
    bar_color = "bg-green-400"
    indicator_bg = "bg-green-100 dark:bg-green-900/30"
    indicator_text = "text-green-700 dark:text-green-400"
  end
  
  # Format comparison text
  if velocity_change_pct.abs < 0.1
    comparison_text = "Similar to 6-month average"
  elsif velocity_change_pct > 0
    comparison_text = "#{velocity_change_pct.abs.round(1)}% above 6-month average"
  else
    comparison_text = "#{velocity_change_pct.abs.round(1)}% below 6-month average"
  end
%>

<div class="bento-span-2 bento-row-span-1 from-blue-50 to-white dark:from-blue-900/10 dark:to-gray-800 rounded-2xl shadow-deep p-6"<%= " id=#{element_id.inspect}" if element_id.present? %>>
  <div class="stat-card-container flex flex-col h-full">
    <!-- Section 1: Icon, Title, and Value -->
    <div class="stat-card-main-content flex-1">
      <!-- Top Row: Icon, Title, and Value -->
      <div class="flex items-center gap-4 mb-4">
        <div class="stat-card-icon inline-flex items-center justify-center w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex-shrink-0">
          <svg class="w-6 h-6 text-primary-700 dark:text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
          </svg>
        </div>
        
        <div class="flex-1 min-w-0">
          <p class="stat-card-title text-sm font-medium text-gray-600 dark:text-gray-400 mb-1">Spending Pace</p>
          <p class="stat-card-value font-bold text-primary-700 dark:text-primary-500">$<%= number_with_precision(daily_rate, precision: 2) %>/day</p>
        </div>
      </div>
      
      <!-- Custom content: Progress bar and pace indicator -->
      <div class="stat-card-custom-content">
        <!-- Progress Bar -->
        <div class="mb-3">
          <div class="flex items-center gap-3 mb-2">
            <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full <%= bar_color %> rounded-full transition-all duration-300" style="width: <%= pace_percentage %>%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= spending_rate.round(0) %>%</span>
          </div>
          
          <!-- Pace Indicator Badge -->
          <div class="inline-flex items-center px-3 py-1 rounded-full <%= indicator_bg %> <%= indicator_text %> text-xs font-semibold">
            <%= pace_status %>
          </div>
        </div>
        
        <!-- Projected Spending -->
        <div class="mb-2">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Projected month-end spending</p>
          <p class="text-lg font-bold text-gray-900 dark:text-white">$<%= number_with_precision(projected_total, precision: 2) %></p>
        </div>
      </div>
    </div>
    
    <!-- Section 2: Footer with comparison -->
    <div class="stat-card-footer pt-4 border-t border-gray-200 dark:border-gray-700">
      <p class="stat-card-detail text-xs text-gray-400 dark:text-gray-500">
        <%= comparison_text %>
      </p>
    </div>
  </div>
</div>

