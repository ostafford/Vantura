<% content_for :title, "Sign In - Vantura" %>

<div class="flex items-center justify-center min-h-screen px-4 py-6 md:min-h-[calc(100vh-4rem)] md:px-4 md:py-12">
  <div class="max-w-md w-full mx-auto">
    <!-- Sign In Card -->
    <section id="user-login-container" class="overflow-hidden rounded-2xl bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 shadow-deep">
      <!-- Header -->
      <header id="user-login-header" class="px-4 py-4 bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 md:px-8 md:py-6">
        <h1 id="user-login-heading" class="text-2xl font-bold text-white md:text-3xl">Sign in</h1>
        <p class="text-xs font-normal text-orange-100 mt-1 md:text-sm">Welcome back to Vantura</p>
      </header>

      <!-- Form -->
      <%= form_with url: session_url, id: "user-login-form", aria_labelledby: "user-login-heading", class: "p-4 space-y-4 md:p-8 md:space-y-6" do |form| %>
        <% if flash[:alert] %>
          <div id="user-login-error-alert" 
               class="p-4 mb-4 rounded-lg border border-red-200 bg-red-50 dark:border-red-800 dark:bg-red-900/20" 
               role="alert">
            <p class="text-sm font-medium text-red-900 dark:text-red-100">
              <%= flash[:alert] %>
            </p>
          </div>
        <% end %>

        <!-- Email Address -->
        <div id="user-login-email-field">
          <label for="user-email-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Email Address
          </label>
          <%= form.email_field :email_address,
              id: "user-email-input",
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "you@example.com",
              value: params[:email_address],
              aria_required: true,
              aria_invalid: false,
              aria_describedby: nil,
              class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-all focus:ring-2 focus:ring-primary-700 focus:border-transparent" %>
        </div>

        <!-- Password -->
        <div id="user-login-password-field">
          <label for="user-password-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Password
          </label>
          <%= form.password_field :password,
              id: "user-password-input",
              required: true,
              autocomplete: "current-password",
              placeholder: "Enter your password",
              maxlength: 72,
              aria_required: true,
              aria_invalid: false,
              aria_describedby: nil,
              class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-all focus:ring-2 focus:ring-primary-700 focus:border-transparent" %>
        </div>

        <!-- Submit Button -->
        <div id="user-login-actions">
          <%= form.submit "Sign in",
              id: "user-login-submit-button",
              class: "relative w-full min-h-[44px] px-6 py-3 rounded-xl text-center font-semibold text-white bg-gradient-to-r from-primary-700 to-primary-500 shadow-lg transition-all hover:from-primary-900 hover:to-primary-600" %>
        </div>

        <!-- Forgot Password Link -->
        <div class="text-center">
          <%= link_to "Forgot password?", new_password_path, id: "user-password-forgot-link", class: "text-sm font-medium text-primary-700 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-500" %>
        </div>

        <!-- Sign Up Link -->
        <div class="text-center">
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Don't have an account?
            <%= link_to "Sign up", sign_up_path, id: "user-signup-link", class: "font-medium text-primary-700 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-500" %>
          </p>
        </div>
      <% end %>
    </section>
  </div>
</div>
