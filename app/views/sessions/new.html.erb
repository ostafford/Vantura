<% content_for :title, "Sign In - Vantura" %>

<div class="flex items-center justify-center min-h-screen px-4 py-6 md:min-h-[calc(100vh-4rem)] md:px-4 md:py-12">
  <div class="max-w-md w-full mx-auto">
    <!-- Sign In Card -->
    <section id="user-login-container" class="overflow-hidden rounded-2xl surface-form-container-primary p-0 shadow-deep">
      <!-- Header -->
      <header id="user-login-header" class="px-4 py-4 surface-header-primary md:px-8 md:py-6">
        <h1 id="user-login-heading" class="text-2xl font-bold text-white md:text-3xl">Sign in</h1>
        <p class="text-xs font-normal text-overlay-subtle mt-1 md:text-sm">Welcome back to Vantura</p>
      </header>

      <!-- Form -->
      <%= form_with url: session_url, id: "user-login-form", aria_labelledby: "user-login-heading", class: "p-4 space-y-4 md:p-8 md:space-y-6" do |form| %>
        <% if flash[:alert] %>
          <div id="user-login-error-alert" 
               class="p-4 mb-4 rounded-lg form-error-border form-error-bg" 
               role="alert">
            <p class="text-sm font-medium form-error-text">
              <%= flash[:alert] %>
            </p>
          </div>
        <% end %>

        <!-- Email Address -->
        <div id="user-login-email-field">
          <label for="user-email-input" class="label-base">
            Email Address
          </label>
          <%= form.email_field :email_address,
              id: "user-email-input",
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "you@example.com",
              value: params[:email_address],
              aria_required: true,
              aria_invalid: false,
              aria_describedby: nil,
              class: "input-full rounded-xl" %>
        </div>

        <!-- Password -->
        <div id="user-login-password-field">
          <label for="user-password-input" class="label-base">
            Password
          </label>
          <%= form.password_field :password,
              id: "user-password-input",
              required: true,
              autocomplete: "current-password",
              placeholder: "Enter your password",
              maxlength: 72,
              aria_required: true,
              aria_invalid: false,
              aria_describedby: nil,
              class: "input-full rounded-xl" %>
        </div>

        <!-- Submit Button -->
        <div id="user-login-actions">
          <%= form.submit "Sign in",
              id: "user-login-submit-button",
              class: "relative w-full min-h-[44px] action-primary text-center" %>
        </div>

        <!-- Forgot Password Link -->
        <div class="text-center">
          <%= link_to "Forgot password?", new_password_path, id: "user-password-forgot-link", class: "text-sm font-medium link-primary" %>
        </div>

        <!-- Sign Up Link -->
        <div class="text-center">
          <p class="text-sm text-neutral-muted">
            Don't have an account?
            <%= link_to "Sign up", sign_up_path, id: "user-signup-link", class: "font-medium link-primary" %>
          </p>
        </div>
      <% end %>
    </section>
  </div>
</div>
