<div id="day-cell-<%= date.strftime('%Y-%m-%d') %>"
     class="relative min-h-[100px] border-r border-b border-gray-200 dark:border-gray-700 p-2<%= ' bg-gray-50 dark:bg-gray-900/50' unless is_current_month %><%= ' bg-blue-50 dark:bg-blue-900/20' if is_today %><%= ' ring-2 ring-blue-500 dark:ring-blue-400' if is_selected %>"
     data-controller="calendar-cell"
     data-calendar-cell-date-value="<%= date.strftime('%Y-%m-%d') %>"
     data-action="click->calendar-cell#selectDay"
     data-calendar-target="dayCell">
  
  <!-- Date Number -->
  <div class="flex justify-between items-start mb-1">
    <span class="text-sm font-medium <%= is_current_month ? 'text-gray-900 dark:text-white' : 'text-gray-400 dark:text-gray-600' %>">
      <%= date.day %>
    </span>
    <% if is_today %>
      <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
    <% end %>
  </div>

  <% if is_current_month && projection %>
    <!-- Planned Transactions Count -->
    <% if projection[:planned_count] > 0 %>
      <div class="flex items-center gap-1 mb-1">
        <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <span class="text-xs text-gray-600 dark:text-gray-400"><%= projection[:planned_count] %></span>
      </div>
    <% end %>

    <!-- Planned Total Amount -->
    <% planned_total = projection[:planned_total] || 0 %>
    <% if planned_total != 0 %>
      <div class="text-xs font-semibold <%= planned_total > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %> mb-1">
        <%= planned_total > 0 ? '+' : '' %><%= number_to_currency(planned_total.abs / 100.0, unit: "$", precision: 0) %>
      </div>
    <% end %>

    <!-- Projected Balance -->
    <% balance_cents = projection[:balance_cents] || 0 %>
    <div class="text-xs <%= balance_cents >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %> font-medium">
      <%= number_to_currency(balance_cents / 100.0, unit: "$", precision: 0) %>
    </div>

    <!-- Actual Transactions Indicator -->
    <% if projection[:actual_count] > 0 %>
      <div class="mt-1 flex items-center gap-1">
        <svg class="w-3 h-3 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-xs text-gray-500 dark:text-gray-400"><%= projection[:actual_count] %></span>
      </div>
    <% end %>
  <% end %>

  <!-- Hover Tooltip (hidden by default, shown on hover) -->
  <% if is_current_month && projection && (projection[:planned_count] > 0 || projection[:actual_count] > 0) %>
    <div class="hidden absolute z-10 w-64 p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg"
         data-calendar-cell-target="tooltip">
      <%= render "calendar/day_tooltip", date: date, projection: projection %>
    </div>
  <% end %>
</div>

