<!-- Calendar Grid - Option A: CSS Grid with Week Summary Cards -->
<div id="calendar-month-view-container" class="relative flex flex-col p-4 bg-gradient-to-br from-neutral-100 to-white dark:from-gray-800 dark:to-gray-900 rounded-2xl shadow-deep chevron-fix">
  <!-- Calendar Legend Toggle -->
  <%= render 'shared/calendar/legend_toggle' %>
  <!-- Weekday Header - Hidden on mobile, visible on tablet+ -->
  <div class="hidden grid grid-cols-7 gap-2 mb-2 pb-3 border-b border-gray-200 dark:border-gray-700 md:grid">
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Monday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Tuesday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Wednesday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Thursday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Friday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Saturday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Sunday</div>
  </div>

  <!-- Weeks -->
  <% @weeks.each_with_index do |week, week_idx| %>
    <section id="calendar-week-<%= week_idx %>-section" class="mb-4" data-week-index="<%= week_idx %>">
      <!-- Week Days Grid - Vertical stack on mobile, horizontal grid on tablet+ -->
      <div class="grid grid-cols-1 gap-4 mb-3 md:grid-cols-7 md:gap-2">
        <% week.each do |day| %>
          <% total = day_total(day[:date]) %>
          <% transactions = day_transactions(day[:date]) %>
          <% day_id = "calendar-day-#{day[:date].to_s}" %>
          <% has_trans = transactions.any? %>
          <% is_today = day[:date] == Date.today %>
          <% is_weekend = weekend?(day[:date]) %>
          <% recurring_count = day_recurring_count(day[:date]) %>
          <% has_recurring = day_has_recurring?(day[:date]) %>
          <% hypo_count = day_hypothetical_count(day[:date]) %>
          <% has_hypo = day_has_hypothetical?(day[:date]) %>

          <div id="calendar-day-<%= day[:date].to_s %>-card"
               class="flex flex-col min-h-[120px] px-4 py-4 rounded-lg border border-gray-200 dark:border-gray-700 <%= calendar_day_bg_class(total: total, in_current_month: day[:in_current_month], is_today: is_today, is_weekend: is_weekend) %> <%= has_trans ? 'cursor-pointer hover:bg-blue-50 dark:hover:bg-blue-900/20' : '' %> transition-all <%= day[:in_current_month] ? '' : 'hidden opacity-50 md:block' %> md:px-2 md:py-2 md:min-h-[100px]"
               <% if has_trans %>role="button" tabindex="0" aria-label="View transactions for <%= day[:date].strftime('%B %d, %Y') %>" data-day-id="<%= day_id %>" data-action="click->calendar#toggleDay keydown->calendar#handleDayKey"<% end %>>
            <% if day[:in_current_month] %>
              <!-- Day header: number and day name (mobile shows full day name) -->
              <div class="flex items-start justify-between mb-3 md:mb-2">
                <div class="flex items-center gap-2">
                  <% if is_today %>
                    <time datetime="<%= day[:date].iso8601 %>" class="inline-flex items-center justify-center h-7 w-7 rounded-full bg-primary-700 text-sm font-semibold text-white md:h-6 md:w-6 md:text-xs">
                      <%= day[:date].day %>
                    </time>
                  <% else %>
                    <time datetime="<%= day[:date].iso8601 %>" class="text-base font-bold text-gray-900 dark:text-gray-100 md:text-sm">
                      <%= day[:date].day %>
                    </time>
                  <% end %>
                  <!-- Day name on mobile only -->
                  <span class="text-sm font-medium text-gray-600 dark:text-gray-400 md:hidden">
                    <%= day[:date].strftime("%A") %>
                  </span>
                </div>
                <% if has_recurring || has_hypo %>
                  <div class="flex items-center gap-2">
                    <% if has_recurring %>
                      <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-info-200 dark:border-info-800 bg-info-100 dark:bg-info-900/30">
                        <svg class="w-3 h-3 text-info-600 dark:text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span class="text-xs font-semibold text-info-700 dark:text-info-300"><%= recurring_count %></span>
                      </div>
                    <% end %>
                    <% if has_hypo %>
                      <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-purple-200 dark:border-purple-800 bg-purple-100 dark:bg-purple-900/30">
                        <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                        </svg>
                        <span class="text-xs font-semibold text-purple-700 dark:text-purple-300"><%= hypo_count %></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              
              <!-- Transaction total (centered) -->
              <div class="flex flex-col flex-1 justify-center text-center">
                <div class="text-xl font-bold <%= total < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %> md:text-lg">
                  <% if total != 0 %>
                    <%= total < 0 ? "-" : "+" %>$<%= number_with_precision(total.abs, precision: 2) %>
                  <% else %>
                    $0.00
                  <% end %>
                </div>
                
                <!-- Category Badges (responsive: stack on mobile, wrap on desktop) -->
                <% if transactions.any? %>
                  <% top_categories = day_top_categories(day[:date], limit: 2) %>
                  <% if top_categories.any? %>
                    <div class="flex flex-col items-center justify-center gap-1 mt-1 md:flex-row md:flex-wrap md:mt-0.5">
                      <% top_categories.each do |cat_data| %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-medium whitespace-nowrap bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 md:text-[10px]"
                              title="<%= cat_data[:category]&.humanize || 'Uncategorized' %>: $<%= number_with_precision(cat_data[:amount], precision: 0) %>">
                          <%= cat_data[:category]&.humanize || 'Uncategorized' %>
                        </span>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <div class="mt-2 text-xs text-gray-500 dark:text-gray-400 md:mt-1">
                    <%= transactions.count %> <%= transactions.count == 1 ? 'item' : 'items' %>
                  </div>
                  <div class="text-xs text-blue-500 dark:text-blue-400 mt-1">Tap for details</div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Inline details slot for this week (desktop) -->
      <div id="calendar-week-details-<%= week_idx %>" class="mt-3"></div>

      <!-- Week Summary Row (EOW) - Option B - Sticky on mobile -->
      <% eow_balance = @eow_amounts[week_idx] %>
      <% week_start = week.first[:date] %>
      <% week_end = week.last[:date] %>
      <div id="calendar-week-<%= week_idx %>-summary-header" data-week-summary-index="<%= week_idx %>">
        <%= render partial: 'shared/bento_cards/week_summary_row', 
            locals: { 
              week_index: week_idx, 
              eow_amount: eow_balance, 
              week_start_date: week_start, 
              week_end_date: week_end 
            } %>
      </div>
    </section>
  <% end %>
</div>

<!-- Transaction Details Sections -->
<% @weeks.each do |week| %>
  <% week.each do |day| %>
    <% transactions = day_transactions(day[:date]) %>
    <% if transactions.any? && day[:in_current_month] %>
      <% day_id = "calendar-day-#{day[:date].to_s}" %>
      <div id="<%= day_id %>" class="hidden mt-6 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-blue-50 dark:bg-blue-900/20">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">
              <time datetime="<%= day[:date].iso8601 %>"><%= day[:date].strftime("%A, %B %d, %Y") %></time>
            </h3>
            <button type="button" 
                    id="calendar-day-<%= day[:date].to_s %>-close-button"
                    data-day-id="<%= day_id %>" 
                    data-action="click->calendar#toggleDay" 
                    aria-label="Close <%= day[:date].strftime('%B %d') %> details"
                    class="text-gray-500 dark:text-gray-400 transition-all hover:text-gray-700 dark:hover:text-gray-300 hover:scale-110">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
        <div class="overflow-x-auto">
          <%= render partial: 'shared/transactions/table', locals: { transactions: transactions, compact: false, show_date: false, show_footer_total: true, total_value: day_total(day[:date]) } %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>

