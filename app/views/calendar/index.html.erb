<% content_for :title, "Calendar - Vantura" %>
<% content_for :page_header_title, "Vantura Calendar" %>
<% content_for :page_header_subtitle, "View your transactions over time" %>

<%# Subscribe to Turbo Streams for real-time calendar updates %>
<%= turbo_stream_from @account.user if @account %>

<main id="calendar-main-container"
      data-modal-type-value="transaction" 
      data-controller="calendar calendar-day calendar-header recurring-modal" 
      data-recurring-modal-target="content" 
      aria-label="Calendar page">

  <% if @account %>
    <%= content_wrapper class: "py-4 sm:py-6 lg:py-8" do %>
      <!-- Turbo Frame for changing content -->
      <%= turbo_frame_tag "calendar_content", data: { turbo_preserve_scroll: true } do %>
        <!-- Calendar Overview Section -->
        <section id="calendar-bento-cards-section" class="bento-grid mb-6" aria-label="Calendar overview statistics">
          <%= render partial: "calendar/bento_cards" %>
        </section>

        <!-- View Switcher (Inside Turbo Frame, after Bento Grid) -->
        <nav id="calendar-view-switcher"
             class="mb-4 flex items-center justify-between gap-2 md:gap-3"
             aria-label="Calendar view switcher"
             data-controller="frame-navigation"
             data-frame-navigation-frame-id-value="calendar_content">
          <div class="inline-flex rounded-lg bg-white dark:bg-neutral-800 p-0.5 md:p-1 shadow-lg">
            <% week_switch_date = calendar_week_switch_date(@view, @date) %>
            <%= view_switcher_button(
              view: 'month',
              icon: 'calendar',
              label: 'Month',
              active: @view == 'month',
              path: calendar_month_path(@date.year, @date.month, view: 'month')
            ) %>
            <%= view_switcher_button(
              view: 'week',
              icon: 'clipboard',
              label: 'Week',
              active: @view == 'week',
              path: calendar_month_path(week_switch_date.year, week_switch_date.month, week_switch_date.day, view: 'week')
            ) %>
          </div>
          
          <!-- Date Picker and Today Button -->
          <div class="flex items-center gap-2">
            <!-- Date Picker -->
            <%= date_field_tag :jump_to_date, 
                @date,
                class: "input-base input-focus transition-all",
                id: "calendar-date-picker-input",
                title: "Jump to specific date",
                aria: { label: "Jump to specific date" },
                data: { 
                  action: "change->calendar#jumpToDate",
                  turbo_frame: "calendar_content"
                } %>
            
            <!-- Today Button -->
            <% today_path = calendar_today_path(@view, Date.today) %>
            <%= link_to(today_path,
                class: "inline-flex items-center justify-center w-10 h-10 md:px-4 md:py-2 md:w-auto md:h-auto border-2 surface-primary-border rounded-xl md:rounded-2xl text-brand surface-primary surface-primary-hover hover:shadow-lg hover:scale-105 transition-all font-medium text-xs md:text-sm",
                title: "Jump to today",
                aria: { label: "Jump to today" },
                data: { turbo_frame: 'calendar_content', action: "click->frame-navigation#navigate" }) do %>
              <svg class="w-5 h-5 md:w-4 md:h-4 md:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="hidden sm:inline">Today</span>
            <% end %>
          </div>
        </nav>

        <!-- Month/Week Navigation (Inside Turbo Frame, after Bento Grid) -->
        <div class="mb-4 md:mb-6">
          <%= render partial: "calendar/month_nav_wrapper" %>
        </div>

        <!-- Render Appropriate View -->
        <div id="calendar-view-container"
             data-current-balance="<%= @account.current_balance %>"
             <% if @view == 'week' %>
             data-end-of-week-balance="<%= calculate_week_end_balance(@account, @date) %>"
             data-end-of-week-date="<%= @date.end_of_week(:monday).strftime('%b %d') %>"
             <% else %>
             data-end-of-month-balance="<%= @end_of_month_balance %>"
             data-end-of-month-date="<%= @date.end_of_month.strftime('%b %d') %>"
             <% end %>>
      <% if @view == 'week' %>
        <%= render 'calendar/week_view' %>
      <% else %>
        <%= render 'calendar/month_view' %>
      <% end %>
        </div>
      <% end # Close turbo_frame_tag "calendar_content" %>
    <% end %>

  <% else %>
    <!-- No Account Message -->
    <%= content_wrapper class: "py-8" do %>
      <div class="surface-empty-state rounded-lg shadow-deep p-12 text-center">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">No account found</h2>
        <p class="text-neutral-600 dark:text-neutral-400">Please sync your Up Bank account first.</p>
      </div>
    <% end %>
  <% end %>

  <%= render 'shared/drawers/transaction_drawer', default_transaction_date: Date.today %>
  <%= render 'shared/drawers/recurring_drawer' %>
  <%= render 'shared/drawers/details_drawer' %>
</main>
