<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Balance Projection</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- Current Balance -->
    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Current Balance</p>
      <% local_current_balance = defined?(current_balance) ? current_balance : (@current_balance || 0) %>
      <p class="text-2xl font-bold <%= local_current_balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(local_current_balance / 100.0, unit: "$") %>
      </p>
    </div>

    <!-- Weekly Projection -->
    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">End of Week</p>
      <% local_weekly_projection = defined?(weekly_projection) ? weekly_projection : @weekly_projection %>
      <% if local_weekly_projection&.any? %>
        <% current_week = local_weekly_projection.find { |w| w[:start_date] <= Date.current && w[:end_date] >= Date.current } || local_weekly_projection.first %>
        <% week_balance = current_week[:balance_cents] || 0 %>
        <p class="text-2xl font-bold <%= week_balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
          <%= number_to_currency(week_balance / 100.0, unit: "$") %>
        </p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
          <%= current_week[:start_date].strftime("%b %d") %> - <%= current_week[:end_date].strftime("%b %d") %>
        </p>
      <% else %>
        <% local_current_balance = defined?(current_balance) ? current_balance : (@current_balance || 0) %>
        <p class="text-2xl font-bold text-gray-900 dark:text-white">
          <%= number_to_currency(local_current_balance / 100.0, unit: "$") %>
        </p>
      <% end %>
    </div>

    <!-- Monthly Projection -->
    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">End of Month</p>
      <% local_monthly_projection = defined?(monthly_projection) ? monthly_projection : (@monthly_projection || 0) %>
      <p class="text-2xl font-bold <%= local_monthly_projection >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(local_monthly_projection / 100.0, unit: "$") %>
      </p>
    </div>
  </div>
</div>

