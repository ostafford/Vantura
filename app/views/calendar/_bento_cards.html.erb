<%
  period_data = calendar_period_end_calculation(@account, @view, @date, @end_of_month_balance)
  is_month_view = @view == "month"
  week_start = @date.beginning_of_week(:monday)
  week_end = @date.end_of_week(:monday)
  pace_indicator = if is_month_view && @spending_rate.positive?
    spending_pace_indicator(@spending_rate)
  end
  upcoming_transactions = upcoming_transactions_list(
    @upcoming_recurring_expenses,
    @upcoming_recurring_income,
    @upcoming_hypothetical_expenses,
    @upcoming_hypothetical_income
  )
  week_range_data = format_date_range_with_count(week_start, week_end, @week_transaction_count, @date.year)
  pace_percentage = is_month_view ? [ @spending_rate, 100 ].min : 0
%>

<!-- Hero Card (2x2) -->
<%= render 'shared/bento_cards/hero_card',
    title: "Calendar Overview",
    subtitle: format_month_year(@date),
    description: "Track your balance trajectory and upcoming activity while you explore the calendar. Switch between views to see how income, expenses, and projections shift over time.",
    icon: 'calendar',
    size: 'col-span-1 row-span-1',
    color: 'blue',
    id: 'calendar-overview-hero-card' do %>
  <div class="flex flex-col gap-4">
    <div class="rounded-2xl bg-white/10 p-4 backdrop-blur-md shadow-deep shadow-black/50">
      <div class="flex items-center justify-between gap-3 text-sm font-medium text-white/80">
        <span>Current Balance</span>
        <span class="text-lg font-semibold text-white">
          <%= number_to_currency(@account.current_balance) %>
        </span>
      </div>
      <div class="mt-4 flex items-start justify-between gap-3 text-sm text-white/70">
        <div>
          <p class="font-semibold text-white/80"><%= period_data[:label] %></p>
          <p class="text-xs text-white/60">
            <time datetime="<%= period_data[:date].iso8601 %>"><%= period_data[:date].strftime('%b %d, %Y') %></time>
          </p>
        </div>
        <span class="text-lg font-semibold text-white">
          <%= number_to_currency(period_data[:value]) %>
        </span>
      </div>
    </div>

    <% if is_month_view %>
      <div class="rounded-2xl bg-white/10 p-4 backdrop-blur-md shadow-deep shadow-black/50">
        <div class="flex items-center justify-between text-xs font-semibold uppercase tracking-wide text-white/70">
          <span>Month Progress</span>
          <span><%= @progress_pct %>%</span>
        </div>
        <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-white/20">
          <div class="h-full rounded-full progress-fill" style="width: <%= @progress_pct %>%"></div>
        </div>
        <p class="mt-2 text-xs text-white/60">
          Day <%= @month_day %> of <%= @total_days %> • <%= number_to_currency(@actual_expenses) %> spent so far
        </p>
      </div>
    <% else %>
      <div class="rounded-2xl bg-white/10 p-4 backdrop-blur-sm shadow-inner shadow-white/10">
        <div class="flex items-center justify-between text-xs font-semibold uppercase tracking-wide text-white/70">
          <span>Week Snapshot</span>
          <span><%= week_range_data[:value] %></span>
        </div>
        <div class="mt-3 grid grid-cols-3 gap-3 text-sm">
          <div>
            <p class="text-[0.7rem] uppercase tracking-wide text-white/60">Income</p>
            <p class="mt-1 text-sm font-semibold amount-positive">
              <%= number_to_currency(@week_income) %>
            </p>
          </div>
          <div>
            <p class="text-[0.7rem] uppercase tracking-wide text-white/60">Expenses</p>
            <p class="mt-1 text-sm font-semibold amount-negative">
              <%= number_to_currency(@week_expenses) %>
            </p>
          </div>
          <div>
            <p class="text-[0.7rem] uppercase tracking-wide text-white/60">Net</p>
            <p class="mt-1 text-sm font-semibold <%= @week_total >= 0 ? 'amount-positive' : 'amount-negative' %>">
              <%= @week_total >= 0 ? '+' : '' %><%= number_to_currency(@week_total) %>
            </p>
          </div>
        </div>
        <p class="mt-2 text-xs text-white/60">
          <%= week_range_data[:subtitle] %>
        </p>
      </div>
    <% end %>
  </div>
<% end %>

<%
  cash_flow_locals =
    if is_month_view
      {
        income_total: @actual_income,
        expense_total: @actual_expenses,
        income_count: @month_income_count,
        expense_count: @month_expense_count,
        projected_income_total: @hypothetical_income,
        projected_expense_total: @hypothetical_expenses,
        projected_income_count: 0,
        projected_expense_count: 0,
        top_income_merchants: @month_top_income_merchants,
        top_expense_merchants: @month_top_expense_merchants,
        top_income_categories: [],
        top_expense_categories: [],
        current_date: @date,
        account: @account,
        id: 'calendar-cash-flow-card',
        size: 'col-span-1 md:col-span-2 row-span-1',
        period_label: 'This month'
      }
    else
      {
        income_total: @week_income,
        expense_total: @week_expenses,
        income_count: @week_income_count,
        expense_count: @week_expense_count,
        projected_income_total: 0,
        projected_expense_total: 0,
        projected_income_count: 0,
        projected_expense_count: 0,
        top_income_merchants: @week_top_income_merchants,
        top_expense_merchants: @week_top_expense_merchants,
        top_income_categories: [],
        top_expense_categories: [],
        current_date: @date,
        account: @account,
        id: 'calendar-cash-flow-card',
        size: 'col-span-1 md:col-span-2 row-span-1',
        period_label: 'This week'
      }
    end
%>

<%= render partial: 'shared/bento_cards/cash_flow_card', locals: cash_flow_locals %>

<%= render partial: 'calendar/timeline_card',
    locals: {
      period_label: period_data[:label],
      period_value: period_data[:value],
      period_date: period_data[:date],
      is_month_view: is_month_view,
      spending_daily_rate: @spending_daily_rate,
      spending_projected_total: @spending_projected_total,
      spending_velocity_change_pct: @spending_velocity_change_pct,
      spending_rate: @spending_rate,
      pace_indicator: pace_indicator,
      pace_percentage: pace_percentage,
      upcoming_transactions: upcoming_transactions,
      days_remaining: is_month_view ? days_remaining_in_month(@date) : [ (week_end - Date.today).to_i, 0 ].max,
      current_balance: @account.current_balance,
      transaction_count: is_month_view ? @transaction_count : @week_transaction_count,
      week_total: @week_total
    } %>

