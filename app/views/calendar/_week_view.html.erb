<!-- Week View Grid - Matching Month View Layout -->
<div id="week-view-container" class="bg-gradient-to-br from-neutral-100 to-white dark:from-gray-800 dark:to-gray-900 rounded-2xl shadow-deep chevron-fix p-4 relative">
  <!-- Calendar Legend Toggle -->
  <div class="absolute top-2 right-2 md:top-4 md:right-4 z-10">
    <button type="button" 
            id="calendar-legend-toggle-button"
            data-action="click->calendar#toggleLegend"
            class="w-6 h-6 md:w-5 md:h-5 rounded-full bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 flex items-center justify-center transition-colors"
            aria-label="Show calendar legend"
            title="What do the colors mean?">
      <svg class="w-4 h-4 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
    </button>
    
    <!-- Legend Dropdown (hidden by default) -->
    <div id="calendar-legend-panel" 
         class="hidden absolute top-10 right-0 md:top-12 md:right-0 z-20 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-4 min-w-[200px] md:min-w-[240px]">
      <h4 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Calendar Guide</h4>
      <div class="space-y-2 text-xs">
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-green-50 dark:bg-green-900/15 border border-green-200 dark:border-green-800 flex-shrink-0"></div>
          <span class="text-gray-700 dark:text-gray-300">Net positive day</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-red-50 dark:bg-red-900/15 border border-red-200 dark:border-red-800 flex-shrink-0"></div>
          <span class="text-gray-700 dark:text-gray-300">Net negative day</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-white dark:bg-gray-800 border-2 border-primary-700/40 dark:border-primary-500/40 flex-shrink-0"></div>
          <span class="text-gray-700 dark:text-gray-300">Today</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-purple-100 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-800 flex-shrink-0">
            <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <span class="text-gray-700 dark:text-gray-300">Hypothetical transactions</span>
        </div>
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
          <div class="w-4 h-4 rounded bg-gray-50/50 dark:bg-gray-700/20 border border-gray-200 dark:border-gray-600 flex-shrink-0"></div>
          <span class="text-gray-700 dark:text-gray-300">Weekend</span>
        </div>
      </div>
    </div>
  </div>
  <!-- Weekday Header - Hidden on mobile, visible on tablet+ -->
  <div class="hidden md:grid grid-cols-7 gap-2 mb-2 border-b border-gray-200 dark:border-gray-700 pb-3">
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Monday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Tuesday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Wednesday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Thursday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Friday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Saturday</div>
    <div class="px-2 py-2 text-center font-semibold text-gray-700 dark:text-gray-300">Sunday</div>
  </div>

  <!-- Week Days Grid - Vertical stack on mobile, horizontal grid on tablet+ -->
  <div class="mb-4" data-week-index="0" id="week-0-section">
    <div class="grid grid-cols-1 md:grid-cols-7 gap-4 md:gap-2 mb-3">
      <% @week_days.each do |day| %>
        <% total = day_total(day[:date]) %>
        <% transactions = day_transactions(day[:date]) %>
        <% day_id = "calendar-day-#{day[:date].to_s}" %>
        <% has_trans = transactions.any? %>
        <% is_today = day[:is_today] %>
        <% is_weekend = [0, 6].include?(day[:date].wday) # Saturday = 6, Sunday = 0 %>
        <% hypo_count = day_hypothetical_count(day[:date]) %>
        <% has_hypo = day_has_hypothetical?(day[:date]) %>

        <div id="calendar-day-<%= day[:date].to_s %>-card"
             class="<%= calendar_day_bg_class(total: total, in_current_month: day[:is_current_month], is_today: is_today, is_weekend: is_weekend) %> flex flex-col rounded-lg px-4 md:px-2 py-4 md:py-2 min-h-[120px] md:min-h-[100px] border border-gray-200 dark:border-gray-700 <%= has_trans ? 'hover:bg-blue-50 dark:hover:bg-blue-900/20 cursor-pointer' : '' %> transition-all <%= day[:is_current_month] ? '' : 'hidden md:block opacity-50' %>"
             <% if has_trans %>data-day-id="<%= day_id %>" data-action="click->calendar#toggleDay"<% end %>>
          <!-- Day header: number and day name (mobile shows full day name) -->
          <div class="flex items-start justify-between mb-3 md:mb-2">
            <div class="flex items-center gap-2">
              <% if is_today %>
                <time datetime="<%= day[:date].iso8601 %>" class="inline-flex items-center justify-center h-7 w-7 md:h-6 md:w-6 rounded-full bg-primary-700 text-sm md:text-xs font-semibold text-white">
                  <%= day[:date].day %>
                </time>
              <% else %>
                <time datetime="<%= day[:date].iso8601 %>" class="text-base md:text-sm font-bold text-gray-900 dark:text-gray-100">
                  <%= day[:date].day %>
                </time>
              <% end %>
              <!-- Day name on mobile only -->
              <span class="md:hidden text-sm font-medium text-gray-600 dark:text-gray-400">
                <%= day[:date].strftime("%A") %>
              </span>
            </div>
            <!-- Hypothetical indicator badge -->
            <% if has_hypo %>
              <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-purple-100 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-800">
                <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                <span class="text-xs font-semibold text-purple-700 dark:text-purple-300"><%= hypo_count %></span>
              </div>
            <% end %>
          </div>
          
          <!-- Transaction total (centered) -->
          <div class="text-center flex-1 flex flex-col justify-center">
            <div class="text-xl md:text-lg font-bold <%= total < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
              <% if total != 0 %>
                <%= total < 0 ? "-" : "+" %>$<%= number_with_precision(total.abs, precision: 2) %>
              <% else %>
                $0.00
              <% end %>
            </div>
            
            <!-- Category Badges (responsive: stack on mobile, wrap on desktop) -->
            <% if transactions.any? %>
              <% top_categories = day_top_categories(day[:date], limit: 2) %>
              <% if top_categories.any? %>
                <div class="flex flex-col md:flex-row md:flex-wrap items-center justify-center gap-1 mt-1 md:mt-0.5">
                  <% top_categories.each do |cat_data| %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] md:text-[10px] font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 whitespace-nowrap"
                          title="<%= cat_data[:category]&.humanize || 'Uncategorized' %>: $<%= number_with_precision(cat_data[:amount], precision: 0) %>">
                      <%= cat_data[:category]&.humanize || 'Uncategorized' %>
                    </span>
                  <% end %>
                </div>
              <% end %>
              
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-2 md:mt-1">
                <%= transactions.count %> <%= transactions.count == 1 ? 'item' : 'items' %>
              </div>
              <div class="text-xs text-blue-500 dark:text-blue-400 mt-1">Tap for details</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Inline details slot for this week (desktop) -->
    <div id="week-details-0" class="mt-3"></div>

    <!-- Week Summary Row - Sticky on mobile -->
    <% week_start = @date.beginning_of_week(:monday) %>
    <% week_end = @date.end_of_week(:monday) %>
    <div id="week-summary-header-0" data-week-summary-index="0">
      <%= render partial: 'shared/bento_cards/week_summary_row', 
          locals: { 
            week_index: 0, 
            eow_amount: @week_end_balance, 
            week_start_date: week_start, 
            week_end_date: week_end,
            income_total: @week_income,
            expense_total: @week_expenses,
            net_total: @week_total,
            transaction_count: @week_transaction_count
          } %>
    </div>
  </div>
</div>

<!-- Transaction Details Sections -->
  <% @week_days.each do |day| %>
    <% transactions = day_transactions(day[:date]) %>
    <% if transactions.any? %>
      <% day_id = "calendar-day-#{day[:date].to_s}" %>
      <div id="<%= day_id %>" class="hidden mt-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="bg-blue-50 dark:bg-blue-900/20 px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">
              <time datetime="<%= day[:date].iso8601 %>"><%= day[:date].strftime("%A, %B %d, %Y") %></time>
            </h3>
            <button type="button" 
                    id="calendar-day-<%= day[:date].to_s %>-close-button"
                    data-day-id="<%= day_id %>" 
                    data-action="click->calendar#toggleDay" 
                    aria-label="Close <%= day[:date].strftime('%B %d') %> details"
                    class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:scale-110 transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
      <div class="overflow-x-auto">
        <%= render partial: 'shared/transactions/table', locals: { transactions: transactions, compact: false, show_date: false, show_footer_total: true, total_value: day_total(day[:date]) } %>
      </div>
    </div>
  <% end %>
<% end %>
