<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
      <%= date.strftime("%B %d, %Y") %>
    </h3>
    <button type="button"
        class="lg:hidden text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
        data-calendar-action="closeDayDetails"
        data-action="click->calendar#closeDayDetails"
        aria-label="Close day details">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Projected Balance -->
  <div class="mb-4 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Projected Balance</p>
    <% balance_cents = projection[:balance_cents] || 0 %>
    <p class="text-xl font-bold <%= balance_cents >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
      <%= number_to_currency(balance_cents / 100.0, unit: "$") %>
    </p>
  </div>

  <!-- Planned Transactions -->
  <div class="mb-4">
    <div class="flex justify-between items-center mb-2">
      <h4 class="text-sm font-semibold text-gray-900 dark:text-white">Planned Transactions</h4>
      <button type="button"
          class="text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
          data-calendar-action="openPlannedTransactionModal"
          data-action="click->calendar#openPlannedTransactionModal"
          data-calendar-date-value="<%= date.strftime('%Y-%m-%d') %>">
        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add
      </button>
    </div>

    <% if projection[:planned_transactions]&.any? %>
      <div class="space-y-2">
        <% projection[:planned_transactions].each do |pt| %>
          <div class="p-2 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= pt[:description] %></p>
                <% if pt[:planned_transaction].is_recurring? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300 mt-1">
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    Recurring
                  </span>
                <% end %>
              </div>
              <div class="text-right ml-2">
                <p class="text-sm font-semibold <%= pt[:transaction_type] == 'income' ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  <%= pt[:transaction_type] == 'income' ? '+' : '-' %><%= number_to_currency(pt[:amount_cents].abs / 100.0, unit: "$") %>
                </p>
                <% if pt[:category] %>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= pt[:category].name %></p>
                <% end %>
              </div>
            </div>
            <div class="mt-2 flex gap-2 items-center">
              <%= link_to "Edit",
                  edit_planned_transaction_path(pt[:planned_transaction].id),
                  class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300",
                  data: { 
                    turbo_frame: "planned-transaction-form",
                    action: "click->calendar#openPlannedTransactionModal"
                  } %>
              <%= button_to "Delete",
                  planned_transaction_path(pt[:planned_transaction].id),
                  method: :delete,
                  class: "text-xs text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 bg-transparent border-0 p-0 cursor-pointer",
                  form: { 
                    data: { 
                      turbo_frame: "day-details",
                      turbo_confirm: "Are you sure?" 
                    },
                    class: "inline-flex items-center",
                    style: "display: inline-flex; align-items: center;"
                  } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">No planned transactions</p>
    <% end %>
  </div>

  <!-- Actual Transactions -->
  <% if projection[:actual_transactions]&.any? %>
    <div>
      <h4 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Actual Transactions</h4>
      <div class="space-y-2">
        <% projection[:actual_transactions].first(5).each do |transaction| %>
          <div class="p-2 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= transaction.description %></p>
                <% if transaction.category %>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= transaction.category.name %></p>
                <% end %>
              </div>
              <div class="text-right ml-2">
                <p class="text-sm font-semibold <%= transaction.amount_cents > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  <%= number_to_currency(transaction.amount_cents.abs / 100.0, unit: "$") %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
        <% if projection[:actual_count] > 5 %>
          <%= link_to "View all #{projection[:actual_count]} transactions",
              transactions_path(start_date: date, end_date: date),
              class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 mt-2 block text-center",
              data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
    <% end %>
</div>

