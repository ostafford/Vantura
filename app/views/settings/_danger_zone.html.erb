<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-2 border-red-200 dark:border-red-800">
  <h2 class="text-xl font-semibold text-red-600 dark:text-red-400 mb-4">Danger Zone</h2>
  
  <div class="space-y-4">
    <div>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Delete Account</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        This will permanently delete your account and all associated data. This action cannot be undone.
        This includes:
      </p>
      <ul class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside mb-4 space-y-1">
        <li>All your transactions and accounts</li>
        <li>All your projects and shared expenses</li>
        <li>All your goals and planned transactions</li>
        <li>All your filters and preferences</li>
      </ul>
    </div>

    <%= button_to settings_account_path,
        method: :delete,
        class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 focus:ring-4 focus:ring-red-300 dark:bg-red-500 dark:hover:bg-red-600 dark:focus:ring-red-800",
        data: { 
          turbo_confirm: "Are you absolutely sure? This will permanently delete your account and all data. This action cannot be undone."
        } do %>
      Delete My Account
    <% end %>
  </div>
</div>

