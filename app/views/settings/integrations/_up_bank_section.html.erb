<!-- Up Bank Integration Section -->
<div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep overflow-hidden">
  <div class="bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 px-6 py-5">
    <h2 class="text-2xl font-bold text-white">Up Bank Integration</h2>
    <p class="text-orange-100 text-sm mt-1">Securely connect your Up Bank account</p>
  </div>

  <div class="p-6">
    <!-- Information Section -->
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 mb-6">
      <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        How to get your Personal Access Token
      </h3>
      <ol class="text-sm text-blue-800 dark:text-blue-200 space-y-2 ml-7 list-decimal">
        <li>Visit <a href="https://developer.up.com.au/" target="_blank" class="underline hover:text-blue-600">developer.up.com.au</a></li>
        <li>Log in with your Up Bank credentials</li>
        <li>Click "Get your Personal Access Token"</li>
        <li>Copy the token and paste it below</li>
      </ol>
    </div>

    <!-- Security Notice -->
    <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 mb-6">
      <h3 class="font-semibold text-green-900 dark:text-green-100 mb-2 flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        Your token is secure
      </h3>
      <ul class="text-sm text-green-800 dark:text-green-200 space-y-1 ml-7 list-disc">
        <li>Encrypted using Rails encrypted attributes</li>
        <li>Never stored in plaintext</li>
        <li>Filtered from all log files</li>
        <li>Only accessible by you</li>
      </ul>
    </div>

    <%= form_with model: Current.user, url: update_up_bank_integration_settings_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <label for="user_up_bank_token" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Personal Access Token
        </label>
        <%= f.text_field :up_bank_token,
            class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:ring-2 focus:ring-primary-700 focus:border-transparent transition-all font-mono",
            placeholder: Current.user.up_bank_token.present? ? "Token is saved - enter new token to update" : "up:yeah:xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
            value: "",
            autocomplete: "off",
            onfocus: "this.placeholder = 'Paste your Up Bank token here'" %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
          <% if Current.user.up_bank_token.present? %>
            Token is saved and encrypted. Enter a new token to update.
          <% else %>
            Paste your Up Bank Personal Access Token here
          <% end %>
        </p>
      </div>

      <!-- Validation Info -->
      <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4">
        <h3 class="font-semibold text-yellow-900 dark:text-yellow-100 mb-2 flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Token Validation
        </h3>
        <p class="text-sm text-yellow-800 dark:text-yellow-200">
          When you save your token, we'll verify it by pinging the Up Bank API. 
          If valid, we'll automatically sync your account data and redirect you to the Dashboard!
        </p>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Save & Sync", 
            class: "flex-1 bg-gradient-to-r from-primary-700 to-primary-500 hover:from-primary-900 hover:to-primary-700 text-white px-6 py-3 rounded-xl hover:shadow-xl hover:scale-105 transition-all font-semibold shadow-lg text-center",
            data: { disable_with: "Validating token and syncing data..." } %>
        <%= link_to "Cancel", root_path, class: "px-6 py-3 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-300 dark:hover:bg-gray-600 hover:shadow-md hover:scale-105 transition-all font-semibold text-center" %>
      </div>
    <% end %>

    <!-- Read-only Access Notice -->
    <div class="mt-6 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
      <p class="text-xs text-gray-600 dark:text-gray-400">
        <strong>Note:</strong> Vantura only has <strong>read-only</strong> access to your Up Bank account. 
        We can view transactions and account balances, but we cannot make transfers or modify your account in any way.
      </p>
    </div>
  </div>
</div>

