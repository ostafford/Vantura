<!-- User Profile Section -->
<div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep overflow-hidden">
  <div class="bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 px-6 py-5">
    <h2 class="text-2xl font-bold text-white">Account Information</h2>
    <p class="text-orange-100 text-sm mt-1">Your account details and statistics</p>
  </div>

  <div class="p-6">
    <!-- Email Address -->
    <div class="mb-6">
      <%= form_with model: @user, url: update_profile_settings_path, method: :patch, class: "space-y-4" do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4">
            <h3 class="font-semibold text-red-900 dark:text-red-100 mb-2">
              <%= pluralize(@user.errors.count, "error") %> prevented this account from being saved:
            </h3>
            <ul class="text-sm text-red-800 dark:text-red-200 space-y-1 ml-5 list-disc">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user-profile-name-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Full Name
          </label>
          <%= f.text_field :name,
              id: "user-profile-name-input",
              autocomplete: "name",
              placeholder: "John Doe",
              maxlength: 100,
              aria_required: false,
              aria_invalid: (@user.errors[:name].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:name].any? ? "user-profile-name-error" : nil),
              class: "w-full px-4 py-3 text-gray-900 dark:text-white bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-primary-700 focus:border-transparent transition-all" %>
          <% if @user.errors[:name].any? %>
            <div id="user-profile-name-error" class="text-sm text-red-600 dark:text-red-400 mt-1" role="alert">
              <%= @user.errors[:name].first %>
            </div>
          <% end %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            This name will be displayed in project cards and member lists
          </p>
        </div>

        <div>
          <label for="user_email_address" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Email Address
          </label>
          <%= f.email_field :email_address,
              id: "user-profile-email-input",
              class: "w-full px-4 py-3 text-gray-900 dark:text-white bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-primary-700 focus:border-transparent transition-all",
              placeholder: "you@example.com",
              autocomplete: "email",
              aria_required: true,
              aria_invalid: (@user.errors[:email_address].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:email_address].any? ? "user-profile-email-error" : nil) %>
          <% if @user.errors[:email_address].any? %>
            <div id="user-profile-email-error" class="text-sm text-red-600 dark:text-red-400 mt-1" role="alert">
              <%= @user.errors[:email_address].first %>
            </div>
          <% end %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            We'll use this email address to send you important account notifications.
          </p>
        </div>

        <div class="flex gap-3">
          <%= f.submit "Update Profile", 
              class: "px-6 py-3 bg-primary-700 hover:bg-primary-900 text-white rounded-xl hover:shadow-xl hover:scale-105 transition-all font-semibold shadow-lg",
              data: { disable_with: "Updating..." } %>
        </div>
      <% end %>
    </div>

    <!-- Member Since -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
        Member Since
      </label>
      <p class="text-gray-900 dark:text-white">
        <%= @user.created_at.strftime("%B %d, %Y") %>
      </p>
    </div>

    <!-- Account Statistics -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Connected Accounts</p>
        <p class="text-2xl font-bold text-primary-700 dark:text-primary-500"><%= @accounts_count %></p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Projects</p>
        <p class="text-2xl font-bold text-primary-700 dark:text-primary-500"><%= @projects_count %></p>
      </div>
    </div>

    <!-- Actions -->
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Account Actions</h3>
      <div class="flex gap-3">
        <%= link_to "Change Password", new_password_path, class: "px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 hover:shadow-md hover:scale-105 transition-all font-semibold text-sm" %>
      </div>
    </div>
  </div>
</div>

