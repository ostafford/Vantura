<%# Close password modal %>
<%= turbo_stream.append "body" do %>
  <script>
    setTimeout(function() {
      const modal = document.getElementById('password-modal');
      if (modal) {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
        
        // Try Stimulus controller close method
        if (window.Stimulus) {
          const modalElement = document.getElementById('password-modal');
          if (modalElement) {
            const controller = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'modal');
            if (controller && typeof controller.close === 'function') {
              controller.close();
            }
          }
        }
      }
    }, 100);
  </script>
<% end %>

<%# Update profile form frame %>
<%= turbo_stream.replace "profile-form" do %>
  <%= render "profile" %>
<% end %>

<%# Show flash message as toast %>
<% if flash[:notice].present? || notice.present? %>
  <%= turbo_stream.append "toast-container" do %>
    <%= render "shared/toast", type: "success", message: flash[:notice] || notice %>
  <% end %>
<% end %>

