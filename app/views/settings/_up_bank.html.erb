<%= turbo_frame_tag "up-bank-status" do %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Up Bank Integration</h2>
    
    <% if @user.has_up_bank_token? %>
      <!-- Connected State -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-green-600 dark:text-green-400 font-medium">Connected</span>
        </div>

        <% if @user.last_synced_at %>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Last Synced: <%= time_ago_in_words(@user.last_synced_at) %> ago
          </p>
        <% end %>

        <% if @accounts&.any? %>
          <div>
            <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Connected Accounts:</p>
            <ul class="space-y-1">
              <% @accounts.each do |account| %>
                <li class="text-sm text-gray-600 dark:text-gray-400">
                  • <%= account.display_name %> (<%= account.balance.format %>)
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex flex-wrap gap-2">
          <%= button_to settings_sync_now_path, 
              method: :post,
              class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:bg-blue-500 dark:hover:bg-blue-600 dark:focus:ring-blue-800",
              data: { turbo_frame: "_top" } do %>
            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Sync Now
          <% end %>

          <%= button_to settings_disconnect_bank_path,
              method: :delete,
              class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 focus:ring-4 focus:ring-red-300 dark:bg-red-500 dark:hover:bg-red-600 dark:focus:ring-red-800",
              data: { 
                turbo_confirm: "Are you sure? This will disconnect your Up Bank account and delete all synced accounts and transactions."
              } do %>
            Disconnect
          <% end %>
        </div>

        <!-- Token Update -->
        <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Personal Access Token
          </label>
          <%= form_with model: @user, url: settings_up_bank_token_path, method: :patch,
              data: { controller: "token-input", turbo_frame: "_top" } do |f| %>
            <div class="relative">
              <%= f.text_field :up_bank_token,
                  type: "password",
                  value: "",
                  placeholder: "Enter new token",
                  autocomplete: "off",
                  class: "w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white",
                  data: { 
                    token_input_target: "input",
                    action: "input->token-input#validate"
                  } %>
              <button type="button"
                      class="absolute inset-y-0 right-0 pr-3 flex items-center"
                      data-action="click->token-input#toggleVisibility"
                      data-token-input-target="toggle">
                <svg class="w-5 h-5 text-gray-400" 
                     data-token-input-target="eyeIcon"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg class="w-5 h-5 text-gray-400 hidden"
                     data-token-input-target="eyeSlashIcon"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                </svg>
              </button>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400" data-token-input-target="feedback"></p>
            <div class="mt-2">
              <%= f.submit "Update Token",
                  class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:bg-blue-500 dark:hover:bg-blue-600 dark:focus:ring-blue-800",
                  data: { token_input_target: "button" } %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- Not Connected State -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
          <span class="text-gray-600 dark:text-gray-400 font-medium">Not Connected</span>
        </div>

        <p class="text-sm text-gray-600 dark:text-gray-400">
          Connect your Up Bank account to start syncing transactions.
        </p>

        <%= link_to onboarding_connect_up_bank_path,
            class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:bg-blue-500 dark:hover:bg-blue-600 dark:focus:ring-blue-800",
            data: { turbo_frame: "_top" } do %>
          Connect Up Bank Account
        <% end %>
      </div>
    <% end %>

    <!-- Help Text -->
    <div class="mt-4 p-3 bg-blue-50 dark:bg-gray-700 rounded-lg">
      <p class="text-xs text-gray-700 dark:text-gray-300">
        <strong>How to get your token:</strong><br>
        1. Open Up app → Settings<br>
        2. Data Sharing → Personal Access Token<br>
        3. Generate Token
      </p>
    </div>
  </div>
<% end %>

