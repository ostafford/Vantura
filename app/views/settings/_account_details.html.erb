<% stats = account_statistics(account) %>

<div class="surface-card-base rounded-lg p-4 border-table-divider space-y-4">
  <div id="<%= dom_id(account, "goal_section") %>">
    <%= render "settings/account_goal_section",
               account: account,
               goal_feedback: nil,
               goal_form_state: nil %>
  </div>

  <h4 class="text-sm font-semibold text-neutral-base mb-3">Account Statistics</h4>
  
  <!-- This Month Stats -->
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div class="surface-card-base rounded-lg p-3">
      <p class="text-xs text-neutral-muted mb-1">This Month Income</p>
      <p class="text-lg font-bold amount-positive">
        $<%= number_with_precision(stats[:month_stats][:income_total], precision: 2) %>
      </p>
      <p class="text-xs text-neutral-muted">
        <%= pluralize(stats[:month_stats][:income_count], 'transaction') %>
      </p>
    </div>
    
    <div class="surface-card-base rounded-lg p-3">
      <p class="text-xs text-neutral-muted mb-1">This Month Expenses</p>
      <p class="text-lg font-bold amount-negative">
        $<%= number_with_precision(stats[:month_stats][:expense_total], precision: 2) %>
      </p>
      <p class="text-xs text-neutral-muted">
        <%= pluralize(stats[:month_stats][:expense_count], 'transaction') %>
      </p>
    </div>
  </div>
  
  <!-- Net Cash Flow -->
  <% net_positive = stats[:month_stats][:net_cash_flow] >= 0 %>
  <div class="mb-4 p-3 <%= net_positive ? 'surface-net-positive' : 'surface-net-negative' %> rounded-lg">
    <p class="text-xs text-neutral-muted mb-1">Net Cash Flow (This Month)</p>
    <p class="text-xl font-bold <%= net_positive ? 'amount-positive' : 'amount-negative' %>">
      $<%= number_with_precision(stats[:month_stats][:net_cash_flow], precision: 2) %>
    </p>
  </div>
  
  <!-- Summary Stats -->
  <div class="grid grid-cols-3 gap-3 mb-4 text-center">
    <div>
      <p class="text-xs text-neutral-muted mb-1">All Time</p>
      <p class="text-sm font-bold text-neutral-base">
        <%= number_with_delimiter(stats[:all_time_count]) %>
      </p>
      <p class="text-xs text-neutral-muted">transactions</p>
    </div>
    
    <div>
      <p class="text-xs text-neutral-muted mb-1">This Month</p>
      <p class="text-sm font-bold text-neutral-base">
        <%= number_with_delimiter(stats[:month_stats][:transaction_count]) %>
      </p>
      <p class="text-xs text-neutral-muted">transactions</p>
    </div>
    
    <div>
      <p class="text-xs text-neutral-muted mb-1">Active Recurring</p>
      <p class="text-sm font-bold text-neutral-base">
        <%= number_with_delimiter(stats[:active_recurring_count]) %>
      </p>
      <p class="text-xs text-neutral-muted">patterns</p>
    </div>
  </div>
  
  <!-- Quick Actions -->
  <div class="pt-3 border-t border-table-divider">
    <%= link_to transactions_path, 
        id: "account-#{account.id}-view-transactions-link",
        class: "btn-primary px-4 py-2 text-sm" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      View All Transactions
    <% end %>
  </div>
</div>

