<div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep overflow-hidden">
  <div class="surface-header-primary px-6 py-5">
    <h2 class="text-2xl font-bold text-white">Account Information</h2>
    <p class="text-header-subtitle text-sm mt-1">Your account details and statistics</p>
  </div>

  <div class="p-6">
    <!-- Email Address -->
    <div class="mb-6">
      <%= form_with model: @user, url: update_profile_settings_path, method: :patch, class: "space-y-4", data: { turbo: true } do |f| %>
        <% if @user.errors.any? %>
          <div class="form-error-bg form-error-border rounded-lg p-4 mb-4">
            <h3 class="form-error-text mb-2">
              <%= pluralize(@user.errors.count, "error") %> prevented this account from being saved:
            </h3>
            <ul class="form-error space-y-1 ml-5 list-disc">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user-profile-name-input" class="label-base">
            Full Name
          </label>
          <%= f.text_field :name,
              id: "user-profile-name-input",
              autocomplete: "name",
              placeholder: "John Doe",
              maxlength: 100,
              aria_required: false,
              aria_invalid: (@user.errors[:name].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:name].any? ? "user-profile-name-error" : nil),
              class: "input-full" %>
          <% if @user.errors[:name].any? %>
            <div id="user-profile-name-error" class="form-error mt-1" role="alert">
              <%= @user.errors[:name].first %>
            </div>
          <% end %>
          <p class="text-xs text-neutral-muted mt-1">
            This name will be displayed in project cards and member lists
          </p>
        </div>

        <div>
          <label for="user-profile-email-input" class="label-base">
            Email Address
          </label>
          <%= f.email_field :email_address,
              id: "user-profile-email-input",
              class: "input-full",
              placeholder: "you@example.com",
              autocomplete: "email",
              aria_required: true,
              aria_invalid: (@user.errors[:email_address].any? ? "true" : "false"),
              aria_describedby: (@user.errors[:email_address].any? ? "user-profile-email-error" : nil) %>
          <% if @user.errors[:email_address].any? %>
            <div id="user-profile-email-error" class="form-error mt-1" role="alert">
              <%= @user.errors[:email_address].first %>
            </div>
          <% end %>
          <p class="text-xs text-neutral-muted mt-1">
            We'll use this email address to send you important account notifications.
          </p>
        </div>

        <div class="flex gap-3">
          <%= f.submit "Update Profile", 
              class: "btn-primary px-6 py-3",
              data: { disable_with: "Updating..." } %>
        </div>
      <% end %>
    </div>

    <!-- Member Since -->
    <div class="mb-6">
      <label class="label-base">
        Member Since
      </label>
      <p class="text-neutral-base">
        <%= @user.created_at.strftime("%B %d, %Y") %>
      </p>
    </div>

    <!-- Account Statistics -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="surface-card-base rounded-lg p-4 border-table-divider">
        <p class="text-sm text-neutral-muted mb-1">Connected Accounts</p>
        <p class="text-2xl font-bold text-brand"><%= @statistics[:accounts_count] %></p>
      </div>
      <div class="surface-card-base rounded-lg p-4 border-table-divider">
        <p class="text-sm text-neutral-muted mb-1">Projects</p>
        <p class="text-2xl font-bold text-brand"><%= @statistics[:projects_count] %></p>
      </div>
    </div>

    <!-- Actions -->
    <div class="border-t border-table-divider pt-6">
      <h3 class="font-semibold text-neutral-base mb-3">Account Actions</h3>
      <div class="flex gap-3">
        <%= link_to "Change Password", new_password_path, data: { turbo_frame: "_top" }, class: "btn-secondary text-sm" %>
      </div>
    </div>
  </div>
</div>

