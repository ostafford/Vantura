<%= turbo_frame_tag "recurring_transaction_#{recurring.id}" do %>
  <tr class="hover:bg-neutral-50 dark:hover:bg-neutral-700 <%= recurring.is_active? ? '' : 'bg-neutral-100 dark:bg-neutral-700 opacity-60' %>">
    <td class="px-6 py-4 text-sm text-neutral-900 dark:text-neutral-300">
      <div class="flex items-center gap-2">
        <%= recurring.description %>
        <% if recurring.recurring_category.present? %>
          <%= recurring_category_badge(recurring) %>
        <% end %>
      </div>
      <div class="text-xs text-neutral-muted mt-1">
        Pattern: "<%= recurring.merchant_pattern %>" 
        <% if recurring.tolerance_type == "percentage" && recurring.tolerance_percentage.present? %>
          (±<%= recurring.tolerance_percentage %>%)
        <% else %>
          (±$<%= recurring.amount_tolerance %>)
        <% end %>
      </div>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium <%= amount_color_class(recurring.amount) %>">
      <%= recurring.amount < 0 ? "-" : "+" %>$<%= number_with_precision(recurring.amount.abs, precision: 2) %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-muted">
      <%= recurring.frequency.humanize %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-muted">
      <%= recurring.next_occurrence_date.strftime("%b %d, %Y") %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap">
      <% if recurring.is_active? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium badge-active">
          Active
        </span>
      <% else %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium badge-pending">
          Paused
        </span>
      <% end %>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
      <div class="flex gap-2 justify-end">
        <%= link_to edit_recurring_transaction_path(recurring, account_id: recurring.account_id),
            class: "inline-flex items-center px-3 py-1 surface-info text-info-dark rounded-lg surface-info-hover hover:shadow-md hover:scale-105 transition-all text-xs font-medium" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit
        <% end %>
        
        <%= button_to toggle_active_recurring_transaction_path(recurring), method: :post,
            class: "inline-flex items-center px-3 py-1 btn-warning hover:shadow-md hover:scale-105 transition-all text-xs font-medium" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <%= recurring.is_active? ? 'Pause' : 'Resume' %>
        <% end %>
        
        <%= button_to recurring_transaction_path(recurring), method: :delete,
            form: { data: { turbo_confirm: "Delete this recurring pattern? All future projected transactions will be removed." } },
            class: "inline-flex items-center px-3 py-1 btn-destructive hover:shadow-md hover:scale-105 transition-all text-xs font-medium" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete
        <% end %>
      </div>
    </td>
  </tr>
<% end %>

