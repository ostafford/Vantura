<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  
  <%= turbo_stream_from "user_#{current_user.id}_onboarding" %>

  <div class="max-w-2xl w-full space-y-8">
    <!-- Step Indicator -->
    <%= render "onboarding/step_indicator", current_step: 3, total_steps: 3 %>

    <!-- Main Card -->
    <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg p-8">
      <div class="text-center mb-8">
        <div class="flex justify-center items-center mb-4">
          <!-- Flowbite Spinner - Larger and Green -->
          <div role="status" class="mr-4">
            <svg aria-hidden="true" class="w-12 h-12 text-gray-200 animate-spin dark:text-gray-600 fill-green-600" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 28.9921 72.5987 10.6722 50 10.6722C27.4013 10.6722 9.08144 28.9921 9.08144 50.5908Z" fill="currentColor"/>
              <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill"/>
            </svg>
            <span class="sr-only">Loading...</span>
          </div>
          <!-- Flowbite Sync Icon -->
          <svg class="w-12 h-12 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 15v2a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-2m-8 1V4m0 12-4-4m4 4 4-4"/>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Setting Up Your Account
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          We're syncing your Up Bank data...
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-500 mt-1">
          This usually takes 10-30 seconds.
        </p>
      </div>

      <!-- Progress Bar -->
      <%= render "onboarding/progress_bar", percentage: 0, message: "Initializing..." %>

      <!-- Sync Steps -->
      <div id="sync-steps" class="mt-6 space-y-3">
        <!-- Next step loading indicator (hidden initially, shown when processing) -->
        <div id="next-step-loading" class="hidden flex items-center text-sm text-gray-500 dark:text-gray-400 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
          <svg class="animate-spin h-4 w-4 mr-2 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span>Preparing next step...</span>
        </div>
        <!-- Steps will be appended here via Turbo Stream -->
      </div>

      <!-- Completion Redirect (hidden initially) -->
      <div id="completion-redirect" class="hidden mt-8">
        <!-- Completion content will be replaced here via Turbo Stream -->
      </div>

      <!-- Tip Box -->
      <div class="mt-8 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-6">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-200 mb-1">
              Did you know?
            </h3>
            <p class="text-sm text-yellow-700 dark:text-yellow-300">
              You can set spending goals and track them in real-time!
            </p>
            <%= link_to "Learn more about Goals →", goals_path, 
                class: "text-sm text-yellow-800 dark:text-yellow-200 hover:underline mt-1 inline-block" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>