<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl w-full space-y-8">
    <!-- Step Indicator -->
    <%= render "onboarding/step_indicator", current_step: 2, total_steps: 3 %>

    <!-- Main Card -->
    <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg p-8">
      <div class="text-center mb-8">
        <div class="flex justify-center items-center mb-4">
          <!-- Bank Icon -->
          <svg class="w-16 h-16 text-blue-600 dark:text-blue-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12h20M2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6M2 12l10-8 10 8M7 12v6m10-6v6"/>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Connect Your Up Bank Account
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Automatically sync your transactions and get real-time insights.
        </p>
      </div>

      <!-- Info Box -->
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6 mb-6">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200 mb-2">
              Why do I need this?
            </h3>
            <ul class="text-sm text-blue-700 dark:text-blue-300 space-y-1">
              <li>• Auto-sync transactions</li>
              <li>• Real-time balance updates</li>
              <li>• Spending analytics</li>
              <li>• Category insights</li>
            </ul>
            <p class="text-sm text-blue-700 dark:text-blue-300 mt-2">
              Don't have Up Bank? You can still use Projects!
            </p>
          </div>
        </div>
      </div>

      <!-- Instructions -->
      <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-6 mb-6">
        <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-3 flex items-center">
          <svg class="w-5 h-5 mr-2 text-gray-600 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/>
          </svg>
          How to get your token:
        </h3>
        <ol class="text-sm text-gray-700 dark:text-gray-300 space-y-2 list-decimal list-inside">
          <li>Open the Up app on your phone</li>
          <li>Tap your profile → Settings</li>
          <li>Navigate to Data Sharing</li>
          <li>Tap Personal Access Token</li>
          <li>Generate a new token</li>
          <li>Copy and paste it below</li>
        </ol>
      </div>

      <!-- Flash Messages -->
      <%= render "shared/flash_messages" %>

      <!-- Form -->
      <%= form_with url: onboarding_create_connection_path, method: :post, 
          data: { controller: "token-validator" },
          class: "space-y-6" do |f| %>
        
        <div>
          <%= label_tag :token, "Personal Access Token", 
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="relative">
            <%= password_field_tag :token, nil,
                id: "token",
                autocomplete: "off",
                data: { 
                  token_validator_target: "input",
                  action: "input->token-validator#validate"
                },
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white sm:text-sm pr-10",
                placeholder: "up:yeah:xxxxxxxxxxxxxxxxxxx",
                required: true %>
            <button type="button" 
                    data-token-validator-target="toggle"
                    data-action="click->token-validator#toggleVisibility"
                    class="absolute inset-y-0 right-0 pr-3 flex items-center">
              <svg data-token-validator-target="eyeIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              <svg data-token-validator-target="eyeSlashIcon" class="h-5 w-5 text-gray-400 hover:text-gray-600 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.29 3.29m0 0L3 15.29m3.29-9.29L12 12m0 0l3.29 3.29M12 12l-3.29-3.29m0 0L12 8.71"/>
              </svg>
            </button>
          </div>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 flex items-center">
            <svg class="w-4 h-4 mr-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            Encrypted and stored securely
          </p>
          <div data-token-validator-target="feedback" class="mt-2 text-sm"></div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <button type="submit" 
                  data-token-validator-target="button"
                  class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            ✓ Validate & Connect
          </button>
          
          <%= link_to "I'll do this later",
              onboarding_skip_connection_path,
              data: { turbo_method: :post },
              class: "flex-1 text-center bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 font-medium py-3 px-4 rounded-md transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

