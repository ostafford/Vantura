<div class="text-center">
  <div class="text-6xl mb-4">✅</div>
  <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
    All Set!
  </h3>
  <p class="text-gray-600 dark:text-gray-400 mb-6">
    Your account is ready to go.
  </p>

  <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-6 mb-6">
    <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-4">Synced:</h4>
    <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2">
      <li>• <%= accounts_count %> accounts</li>
      <li>• <%= transactions_count %> transactions</li>
      <li>• <%= categories_count %> categories</li>
    </ul>
  </div>

  <div class="space-y-4">
    <%= link_to "Go to Dashboard", dashboard_path,
        class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-md transition-colors" %>
    
    <div data-controller="countdown"
         data-countdown-seconds-value="3"
         data-countdown-url-value="<%= dashboard_path %>">
      <p class="text-sm text-gray-500 dark:text-gray-500">
        Redirecting in <span data-countdown-target="number">3</span> seconds...
      </p>
    </div>
  </div>
</div>

<script>
  // Reveal the completion element when this partial loads
  const completionEl = document.getElementById('completion-redirect');
  if (completionEl) {
    completionEl.classList.remove('hidden');
  }
</script>