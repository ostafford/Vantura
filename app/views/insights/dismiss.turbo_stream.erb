<%# The card removal and section hiding is handled by the JavaScript controller %>
<%# We just need to update the header with dismissed insights %>

<% dismissed_types = Current.user.dismissed_insight_types || [] %>
<% if dismissed_types.present? %>
  <%= turbo_stream.update "dashboard-dismissed-insights-header" do %>
    <div data-controller="collapsible" 
         data-action="click@window->collapsible#closeIfOutside"
         data-collapsible-expanded-value="false"
         class="relative">
      <button type="button"
              data-action="click->collapsible#toggle"
              data-collapsible-target="toggle"
              class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium rounded-lg surface-card-light text-neutral-700 dark:text-neutral-300 border border-neutral-300 dark:border-neutral-600 surface-info-hover transition-colors"
              title="Dismissed insights"
              aria-expanded="false">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Dismissed Insights</span>
        <svg class="w-3 h-3 flex-shrink-0 transition-transform" 
             data-collapsible-target="icon"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      
      <div data-collapsible-target="content" 
           class="hidden absolute right-0 top-full mt-2 w-64 surface-card-medium rounded-lg shadow-deep border border-neutral-200 dark:border-neutral-700 p-3 z-50 space-y-1.5">
        <p class="text-xs font-semibold text-neutral-900 dark:text-white mb-2">Restore Dismissed Insights</p>
        <% 
          insight_type_labels = {
            "spending_velocity" => "Spending Velocity",
            "spending_warning" => "Spending Warning",
            "negative_savings_pattern" => "Overspending Pattern",
            "savings_opportunity" => "Savings Opportunity",
            "savings_investment_opportunity" => "Savings & Investment",
            "investment_suggestion" => "Investment Suggestion",
            "category_merchant" => "Category/Merchant",
            "day_of_week_pattern" => "Day-of-Week Pattern",
            "merchant_habit_pattern" => "Merchant Habit Pattern"
          }
        %>
        <% dismissed_types.each do |insight_type| %>
          <% label = insight_type_labels[insight_type] || insight_type.humanize %>
          <%= form_with url: insights_undismiss_path, method: :post, local: false, class: "block" do |f| %>
            <%= f.hidden_field :insight_type, value: insight_type %>
            <%= f.button type: :submit, 
                class: "w-full flex items-center gap-2 px-3 py-1.5 text-xs font-medium rounded-md surface-card-medium text-neutral-700 dark:text-neutral-300 border border-neutral-300 dark:border-neutral-600 surface-info-hover transition-colors",
                data: { 
                  controller: "insight-restore",
                  action: "click->insight-restore#restore"
                } do %>
              <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              <span class="truncate">Restore <%= label %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% else %>
  <%= turbo_stream.remove "dashboard-dismissed-insights-header" %>
<% end %>

