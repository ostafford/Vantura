<% content_for :title, "Edit Account - Vantura" %>

<div>
  <!-- Header -->
  <%= render 'shared/page_header_simple', title: "Edit Account", subtitle: "Update your account information" %>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Edit Form -->
    <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-primary-700 dark:to-primary-900 rounded-2xl shadow-deep overflow-hidden">
      <div class="bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700 px-6 py-5">
        <h2 class="text-2xl font-bold text-white">Account Information</h2>
        <p class="text-orange-100 text-sm mt-1">Update your account details</p>
      </div>

      <div class="p-6">
        <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-6" do |f| %>
          <!-- Error Messages -->
          <% if @user.errors.any? %>
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
              <h3 class="font-semibold text-red-900 dark:text-red-100 mb-2">
                <%= pluralize(@user.errors.count, "error") %> prevented this account from being saved:
              </h3>
              <ul class="text-sm text-red-800 dark:text-red-200 space-y-1 ml-5 list-disc">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <!-- Email Address Field -->
          <div>
            <label for="user_email_address" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Email Address
            </label>
            <%= f.email_field :email_address,
                class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:ring-2 focus:ring-primary-700 focus:border-transparent transition-all",
                placeholder: "you@example.com",
                autocomplete: "email" %>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
              We'll use this email address to send you important account notifications.
            </p>
          </div>

          <!-- Form Actions -->
          <div class="flex gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
            <%= f.submit "Update Account", 
                class: "flex-1 bg-gradient-to-r from-primary-700 to-primary-500 hover:from-primary-900 hover:to-primary-700 text-white px-6 py-3 rounded-xl hover:shadow-xl hover:scale-105 transition-all font-semibold shadow-lg text-center",
                data: { disable_with: "Updating..." } %>
            <%= link_to "Cancel", account_path, class: "px-6 py-3 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-300 dark:hover:bg-gray-600 hover:shadow-md hover:scale-105 transition-all font-semibold text-center" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

