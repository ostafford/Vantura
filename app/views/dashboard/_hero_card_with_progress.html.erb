<%# 
  Hero Card with Progress Component
  Used for displaying current balance with month-to-date progress tracking.
  Referenced by: DashboardBroadcastService for real-time updates.
  
  Required locals: account, current_date
%>
<%= render 'shared/bento_cards/hero_card',
    title: "Current Balance",
    subtitle: formatted_balance(account.current_balance),
    description: "Monitor your account balance in real-time with month-to-date progress tracking. Track your financial activity as you progress through the month with visual indicators and detailed breakdowns.",
    icon: 'wallet',
    size: 'col-span-1 md:col-span-2 row-span-2',
    color: 'primary',
    id: 'dashboard-current-balance-card' do %>
  <div class="flex items-center justify-between mb-3">
    <!-- Left: Full date -->
    <div class="text-left">
      <p class="text-sm text-coral-50">
        <%= day_name(current_date) %> <time datetime="<%= current_date.iso8601 %>"><%= current_date.strftime("%B %d, %Y") %></time>
      </p>
    </div>
    
    <!-- Right: Month progress -->
    <div class="text-right">
      <div class="flex items-center justify-end gap-2">
        <div class="relative h-2 w-24 overflow-hidden rounded-full bg-white/20" role="progressbar" aria-label="Month progress" aria-valuenow="<%= month_progress(current_date) %>" aria-valuemin="0" aria-valuemax="100">
          <div class="absolute inset-0 rounded-full bg-gradient-to-r from-white via-coral-100 to-coral-200 progress-bar-fill" data-progress-width="<%= month_progress(current_date) %>%" style="--progress-width: <%= month_progress(current_date) %>%"></div>
        </div>
        <span class="text-sm font-semibold text-coral-100 whitespace-nowrap"><%= month_progress(current_date) %>%</span>
      </div>
    </div>
  </div>
<% end %>

