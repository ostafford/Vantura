<%
  # Calculate all net cash flow data using helper
  card_data = net_cash_flow_data(
    income_total: income_total,
    expense_total: expense_total,
    expense_count: expense_count,
    income_count: income_count,
    current_date: current_date
  )
%>
<%= render 'shared/bento_cards/stat_card',
    id: 'dashboard-net-cash-flow-card',
    title: "Net Cash Flow",
    value: card_data[:formatted_net],
    subtitle: nil,
    detail: "#{card_data[:total_transactions]} transactions this month",
    icon: card_data[:icon],
    color: card_data[:color],
    size: 'bento-span-2 bento-row-span-1',
    link: transactions_path(year: current_date.year, month: current_date.month) do %>
  <div class="flex flex-col gap-2 mt-2">
    <div class="flex items-center justify-between text-sm">
      <span class="text-gray-600 dark:text-gray-400">Savings Rate:</span>
      <span class="font-semibold <%= card_data[:is_positive] ? 'text-green-600 dark:text-green-400' : 'text-expense-600 dark:text-expense-400' %>">
        <%= number_with_precision(card_data[:savings_rate], precision: 1) %>%
      </span>
    </div>
    <% if card_data[:avg_transaction] != 0 %>
      <div class="flex items-center justify-between text-sm">
        <span class="text-gray-600 dark:text-gray-400">Avg per Transaction:</span>
        <span class="font-semibold <%= card_data[:is_positive] ? 'text-green-600 dark:text-green-400' : 'text-expense-600 dark:text-expense-400' %>">
          $<%= number_with_precision(card_data[:avg_transaction], precision: 2) %>
        </span>
      </div>
    <% end %>
  </div>
<% end %>

