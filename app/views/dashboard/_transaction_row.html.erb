<tr class="hover:bg-neutral-50 dark:hover:bg-neutral-700/50 transition-colors" id="dashboard-transaction-<%= transaction.id %>-row">
  <td id="dashboard-transaction-<%= transaction.id %>-date" 
      class="px-6 py-4 whitespace-nowrap text-sm text-neutral-900 dark:text-neutral-300">
    <time datetime="<%= transaction.transaction_date.iso8601 %>">
      <%= transaction.transaction_date.strftime("%b %d, %Y") %>
    </time>
  </td>
  <td id="dashboard-transaction-<%= transaction.id %>-description" 
      class="px-6 py-4 text-sm text-neutral-900 dark:text-neutral-300">
    <%= transaction.description %>
  </td>
  <td id="dashboard-transaction-<%= transaction.id %>-category" 
      class="px-6 py-4 whitespace-nowrap text-sm text-neutral-500 dark:text-neutral-400">
    <%= transaction.category&.humanize || "Uncategorized" %>
  </td>
  <td id="dashboard-transaction-<%= transaction.id %>-status" 
      class="px-6 py-4 whitespace-nowrap">
    <div class="flex items-center gap-1.5">
      <%= transaction_status_badge(transaction) %>
      <%= transaction_recurring_badge(transaction) %>
    </div>
  </td>
  <td id="dashboard-transaction-<%= transaction.id %>-amount" 
      class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold">
    <%= formatted_transaction_amount(transaction) %>
  </td>
</tr>

