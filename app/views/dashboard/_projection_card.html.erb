<%
  # Calculate net cash flow for the month using helper method
  monthly_net = monthly_net_cash_flow(income_total, expense_total)
  
  # Calculate days remaining using helper method
  days_remaining = days_remaining_in_month(current_date)
%>
<%= render 'shared/bento_cards/projection_card',
    id: 'dashboard-projection-card',
    title: "End of Month Projection",
    value: "$#{number_with_precision(end_of_month_balance, precision: 2)}",
    balance: end_of_month_balance,
    change: monthly_net,
    size: 'bento-span-3 bento-row-span-1',
    days_remaining: days_remaining,
    upcoming_recurring_expenses: upcoming_recurring_expenses,
    upcoming_recurring_income: upcoming_recurring_income,
    current_balance: current_balance %>

