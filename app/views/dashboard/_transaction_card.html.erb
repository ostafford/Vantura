<%# 
  Mobile Transaction Card Component
  Used in dashboard for responsive transaction display on small screens
  
  Required local: transaction
%>

<div id="dashboard-transaction-<%= transaction.id %>-card" 
     class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg bg-white dark:bg-neutral-800 hover:shadow-md transition-shadow">
  
  <!-- Top Row: Description and Amount -->
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex-1 min-w-0">
      <p class="text-neutral-900 dark:text-white font-semibold truncate">
        <%= transaction.description %>
      </p>
      <time datetime="<%= transaction.transaction_date.iso8601 %>" 
            class="block mt-0.5 text-sm text-neutral-500 dark:text-neutral-400">
        <%= transaction.transaction_date.strftime("%b %d, %Y") %>
      </time>
    </div>
    
    <div class="flex-shrink-0 text-right">
      <p class="text-base font-semibold">
        <%= formatted_transaction_amount(transaction) %>
      </p>
    </div>
  </div>
  
  <!-- Bottom Row: Category and Status Badges -->
  <div class="flex flex-wrap items-center gap-2">
    <span id="dashboard-transaction-<%= transaction.id %>-category-badge" 
          class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium rounded-md bg-neutral-100 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-300">
      <%= transaction.category&.humanize || "Uncategorized" %>
    </span>
    
    <div class="flex items-center gap-1.5">
      <%= transaction_status_badge(transaction) %>
      <%= transaction_recurring_badge(transaction) %>
    </div>
  </div>
</div>

