<%# 
  Mobile Transaction Card Component
  Used in dashboard for responsive transaction display on small screens
  
  Required local: transaction
%>

<div id="dashboard-transaction-<%= transaction.id %>-card" 
     class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
  
  <!-- Top Row: Description and Amount -->
  <div class="flex justify-between items-start gap-4 mb-3">
    <div class="flex-1 min-w-0">
      <p class="font-semibold text-gray-900 dark:text-white truncate">
        <%= transaction.description %>
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
        <%= transaction.transaction_date.strftime("%b %d, %Y") %>
      </p>
    </div>
    
    <div class="text-right flex-shrink-0">
      <p class="font-semibold text-base">
        <%= formatted_transaction_amount(transaction) %>
      </p>
    </div>
  </div>
  
  <!-- Bottom Row: Category and Status Badges -->
  <div class="flex items-center gap-2 flex-wrap">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
      <%= transaction.category&.humanize || "Uncategorized" %>
    </span>
    
    <div class="flex items-center gap-1.5">
      <%= transaction_status_badge(transaction) %>
      <%= transaction_recurring_badge(transaction) %>
    </div>
  </div>
</div>

