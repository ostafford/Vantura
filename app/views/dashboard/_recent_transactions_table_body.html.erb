<% if recent_transactions.any? %>
  <% recent_transactions.each do |transaction| %>
    <%= render 'dashboard/transaction_row', transaction: transaction %>
  <% end %>
<% else %>
  <tr id="dashboard-recent-transactions-empty-row">
    <td colspan="5" 
        class="px-6 py-8 text-center text-neutral-500 dark:text-neutral-400"
        role="status"
        aria-live="polite">
      <p>No transactions for this week.</p>
    </td>
  </tr>
<% end %>

