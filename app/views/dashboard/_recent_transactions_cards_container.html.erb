<% if recent_transactions.any? %>
  <% recent_transactions.each do |transaction| %>
    <%= render 'dashboard/transaction_card', transaction: transaction %>
  <% end %>
<% else %>
  <div id="dashboard-recent-transactions-empty-state" 
       class="text-center py-8 text-neutral-500 dark:text-neutral-400"
       role="status"
       aria-live="polite">
    <p>No transactions for this week.</p>
  </div>
<% end %>

