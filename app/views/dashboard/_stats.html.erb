<% stats ||= @stats %>
<%# Fragment caching for dashboard stats - Reference: https://guides.rubyonrails.org/caching_with_rails.html#fragment-caching %>
<%# Use last_synced_at for cache key, or fallback to user's updated_at if never synced %>
<% cache_key = current_user.last_synced_at || current_user.updated_at %>
<% cache [ "dashboard-stats", current_user, cache_key ] do %>
<div id="dashboard-stats" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%= render "shared/stats_card",
      title: "Balance",
      value: number_to_currency(stats[:total_balance] / 100.0, unit: "$"),
      icon: "💰",
      change: nil %>

  <%= render "shared/stats_card",
      title: "Income",
      value: number_to_currency(stats[:income_this_month] / 100.0, unit: "$"),
      icon: "📈",
      change: nil %>

  <%= render "shared/stats_card",
      title: "Expenses",
      value: number_to_currency(stats[:expenses_this_month] / 100.0, unit: "$"),
      icon: "📉",
      change: nil %>

  <%= render "shared/stats_card",
      title: "Net",
      value: number_to_currency(stats[:net_this_month] / 100.0, unit: "$"),
      icon: "📊",
      change: stats[:net_this_month] >= 0 ? { positive: true, value: "+#{number_to_currency(stats[:net_this_month] / 100.0, unit: "$")}" } : { positive: false, value: number_to_currency(stats[:net_this_month] / 100.0, unit: "$") } %>
</div>
<% end %>

