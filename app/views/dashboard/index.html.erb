<div class="dashboard">
  <h1 class="text-3xl font-bold mb-6">Dashboard</h1>
  
  <div class="balance-section mb-8">
    <h2 class="text-2xl font-semibold mb-2">Total Balance</h2>
    <p class="balance text-4xl font-bold text-green-600">
      <%= number_to_currency(@balance / 100.0, unit: "$") %>
    </p>
  </div>

  <div class="accounts-section mb-8">
    <h2 class="text-2xl font-semibold mb-4">Accounts</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @accounts.each do |account| %>
        <div class="account-card border rounded-lg p-4 shadow">
          <h3 class="font-semibold text-lg"><%= account.display_name %></h3>
          <p class="text-gray-600"><%= account.account_type %></p>
          <p class="text-xl font-bold mt-2">
            <%= number_to_currency(account.balance_cents / 100.0, unit: "$") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="transactions-section">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-2xl font-semibold">Recent Transactions</h2>
      <%= form_with url: sync_dashboard_path, method: :post, class: "inline" do |f| %>
        <%= f.submit "Sync", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
    </div>
    
    <% if @recent_transactions.any? %>
      <table class="min-w-full bg-white border border-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @recent_transactions.each do |transaction| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= transaction.created_at.strftime("%Y-%m-%d") %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-900">
                <%= transaction.description || transaction.raw_text %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm <%= transaction.amount_cents < 0 ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(transaction.amount_cents.abs / 100.0, unit: "$") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                  <%= transaction.status == 'settled' ? 'bg-green-100 text-green-800' : 
                      transaction.status == 'held' ? 'bg-yellow-100 text-yellow-800' : 
                      'bg-gray-100 text-gray-800' %>">
                  <%= transaction.status.capitalize %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      
      <div class="mt-4">
        <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
      </div>
    <% else %>
      <p class="text-gray-500">No transactions found. Click "Sync" to fetch your transactions.</p>
    <% end %>
  </div>
</div>

