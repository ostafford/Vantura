<% content_for :title, "Dashboard - Vantura" %>
<% content_for :page_header_title, "Dashboard" %>
<% content_for :page_header_subtitle, "Your cash flow projection tool" %>
<% content_for :page_header_actions do %>
  <!-- Dismissed Insights (only show if there are dismissed insights) -->
  <div id="dashboard-dismissed-insights-header">
    <% dismissed_types = Current.user&.dismissed_insight_types || [] %>
    <% if dismissed_types.present? %>
      <div data-controller="collapsible" 
           data-action="click@window->collapsible#closeIfOutside"
           data-collapsible-expanded-value="false"
           class="relative">
      <button type="button"
              data-action="click->collapsible#toggle"
              data-collapsible-target="toggle"
              class="inline-flex items-center gap-2 px-3 py-1.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              title="Dismissed insights"
              aria-expanded="false">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Dismissed Insights</span>
        <svg class="w-3 h-3 flex-shrink-0 transition-transform" 
             data-collapsible-target="icon"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      
      <div data-collapsible-target="content" 
           class="absolute right-0 top-full z-50 hidden w-64 p-3 mt-2 space-y-1.5 border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 shadow-lg">
        <p class="text-xs font-semibold text-gray-900 dark:text-white mb-2">Restore Dismissed Insights</p>
        <% 
          insight_type_labels = {
            "spending_velocity" => "Spending Velocity",
            "spending_warning" => "Spending Warning",
            "negative_savings_pattern" => "Overspending Pattern",
            "savings_opportunity" => "Savings Opportunity",
            "savings_investment_opportunity" => "Savings & Investment",
            "investment_suggestion" => "Investment Suggestion",
            "category_merchant" => "Category/Merchant",
            "day_of_week_pattern" => "Day-of-Week Pattern",
            "merchant_habit_pattern" => "Merchant Habit Pattern",
            "budget_coach" => "Budget Coach"
          }
        %>
        <% dismissed_types.each do |insight_type| %>
          <% label = insight_type_labels[insight_type] || insight_type.humanize %>
          <%= form_with url: insights_undismiss_path, method: :post, local: false, class: "block" do |f| %>
            <%= f.hidden_field :insight_type, value: insight_type %>
            <%= f.button type: :submit, 
                class: "flex items-center w-full gap-2 px-3 py-1.5 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors",
                data: { 
                  controller: "insight-restore",
                  action: "click->insight-restore#restore"
                } do %>
              <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              <span class="truncate">Restore <%= label %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>
<% end %>

<main id="dashboard-main-container"
      data-controller="dashboard" 
      <% if @sync_result %>data-dashboard-sync-result-value='<%= @sync_result.to_json %>'<% end %>
      data-modal-type-value="transaction" 
      aria-label="Dashboard page">
  <!-- Sync Loading Indicator (hidden by default, shown via Turbo Stream) -->
  <div id="dashboard-sync-notification-container"></div>
  
  <%= content_wrapper class: "py-6" do %>
    <% if @account %>
      <!-- Key Insights Section -->
      <% if @key_insights.present? %>
        <section id="dashboard-financial-insights-section" class="mb-6" aria-label="Financial insights">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Financial Insights</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Actionable recommendations based on your spending patterns</p>
            </div>
            <%= link_to trends_path, 
                        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg border bg-primary-700/10 text-primary-700 border-primary-700/20 hover:bg-primary-700/20 hover:shadow-md hover:scale-105 transition-all dark:bg-primary-500/30 dark:text-primary-300 dark:border-primary-400/40 dark:hover:bg-primary-500/40" do %>
              View Full Analysis
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            <% end %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
            <% @key_insights.each do |insight| %>
              <%= render 'shared/insight_card', insight: insight %>
            <% end %>
          </div>
        </section>
      <% end %>
        <%
          # Get trajectory status data from helper method
          trajectory_data = trajectory_status_data
        %>

      <!-- Financial Overview Section -->
      <section id="dashboard-financial-overview-section" class="bento-grid mb-6" aria-label="Financial overview statistics">
        <!-- Current Balance Hero Card (1x2) - Compact with actionable data -->
        <%= render 'shared/bento_cards/hero_card',
            title: "Current Balance",
            subtitle: formatted_balance(@account.current_balance),
            description: nil,
            icon: 'wallet',
            size: 'bento-span-2 bento-row-span-3',
            color: 'primary',
            id: 'dashboard-current-balance-card',
            inline_subtitle: true do %>
          <div class="space-y-5">
            <% budget_amount_classes = trajectory_data[:net_positive] ? 'text-income-200' : 'text-expense-200' %>
            <% income_data = income_frequency_data %>
            <% next_income_label = income_data[:next_recurring_date]&.strftime("%b %d") %>
            <% last_income_label = income_data[:last_income_date]&.strftime("%b %d") %>
 
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
              <div class="rounded-xl bg-white/5 p-4 backdrop-blur-sm shadow-lg">
                <div class="flex items-center gap-2">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-amber-400/20 text-amber-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-white/70">Trajectory</span>
                </div>
                <div class="mt-3 inline-flex items-center gap-1.5 px-2 py-1 rounded-lg border <%= trajectory_data[:status_props][:container_classes] %> bg-white/5">
                  <span class="inline-block w-2 h-2 rounded-full <%= trajectory_data[:status_props][:indicator_classes] %>" aria-hidden="true"></span>
                  <span class="text-xs font-semibold leading-none text-white"><%= trajectory_data[:status_props][:label] %></span>
                </div>
                <% 
                  # Hybrid approach: Reference insight card when relevant and off-track
                  trajectory_message = if trajectory_data[:on_track] == :off_track && has_relevant_warning_insight?
                    insight_title = relevant_insight_title
                    "This aligns with your #{insight_title} insight above."
                  else
                    trajectory_data[:trend_copy]
                  end
                %>
                <p class="mt-3 text-xs leading-relaxed text-white/70"><%= trajectory_message %></p>
              </div>

              <% 
                daily_target_data = daily_spending_target
                daily_target_styling = daily_target_styling_data(daily_target_data)
              %>
              <% if daily_target_data && daily_target_styling %>
                <div class="rounded-xl bg-white/5 p-4 backdrop-blur-sm shadow-lg">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg <%= daily_target_styling[:target_icon_color] %>">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                      </svg>
                    </span>
                    <span class="text-xs font-semibold uppercase tracking-wide text-white/70">
                      <%= daily_target_data[:daily_target] < 0 ? "Today's Reduction Needed" : "Today's Spending Target" %>
                    </span>
                  </div>
                  <p class="mt-3 text-3xl font-bold <%= daily_target_styling[:target_text_color] %> text-right">
                    <%= daily_target_data[:daily_target] < 0 ? number_to_currency(daily_target_data[:daily_target].abs) : number_to_currency(daily_target_data[:daily_target]) %>
                  </p>
                  <p class="mt-2 text-xs text-white/60"><%= daily_target_data[:context] %></p>
                  <% 
                    # Link to insight card when negative and insight exists
                    if daily_target_data[:daily_target] < 0 && has_relevant_warning_insight?
                      insight_title = relevant_insight_title
                  %>
                    <p class="mt-1.5 text-xs text-white/50 italic">This aligns with your <%= insight_title %> insight above.</p>
                  <% end %>
                </div>
              <% end %>

              <div class="rounded-xl bg-white/5 p-4 backdrop-blur-sm shadow-lg">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-orange-400/20 text-orange-100">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </span>
                    <span class="text-xs font-semibold uppercase tracking-wide text-white/70">Month Progress</span>
                  </div>
                  <span class="text-sm font-semibold text-white"><%= month_progress(current_date) %>%</span>
                </div>
                <div class="mt-3 flex items-center gap-3">
                  <div class="relative h-2 w-full rounded-full bg-white/15" role="progressbar" aria-label="Calendar month progress" aria-valuenow="<%= month_progress(current_date) %>" aria-valuemin="0" aria-valuemax="100">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-r from-orange-200/70 via-orange-100 to-white" style="width: <%= month_progress(current_date) %>%"></div>
                  </div>
                </div>
                <p class="mt-2 text-xs text-white/60">Day <%= current_date.day %> of <%= current_date.end_of_month.day %> in <%= current_date.strftime("%B") %>.</p>
              </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
              <% break_even_data = days_until_break_even %>
              <% break_even_positive = break_even_data[:source] == :already_positive %>
              <% break_even_icon_color = break_even_positive ? 'bg-emerald-400/20 text-emerald-200' : 'bg-amber-400/20 text-amber-200' %>
              <div class="rounded-xl bg-white/5 p-4 backdrop-blur-sm shadow-lg">
                <div class="flex items-center gap-2">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg <%= break_even_icon_color %>">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-white/70">Days Until Break-Even</span>
                </div>
                <% if break_even_data[:days].present? && break_even_data[:days] > 0 %>
                  <p class="mt-3 text-2xl font-semibold text-amber-200 text-right">
                    ~<%= break_even_data[:days] %> <%= break_even_data[:days] == 1 ? 'day' : 'days' %>
                  </p>
                  <% if break_even_data[:target_date] %>
                    <p class="mt-1 text-xs text-white/70 text-right">
                      <%= break_even_data[:target_date].strftime('%b %d') %>
                    </p>
                  <% end %>
                  <% if break_even_data[:next_income_payment] && break_even_data[:next_income_date] %>
                    <p class="mt-2 text-xs text-white/60">
                      After your <%= number_to_currency(break_even_data[:next_income_payment]) %> payment on <%= break_even_data[:next_income_date].strftime('%b %d') %>
                    </p>
                  <% else %>
                    <p class="mt-2 text-xs text-white/60">
                      <% if break_even_data[:source] == :recurring %>
                        Based on your recurring income pattern
                      <% elsif break_even_data[:source] == :historical %>
                        Based on your past 6 months average
                      <% else %>
                        Following your daily spending target
                      <% end %>
                    </p>
                  <% end %>
                <% elsif break_even_positive %>
                  <p class="mt-3 text-2xl font-semibold text-emerald-200 text-right">
                    Already ahead
                  </p>
                  <p class="mt-2 text-xs text-white/60">
                    You're at or ahead of your month-start balance
                  </p>
                <% else %>
                  <p class="mt-3 text-2xl font-semibold text-rose-200 text-right">
                    Reduce spending
                  </p>
                  <p class="mt-2 text-xs text-white/60">
                    Adjust your spending to reach break-even
                  </p>
                <% end %>
              </div>

              <div class="rounded-xl bg-white/5 p-4 backdrop-blur-sm shadow-lg">
                <div class="flex items-center gap-2">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-400/20 text-indigo-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.343 6.343L4.222 4.222m15.556 0l-2.121 2.121M4 12H2m20 0h-2m-1.879 7.778l-2.121-2.121M6.343 17.657l-2.121 2.121" />
                    </svg>
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-white/70">Income Activity</span>
                </div>
                <dl class="mt-3 space-y-3 text-xs text-white/70">
                  <div class="flex items-center justify-between">
                    <dt class="flex items-center gap-2">
                      <span>Avg Daily</span>
                      <% income_data = average_daily_income %>
                      <% if income_data[:has_recurring] && income_data[:has_historical] %>
                        <div class="flex items-center gap-1" 
                             data-controller="income-view-toggle"
                             data-income-view-toggle-has-recurring-value="<%= income_data[:has_recurring] %>"
                             data-income-view-toggle-has-historical-value="<%= income_data[:has_historical] %>"
                             data-income-view-toggle-recurring-value-value="<%= income_data[:recurring_daily_rate] || 0 %>"
                             data-income-view-toggle-historical-value-value="<%= income_data[:historical_daily_rate] || 0 %>"
                             data-income-view-toggle-current-month-value-value="<%= income_data[:current_month_actual] %>">
                          <button type="button"
                                  data-income-view-toggle-target="recurringButton"
                                  data-action="click->income-view-toggle#switchToRecurring"
                                  class="px-1.5 py-0.5 text-[10px] font-medium rounded transition-colors text-white/60 hover:text-white/80"
                                  id="dashboard-income-view-recurring-button"
                                  aria-label="Show recurring income rate">
                            Recurring
                          </button>
                          <button type="button"
                                  data-income-view-toggle-target="historicalButton"
                                  data-action="click->income-view-toggle#switchToHistorical"
                                  class="px-1.5 py-0.5 text-[10px] font-medium rounded transition-colors text-white/60 hover:text-white/80"
                                  id="dashboard-income-view-historical-button"
                                  aria-label="Show historical income rate">
                            Historical
                          </button>
                        </div>
                      <% end %>
                    </dt>
                    <dd class="text-sm font-semibold text-income-200 text-right">
                      <% if income_data[:has_recurring] && income_data[:has_historical] %>
                        <!-- Toggle view - controlled by Stimulus -->
                        <div class="text-right">
                          <span data-income-view-toggle-target="valueDisplay">
                            $<%= number_with_precision(
                              income_data[:has_recurring] ? income_data[:recurring_daily_rate] : income_data[:historical_daily_rate], 
                              precision: 2
                            ) %>
                          </span>
                          <span class="block text-xs font-normal text-white/50 mt-0.5" 
                                data-income-view-toggle-target="labelDisplay">
                            <%= income_data[:has_recurring] ? "from recurring income" : "estimated from past 6 months" %>
                          </span>
                        </div>
                      <% elsif income_data[:has_recurring] %>
                        <!-- Only recurring available -->
                        <div class="text-right">
                          $<%= number_with_precision(income_data[:recurring_daily_rate], precision: 2) %>
                          <span class="block text-xs font-normal text-white/50 mt-0.5">from recurring income</span>
                        </div>
                      <% elsif income_data[:has_historical] %>
                        <!-- Only historical available -->
                        <div class="text-right">
                          $<%= number_with_precision(income_data[:historical_daily_rate], precision: 2) %>
                          <span class="block text-xs font-normal text-white/50 mt-0.5">estimated from past 6 months</span>
                        </div>
                      <% else %>
                        <!-- Fallback to current month (should rarely happen) -->
                        <div class="text-right">
                          $<%= number_with_precision(income_data[:current_month_actual], precision: 2) %>
                          <span class="block text-xs font-normal text-white/50 mt-0.5">this month so far</span>
                        </div>
                      <% end %>
                    </dd>
                  </div>
                  <% if next_income_label || last_income_label %>
                    <div class="flex items-center justify-between">
                      <dt><%= next_income_label ? 'Next Income' : 'Last Income' %></dt>
                      <dd class="text-xs font-semibold text-white"><%= next_income_label || last_income_label %></dd>
                    </div>
                  <% end %>
                  <% if income_data[:count_this_month].to_i.positive? %>
                    <div class="flex items-center justify-between">
                      <dt>This Month</dt>
                      <dd class="text-xs font-semibold text-white"><%= pluralize(income_data[:count_this_month], 'deposit') %></dd>
                    </div>
                  <% end %>
                </dl>
                <% 
                  # Add connection to spending target when both exist
                  if daily_target_data && daily_target_data[:daily_target] > 0
                    target_amount = number_to_currency(daily_target_data[:daily_target])
                    current_income_display = if income_data[:has_recurring] && income_data[:has_historical]
                      # For toggle view, show the currently selected value
                      income_data[:has_recurring] ? income_data[:recurring_daily_rate] : income_data[:historical_daily_rate]
                    elsif income_data[:has_recurring]
                      income_data[:recurring_daily_rate]
                    elsif income_data[:has_historical]
                      income_data[:historical_daily_rate]
                    else
                      income_data[:current_month_actual]
                    end
                %>
                  <p class="mt-3 pt-3 border-t border-white/10 text-xs text-white/60">
                    To stay on track, spend below <span class="font-semibold text-white/80"><%= target_amount %></span> today.
                  </p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
        
        <!-- Combined Cash Flow Card (2x1) - Income, Expenses, Net with expandable merchants/categories -->
        <%= render partial: 'shared/bento_cards/cash_flow_card',
            locals: {
              income_total: income_total,
              expense_total: expense_total,
              income_count: income_count,
              expense_count: expense_count,
              projected_income_total: projected_income_total,
              projected_expense_total: projected_expense_total,
              projected_income_count: projected_income_count,
              projected_expense_count: projected_expense_count,
              current_date: current_date,
              top_income_merchants: top_income_merchants,
              top_expense_merchants: top_expense_merchants,
              top_income_categories: top_income_categories,
              top_expense_categories: top_expense_categories,
              account: @account
            } %>

        <!-- End of Month Projection (2x1) - Using Reusable Partial -->
        <%= render 'dashboard/projection_card',
            income_total: income_total,
            expense_total: expense_total,
            end_of_month_balance: end_of_month_balance,
            current_date: current_date,
            upcoming_recurring_expenses: upcoming_recurring_expenses,
            upcoming_recurring_income: upcoming_recurring_income,
            current_balance: @account.current_balance,
            upcoming_recurring_total: upcoming_recurring_total 
            %>

      </section>

      <!-- Recent Transactions -->
      <section id="dashboard-recent-transactions-section" class="rounded-2xl bg-gradient-to-br from-neutral-100 to-white shadow-deep dark:from-gray-800 dark:to-gray-900" aria-label="Recent transactions">
        <div class="flex items-center justify-between px-6 py-5 border-b bg-gray-50 dark:bg-gray-800 border-gray-200 dark:border-gray-700">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Recent Transactions</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Your latest activity this month</p>
          </div>
          <%= link_to transactions_path(year: current_date.year, month: current_date.month), 
                      class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg border bg-primary-700/10 text-primary-700 border-primary-700/20 hover:bg-primary-700/20 hover:shadow-md hover:scale-105 transition-all dark:bg-primary-500/30 dark:text-primary-300 dark:border-primary-400/40 dark:hover:bg-primary-500/40" do %>
            View All
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>

        <!-- Mobile Card View (< 1024px) -->
        <div id="dashboard-recent-transactions-cards-container" class="lg:hidden p-4 space-y-3">
          <%= render 'dashboard/recent_transactions_cards_container', recent_transactions: recent_transactions %>
        </div>

        <!-- Desktop Table View (>= 1024px) -->
        <div id="dashboard-recent-transactions-table-container" class="hidden lg:block overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700" aria-label="Recent transactions for current week">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Date</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Description</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Category</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Amount</th>
              </tr>
            </thead>
            <tbody id="dashboard-recent-transactions-table-body" class="bg-white divide-y divide-gray-200 dark:bg-gray-800 dark:divide-gray-700">
              <%= render 'dashboard/recent_transactions_table_body', recent_transactions: recent_transactions %>
            </tbody>
          </table>
        </div>
          </section>

    <% else %>
      <!-- No Account Found - Guide User to Settings -->
      <div class="bg-gradient-to-br from-cream-100 via-white to-cream-100 rounded-2xl shadow-deep p-12 text-center dark:from-gray-800 dark:via-success-700 dark:to-gray-800">
          <div class="max-w-md mx-auto">
          <div class="inline-flex items-center justify-center w-16 h-16 mb-4 rounded-full bg-primary-700/10 dark:bg-primary-700/20">
            <svg class="w-8 h-8 text-primary-700 dark:text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Welcome to Vantura!</h2>
          
          <% if Current.user.up_bank_token.present? %>
            <!-- Token is configured but sync hasn't happened yet -->
            <p class="text-gray-600 dark:text-gray-400 mb-6">Your Up Bank token is configured. Click the button below to sync your data!</p>
            <%= button_to sync_path, method: :post, class: "inline-flex items-center px-6 py-3 font-semibold text-white rounded-xl bg-gradient-to-r from-primary to-primary-light shadow-lg hover:from-primary-dark hover:to-primary hover:shadow-xl hover:scale-105 transition-all", data: { disable_with: "Syncing your data..." } do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Sync Up Bank Data
            <% end %>
          <% else %>
            <!-- No token configured - direct to settings -->
            <p class="text-gray-600 dark:text-gray-400 mb-6">Let's get you set up! Click below to configure your Up Bank token.</p>
            <%= link_to settings_path, class: "inline-flex items-center px-6 py-3 font-semibold text-white rounded-xl bg-gradient-to-r from-primary to-primary-light shadow-lg hover:from-primary-dark hover:to-primary hover:shadow-xl hover:scale-105 transition-all" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Go to Settings
            <% end %>
            
            <div class="p-4 mt-6 border rounded-lg bg-blue-50 border-blue-200 dark:bg-blue-900/20 dark:border-blue-800">
              <p class="text-sm text-blue-800 dark:text-blue-200">
                <strong>What you'll need:</strong> Your Personal Access Token from 
                <a href="https://developer.up.com.au/" target="_blank" class="underline hover:text-blue-600">developer.up.com.au</a>
              </p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render 'shared/transaction_drawer', default_transaction_date: Date.today %>
</main>

