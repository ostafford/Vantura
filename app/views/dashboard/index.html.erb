<% content_for :title, "Dashboard - Vantura" %>
<% content_for :page_header_title, "Dashboard" %>
<% content_for :page_header_subtitle, "Your cash flow projection tool" %>
<% content_for :page_header_actions do %>
  <!-- Dismissed Insights (only show if there are dismissed insights) -->
  <div id="dashboard-dismissed-insights-header">
    <% dismissed_types = Current.user&.dismissed_insight_types || [] %>
    <% if dismissed_types.present? %>
      <div data-controller="collapsible" 
           data-action="click@window->collapsible#closeIfOutside"
           data-collapsible-expanded-value="false"
           class="relative">
      <button type="button"
              data-action="click->collapsible#toggle"
              data-collapsible-target="toggle"
              class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              title="Dismissed insights"
              aria-expanded="false">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Dismissed Insights</span>
        <svg class="w-3 h-3 flex-shrink-0 transition-transform" 
             data-collapsible-target="icon"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      
      <div data-collapsible-target="content" 
           class="hidden absolute right-0 top-full mt-2 w-64 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-3 z-50 space-y-1.5">
        <p class="text-xs font-semibold text-gray-900 dark:text-white mb-2">Restore Dismissed Insights</p>
        <% 
          insight_type_labels = {
            "spending_velocity" => "Spending Velocity",
            "spending_warning" => "Spending Warning",
            "negative_savings_pattern" => "Overspending Pattern",
            "savings_opportunity" => "Savings Opportunity",
            "savings_investment_opportunity" => "Savings & Investment",
            "investment_suggestion" => "Investment Suggestion",
            "category_merchant" => "Category/Merchant",
            "day_of_week_pattern" => "Day-of-Week Pattern",
            "merchant_habit_pattern" => "Merchant Habit Pattern",
            "budget_coach" => "Budget Coach"
          }
        %>
        <% dismissed_types.each do |insight_type| %>
          <% label = insight_type_labels[insight_type] || insight_type.humanize %>
          <%= form_with url: insights_undismiss_path, method: :post, local: false, class: "block" do |f| %>
            <%= f.hidden_field :insight_type, value: insight_type %>
            <%= f.button type: :submit, 
                class: "w-full flex items-center gap-2 px-3 py-1.5 text-xs font-medium rounded-md bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors",
                data: { 
                  controller: "insight-restore",
                  action: "click->insight-restore#restore"
                } do %>
              <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              <span class="truncate">Restore <%= label %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>
<% end %>

<main id="dashboard-main-container"
      data-controller="dashboard" 
      <% if @sync_result %>data-dashboard-sync-result-value='<%= @sync_result.to_json %>'<% end %>
      data-modal-type-value="transaction" 
      aria-label="Dashboard page">
  <!-- Sync Loading Indicator (hidden by default, shown via Turbo Stream) -->
  <div id="dashboard-sync-notification-container"></div>
  
  <%= content_wrapper class: "py-6" do %>
    <% if @account %>
      <!-- Key Insights Section -->
      <% if @key_insights.present? %>
        <section id="dashboard-financial-insights-section" class="mb-6" aria-label="Financial insights">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Financial Insights</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Actionable recommendations based on your spending patterns</p>
            </div>
            <%= link_to trends_path, 
                        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg border bg-primary-700/10 text-primary-700 border-primary-700/20 hover:bg-primary-700/20 hover:shadow-md hover:scale-105 transition-all dark:bg-primary-500/30 dark:text-primary-300 dark:border-primary-400/40 dark:hover:bg-primary-500/40" do %>
              View Full Analysis
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            <% end %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
            <% @key_insights.each do |insight| %>
              <%= render 'shared/insight_card', insight: insight %>
            <% end %>
          </div>
        </section>
      <% end %>

      <!-- Financial Overview Section -->
      <section id="dashboard-financial-overview-section" class="bento-grid mb-6" aria-label="Financial overview statistics">
        <!-- Combined Cash Flow Card (2x1) - Income, Expenses, Net with expandable merchants/categories -->
        <%= render partial: 'shared/bento_cards/cash_flow_card',
            locals: {
              income_total: income_total,
              expense_total: expense_total,
              income_count: income_count,
              expense_count: expense_count,
              projected_income_total: projected_income_total,
              projected_expense_total: projected_expense_total,
              projected_income_count: projected_income_count,
              projected_expense_count: projected_expense_count,
              current_date: current_date,
              top_income_merchants: top_income_merchants,
              top_expense_merchants: top_expense_merchants,
              top_income_categories: top_income_categories,
              top_expense_categories: top_expense_categories,
              account: @account
            } %>
        
        <!-- Current Balance Hero Card (1x2) - Compact with actionable data -->
        <%= render 'shared/bento_cards/hero_card',
            title: "Current Balance",
            subtitle: formatted_balance(@account.current_balance),
            description: nil,
            icon: 'wallet',
            size: 'bento-span-1 bento-row-span-2',
            color: 'primary',
            id: 'dashboard-current-balance-card' do %>
          <div class="space-y-3">
            <!-- Date and Month Progress -->
            <div class="flex items-center justify-between">
              <div class="text-left">
                <p class="text-orange-50 text-sm">
                  <%= day_name(current_date) %> <time datetime="<%= current_date.iso8601 %>"><%= current_date.strftime("%B %d, %Y") %></time>
                </p>
              </div>
              
              <div class="text-right">
                <div class="flex items-center justify-end gap-2">
                  <div class="h-2 w-20 bg-white/20 rounded-full overflow-hidden relative" role="progressbar" aria-label="Month progress" aria-valuenow="<%= month_progress(current_date) %>" aria-valuemin="0" aria-valuemax="100">
                    <div class="absolute inset-0 bg-gradient-to-r from-white via-orange-100 to-orange-200 rounded-full" style="width: <%= month_progress(current_date) %>%"></div>
                  </div>
                  <span class="text-xs text-orange-100 font-semibold whitespace-nowrap"><%= month_progress(current_date) %>%</span>
                </div>
              </div>
            </div>

            <!-- Balance Change Since Month Start -->
            <% balance_change = balance_change_since_month_start %>
            <div class="pt-2 border-t border-white/20">
              <div class="flex items-center justify-between">
                <span class="text-orange-50 text-xs">Change:</span>
                <span class="text-sm font-semibold <%= balance_change >= 0 ? 'text-green-200' : 'text-red-200' %>">
                  <%= balance_change >= 0 ? '+' : '' %>$<%= number_with_precision(balance_change, precision: 2) %>
                </span>
              </div>
              <p class="text-orange-100/70 text-xs mt-0.5">since <%= current_date.beginning_of_month.strftime("%b %d") %></p>
            </div>

            <!-- Average Daily Spending -->
            <div class="flex items-center justify-between">
              <span class="text-orange-50 text-xs">Avg Daily:</span>
              <span class="text-sm font-semibold text-orange-100">
                $<%= number_with_precision(average_daily_spending, precision: 2) %>
              </span>
            </div>

            <!-- On Track Indicator -->
            <% 
              on_track = on_track_status
              status_colors = {
                on_track: 'bg-green-500/30 text-green-200 border-green-400/50',
                caution: 'bg-yellow-500/30 text-yellow-200 border-yellow-400/50',
                off_track: 'bg-red-500/30 text-red-200 border-red-400/50'
              }
              status_labels = {
                on_track: 'On Track',
                caution: 'Caution',
                off_track: 'Off Track'
              }
              status_color = status_colors[on_track] || status_colors[:on_track]
              status_label = status_labels[on_track] || status_labels[:on_track]
            %>
            <div class="pt-2 border-t border-white/20">
              <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-lg border <%= status_color %>">
                <div class="w-2 h-2 rounded-full <%= on_track == :on_track ? 'bg-green-300' : on_track == :caution ? 'bg-yellow-300' : 'bg-red-300' %>"></div>
                <span class="text-xs font-medium"><%= status_label %></span>
              </div>
            </div>

            <!-- Income Information -->
            <% income_data = income_frequency_data %>
            <div class="pt-2 border-t border-white/20">
              <% if income_data[:next_recurring_date] %>
                <!-- Show next recurring income if available -->
                <div class="flex items-center justify-between">
                  <span class="text-orange-50 text-xs">Next Income:</span>
                  <span class="text-xs font-semibold text-orange-100">
                    <%= income_data[:next_recurring_date].strftime("%b %d") %>
                  </span>
                </div>
              <% elsif income_data[:last_income_date] %>
                <!-- Show last income date if no recurring -->
                <div class="flex items-center justify-between">
                  <span class="text-orange-50 text-xs">Last Income:</span>
                  <span class="text-xs font-semibold text-orange-100">
                    <%= income_data[:last_income_date].strftime("%b %d") %>
                  </span>
                </div>
              <% end %>
              <% if income_data[:count_this_month] && income_data[:count_this_month] > 0 %>
                <p class="text-orange-100/70 text-xs mt-0.5">
                  <%= income_data[:count_this_month] %> <%= income_data[:count_this_month] == 1 ? 'time' : 'times' %> this month
                </p>
              <% end %>
            </div>
          </div>
        <% end %>


        

        <!-- End of Month Projection (2x1) - Using Reusable Partial -->
        <%= render 'dashboard/projection_card',
            income_total: income_total,
            expense_total: expense_total,
            end_of_month_balance: end_of_month_balance,
            current_date: current_date,
            upcoming_recurring_expenses: upcoming_recurring_expenses,
            upcoming_recurring_income: upcoming_recurring_income,
            upcoming_recurring_total: upcoming_recurring_total %>
      </section>

      <!-- Recent Transactions -->
      <section id="dashboard-recent-transactions-section" class="rounded-2xl bg-gradient-to-br from-neutral-100 to-white shadow-deep dark:from-gray-800 dark:to-gray-900" aria-label="Recent transactions">
        <div class="flex items-center justify-between px-6 py-5 border-b bg-gray-50 dark:bg-gray-800 border-gray-200 dark:border-gray-700">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Recent Transactions</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Your latest activity this month</p>
          </div>
          <%= link_to transactions_path(year: current_date.year, month: current_date.month), 
                      class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg border bg-primary-700/10 text-primary-700 border-primary-700/20 hover:bg-primary-700/20 hover:shadow-md hover:scale-105 transition-all dark:bg-primary-500/30 dark:text-primary-300 dark:border-primary-400/40 dark:hover:bg-primary-500/40" do %>
            View All
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>

            <div id="dashboard-recent-transactions-table-container" class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700" aria-label="Recent transactions for current week">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Date</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Description</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Category</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Status</th>
                    <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Amount</th>
                  </tr>
                </thead>
                <tbody id="dashboard-recent-transactions-table-body" class="bg-white divide-y divide-gray-200 dark:bg-gray-800 dark:divide-gray-700">
                  <%= render 'dashboard/recent_transactions_table_body', recent_transactions: recent_transactions %>
                </tbody>
              </table>
            </div>
          </section>

    <% else %>
      <!-- No Account Found - Guide User to Settings -->
      <div class="bg-gradient-to-br from-cream-100 via-white to-cream-100 rounded-2xl shadow-deep p-12 text-center dark:from-gray-800 dark:via-success-700 dark:to-gray-800">
          <div class="max-w-md mx-auto">
          <div class="inline-flex items-center justify-center w-16 h-16 mb-4 rounded-full bg-primary-700/10 dark:bg-primary-700/20">
            <svg class="w-8 h-8 text-primary-700 dark:text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Welcome to Vantura!</h2>
          
          <% if Current.user.up_bank_token.present? %>
            <!-- Token is configured but sync hasn't happened yet -->
            <p class="text-gray-600 dark:text-gray-400 mb-6">Your Up Bank token is configured. Click the button below to sync your data!</p>
            <%= button_to sync_path, method: :post, class: "inline-flex items-center px-6 py-3 font-semibold text-white rounded-xl bg-gradient-to-r from-primary to-primary-light shadow-lg hover:from-primary-dark hover:to-primary hover:shadow-xl hover:scale-105 transition-all", data: { disable_with: "Syncing your data..." } do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Sync Up Bank Data
            <% end %>
          <% else %>
            <!-- No token configured - direct to settings -->
            <p class="text-gray-600 dark:text-gray-400 mb-6">Let's get you set up! Click below to configure your Up Bank token.</p>
            <%= link_to settings_path, class: "inline-flex items-center px-6 py-3 font-semibold text-white rounded-xl bg-gradient-to-r from-primary to-primary-light shadow-lg hover:from-primary-dark hover:to-primary hover:shadow-xl hover:scale-105 transition-all" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Go to Settings
            <% end %>
            
            <div class="p-4 mt-6 border rounded-lg bg-blue-50 border-blue-200 dark:bg-blue-900/20 dark:border-blue-800">
              <p class="text-sm text-blue-800 dark:text-blue-200">
                <strong>What you'll need:</strong> Your Personal Access Token from 
                <a href="https://developer.up.com.au/" target="_blank" class="underline hover:text-blue-600">developer.up.com.au</a>
              </p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render 'shared/transaction_drawer', default_transaction_date: Date.today %>
</main>
