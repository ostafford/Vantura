<div class="dashboard" data-controller="dashboard">
  <%= turbo_stream_from "user_#{current_user.id}_dashboard" %>
  <%= turbo_stream_from "user_#{current_user.id}_transactions" %>

  <!-- Insights Banner (dismissible) -->
  <% if @show_insights %>
    <%# Simple insight message - can be enhanced with actual analytics %>
    <%= render "dashboard/insights_banner", 
        insight_message: "Welcome to Vantura! Connect your Up Bank account to start tracking your finances." %>
  <% end %>

  <!-- Stats Cards -->
  <div id="dashboard-stats">
    <%= render "dashboard/stats" %>
  </div>

  <!-- Charts Section -->
  <%= render "dashboard/charts" %>

  <!-- Recent Transactions -->
  <div class="mb-6">
    <%= render "dashboard/recent_transactions", recent_transactions: @recent_transactions %>
  </div>

  <!-- Upcoming Planned Transactions -->
  <div class="mb-6">
    <%= render "dashboard/upcoming_expenses", upcoming_planned: @upcoming_planned %>
  </div>

  <!-- Active Projects -->
  <% if @active_projects.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Active Projects</h2>
        <%= link_to "View All Projects →", projects_path,
            class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" %>
      </div>
      <div class="space-y-3">
        <% @active_projects.each do |project| %>
          <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <h3 class="font-medium text-gray-900 dark:text-white"><%= project.name %></h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">
              <%= project.description.presence || "No description" %>
            </p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

