<!DOCTYPE html>
<html class="<%= current_user&.dark_mode ? 'dark' : '' %>" data-controller="dark-mode">
  <head>
    <title><%= content_for(:title) || "Vantura" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Initialize dark mode before page render to avoid FOUC (Flash of Unstyled Content) %>
    <script>
      (function() {
        const userPreference = <%= user_signed_in? && current_user.dark_mode ? 'true' : 'null' %>;
        // Migrate old 'theme' key to 'color-theme' for Flowbite consistency
        const oldTheme = localStorage.getItem('theme');
        if (oldTheme && !localStorage.getItem('color-theme')) {
          localStorage.setItem('color-theme', oldTheme);
          localStorage.removeItem('theme');
        }
        const savedTheme = localStorage.getItem('color-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        // Priority: user database preference > localStorage > system preference
        if (userPreference === true || (userPreference === null && (savedTheme === 'dark' || (!savedTheme && prefersDark)))) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <%# Set current user ID for JavaScript controllers (e.g., dark mode database sync) %>
    <% if user_signed_in? %>
      <script>
        window.currentUserId = <%= current_user.id %>;
      </script>
    <% end %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900">
    <%# Toast notification container for JavaScript-triggered toasts %>
    <div id="toast-container" class="fixed top-20 right-4 z-50 space-y-2" aria-live="polite" aria-atomic="true"></div>

    <% if user_signed_in? %>
      <%# Hide sidebar/topbar for onboarding pages %>
      <% unless request.path.start_with?('/onboarding') %>
        <%= render 'layouts/sidebar' %>
        <%= render 'layouts/topbar' %>

        <div class="p-4 mt-16 sm:ml-64">
          <div class="p-4">
            <%= render 'shared/flash_messages' %>
            <%= yield %>
          </div>
        </div>
      <% else %>
        <%= render 'shared/flash_messages' %>
        <%= yield %>
      <% end %>
    <% else %>
      <%# Don't wrap sign up/sign in pages - they handle their own centering %>
      <% if request.path.start_with?('/users/sign_up') || request.path.start_with?('/users/sign_in') %>
        <%= render 'shared/flash_messages' %>
        <%= yield %>
      <% else %>
        <main class="container mx-auto mt-28 px-5 flex">
          <%= render 'shared/flash_messages' %>
          <%= yield %>
        </main>
      <% end %>
    <% end %>

    <%# Toast event listener - handles toast:show events from JavaScript %>
    <script>
      (function() {
        const toastContainer = document.getElementById('toast-container');
        if (!toastContainer) return;

        window.addEventListener('toast:show', function(event) {
          const { message, type } = event.detail;
          if (!message) return;

          // Escape HTML to prevent XSS
          const escapeHtml = (text) => {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
          };

          const escapedMessage = escapeHtml(message);

          // Create toast element
          const toastId = 'toast-' + Date.now();
          const toastTypes = {
            'success': {
              textClass: 'text-green-800',
              bgClass: 'bg-green-50',
              darkTextClass: 'dark:text-green-400',
              darkBgClass: 'dark:bg-gray-800',
              buttonBgClass: 'bg-green-50',
              buttonTextClass: 'text-green-500',
              buttonFocusClass: 'focus:ring-green-400',
              buttonDarkBgClass: 'dark:bg-gray-800',
              buttonDarkTextClass: 'dark:text-green-400',
              buttonDarkHoverClass: 'dark:hover:bg-gray-700',
              iconPath: 'M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z',
              srText: 'Success'
            },
            'error': {
              textClass: 'text-red-800',
              bgClass: 'bg-red-50',
              darkTextClass: 'dark:text-red-400',
              darkBgClass: 'dark:bg-gray-800',
              buttonBgClass: 'bg-red-50',
              buttonTextClass: 'text-red-500',
              buttonFocusClass: 'focus:ring-red-400',
              buttonDarkBgClass: 'dark:bg-gray-800',
              buttonDarkTextClass: 'dark:text-red-400',
              buttonDarkHoverClass: 'dark:hover:bg-gray-700',
              iconPath: 'M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z',
              srText: 'Error'
            },
            'info': {
              textClass: 'text-blue-800',
              bgClass: 'bg-blue-50',
              darkTextClass: 'dark:text-blue-400',
              darkBgClass: 'dark:bg-gray-800',
              buttonBgClass: 'bg-blue-50',
              buttonTextClass: 'text-blue-500',
              buttonFocusClass: 'focus:ring-blue-400',
              buttonDarkBgClass: 'dark:bg-gray-800',
              buttonDarkTextClass: 'dark:text-blue-400',
              buttonDarkHoverClass: 'dark:hover:bg-gray-700',
              iconPath: 'M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z',
              srText: 'Info'
            },
            'warning': {
              textClass: 'text-yellow-800',
              bgClass: 'bg-yellow-50',
              darkTextClass: 'dark:text-yellow-400',
              darkBgClass: 'dark:bg-gray-800',
              buttonBgClass: 'bg-yellow-50',
              buttonTextClass: 'text-yellow-500',
              buttonFocusClass: 'focus:ring-yellow-400',
              buttonDarkBgClass: 'dark:bg-gray-800',
              buttonDarkTextClass: 'dark:text-yellow-400',
              buttonDarkHoverClass: 'dark:hover:bg-gray-700',
              iconPath: 'M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z',
              srText: 'Warning'
            }
          };

          const config = toastTypes[type] || toastTypes['info'];
          const toast = document.createElement('div');
          toast.id = toastId;
          toast.className = 'flex items-center p-4 mb-4 text-sm rounded-lg ' + config.textClass + ' ' + config.bgClass + ' ' + config.darkTextClass + ' ' + config.darkBgClass;
          toast.setAttribute('role', 'alert');
          toast.setAttribute('data-controller', 'toast');
          toast.setAttribute('data-action', 'click->toast#dismiss');

          toast.innerHTML = `
            <svg class="shrink-0 inline w-4 h-4 me-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="${config.iconPath}" clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">${config.srText}</span>
            <div>
              <span class="font-medium">${escapedMessage}</span>
            </div>
            <button type="button" class="ms-auto -mx-1.5 -my-1.5 ${config.buttonBgClass} ${config.buttonTextClass} rounded-lg ${config.buttonFocusClass} focus:ring-2 p-1.5 inline-flex h-8 w-8 ${config.buttonDarkBgClass} ${config.buttonDarkTextClass} ${config.buttonDarkHoverClass}" data-action="click->toast#dismiss">
              <span class="sr-only">Close</span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          `;

          toastContainer.appendChild(toast);

          // Auto-dismiss after 5 seconds
          setTimeout(() => {
            const toastElement = document.getElementById(toastId);
            if (toastElement) {
              toastElement.style.transition = 'opacity 0.3s ease-out';
              toastElement.style.opacity = '0';
              setTimeout(() => toastElement.remove(), 300);
            }
          }, 5000);
        });
      })();
    </script>
  </body>
</html>
