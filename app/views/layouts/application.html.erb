<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Vantura" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# PWA Manifest - Currently disabled
        To enable PWA functionality:
        1. Uncomment the manifest link below
        2. Create/configure pwa_manifest_path route in config/routes.rb
        3. Generate manifest.json view or controller action
        4. Configure service worker if needed
        5. Test PWA installation on mobile devices
        See: Rails PWA documentation for full setup instructions
    %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# DNS prefetch for external APIs to reduce latency on first request %>
    <link rel="dns-prefetch" href="//api.up.com.au">

    <script>
      // Initialize theme before page renders to prevent Flash of Unstyled Content (FOUC)
      (function() {
        const theme = localStorage.getItem('theme') || 'auto';
        const root = document.documentElement;
        
        if (theme === 'dark') {
          root.classList.add('dark');
        } else if (theme === 'light') {
          root.classList.remove('dark');
        } else {
          // Auto mode - use system preference
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            root.classList.add('dark');
          }
        }
      })();
    </script>

    <%# Includes Tailwind CSS (built from app/assets/tailwind/application.css) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme modal sync" class="flex flex-col h-screen bg-neutral-50 dark:bg-neutral-900">
    <!-- WebSocket subscription for real-time updates (available on all pages) -->
    <% if Current.user %>
      <%= turbo_stream_from Current.user %>
    <% end %>

    <!-- Desktop Navbar with integrated page header (only show when authenticated) -->
    <% if Current.user %>
      <%= render 'shared/layout/navbar' %>
    <% end %>

    <!-- Main content wrapper -->
    <main id="application-main-container" 
          role="main"
          aria-label="Main content"
          data-modal-target="content"
          class="flex-1 overflow-y-auto overflow-x-hidden transition-all duration-300 ease-in-out pb-16 lg:pb-0">
      
      <%= yield %>
    </main>

    <!-- Form Drawer for Desktop (only show when authenticated) -->
    <% if Current.user %>
      <%= render 'shared/layout/form_drawer' %>
    <% end %>

    <!-- Mobile Navigation (only show when authenticated) -->
    <% if Current.user %>
      <%= render 'shared/layout/navigation' %>
    <% end %>
    
    <!-- Sync notification container (available on all pages) -->
    <div id="app-sync-notification-container"></div>
    
    <%= render 'shared/layout/notifications' %>
  </body>
</html>