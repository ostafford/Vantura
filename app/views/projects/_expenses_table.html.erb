<section id="project-expenses-section" class="surface-table-container rounded-lg shadow-deep" aria-label="Project expenses list">
  <div class="px-6 py-4 border-table-divider border-b">
    <div class="flex items-center justify-between gap-4">
      <!-- Left: Previous/Today/Next Navigation Buttons -->
      <div class="flex gap-3" data-controller="month-nav" data-month-nav-turbo-frame-value="calendar_content">
        <%= link_to project_path(@project, year: (@project_show_data[:date].prev_month.year), month: (@project_show_data[:date].prev_month.month)),
                    class: "btn-secondary",
                    data: { action: 'click->month-nav#navigate', turbo_frame: 'calendar_content' } do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Previous
        <% end %>

        <%= link_to project_path(@project, year: Date.today.year, month: Date.today.month),
                    class: "btn-secondary",
                    data: { action: 'click->month-nav#navigate', turbo_frame: 'calendar_content' } do %>
          Today
        <% end %>

        <%= link_to project_path(@project, year: (@project_show_data[:date].next_month.year), month: (@project_show_data[:date].next_month.month)),
                    class: "btn-secondary",
                    data: { action: 'click->month-nav#navigate', turbo_frame: 'calendar_content' } do %>
          Next
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        <% end %>
      </div>

      <!-- Center: Project Expenses Heading -->
      <h2 class="text-xl font-bold text-neutral-base flex-1 text-center">Project Expenses</h2>

      <!-- Right: Action Buttons -->
      <div class="flex gap-2">
        <% can_manage = (@project.owner_id == Current.user.id) || @project.project_memberships.where(user_id: Current.user.id, access_level: ProjectMembership.access_levels[:full]).exists? %>
        <% if can_manage %>
          <%= link_to new_project_expense_path(@project), 
              id: "project-expense-add-link",
              "aria-label" => "Add Expense",
              class: "inline-flex items-center justify-center w-12 h-12 btn-secondary-icon hover:scale-110 hover:shadow-lg transition-all", 
              title: "Add expense" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
          <% end %>
          
          <%= link_to edit_project_path(@project), class: "inline-flex items-center justify-center w-12 h-12 btn-secondary-icon hover:scale-110 hover:shadow-lg transition-all", title: "Edit project" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
          <% end %>
          
          <% if @project.owner_id == Current.user.id %>
            <%= button_to project_path(@project), method: :delete, form: { data: { turbo_confirm: "Delete this project?" }, class: "inline" }, class: "inline-flex items-center justify-center w-12 h-12 bg-white dark:bg-neutral-800 btn-destructive-icon hover:scale-110 hover:shadow-lg transition-all", title: "Delete project" do %>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
            <% end %>
          <% end %>
        <% else %>
          <!-- Spacer to maintain layout when buttons aren't shown -->
          <div class="w-12"></div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-table-divider divide-y">
      <thead class="bg-table-header">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Merchant</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Total</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Due</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-neutral-muted uppercase tracking-wider">Notes</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-neutral-muted uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="project-expenses-table-body" class="bg-white dark:bg-neutral-800 divide-table-divider divide-y">
        <% if @project_show_data[:expenses].any? %>
          <% @project_show_data[:expenses].each do |expense| %>
            <tr data-controller="expense-row" data-action="click->expense-row#toggle" class="cursor-pointer hover:bg-neutral-50 dark:hover:bg-neutral-700/50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-neutral-400 chevron-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                  <span class="text-sm text-neutral-900 dark:text-neutral-100"><%= expense.merchant %></span>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-900 dark:text-neutral-100"><%= expense.category %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-neutral-900 dark:text-neutral-100"><%= format_cents(expense.total_cents) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-900 dark:text-neutral-100"><%= expense.due_on&.strftime('%Y-%m-%d') %></td>
              <td class="px-6 py-4 text-sm text-neutral-900 dark:text-neutral-100"><%= expense.notes %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium" onclick="event.stopPropagation()">
                <% if @project.owner_id == Current.user.id %>
                  <%= link_to "Edit", edit_expense_path(expense), class: "link-primary mr-3" %>
                  <%= button_to "Delete", expense_path(expense), method: :delete, form: { data: { turbo_confirm: "Delete this expense?" }, class: "inline" }, class: "btn-destructive-text" %>
                <% end %>
              </td>
            </tr>
            <tr data-expense-row-target="contributions" class="hidden">
              <td colspan="6" class="px-6 pb-4 bg-neutral-50 dark:bg-neutral-800/50">
                <div class="rounded-lg border-table-divider border p-4 bg-white dark:bg-neutral-900">
                  <div class="font-medium mb-3 text-sm text-neutral-base">Contributions</div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <% expense.expense_contributions.each do |contrib| %>
                      <div class="flex items-center justify-between bg-neutral-50 dark:bg-neutral-800 border-table-divider border rounded-lg px-4 py-3">
                        <div>
                          <div class="text-sm font-medium text-neutral-900 dark:text-neutral-100"><%= user_display_name(contrib.user) %></div>
                          <div class="text-xs text-neutral-muted mt-1"><%= format_cents(contrib.share_cents) %></div>
                        </div>
                        <div>
                          <% if can_toggle_paid?(contrib) %>
                            <%= form_with(model: contrib, url: contribution_path(contrib), method: :patch) do |ff| %>
                              <label class="inline-flex items-center gap-2 text-sm cursor-pointer">
                                <%= ff.check_box :paid, { checked: contrib.paid, onchange: 'this.form.submit()', include_hidden: true, class: "rounded border-neutral-300 input-accent-primary" }, true, false %>
                                <span class="text-neutral-label"><%= contrib.paid ? 'Paid' : 'Unpaid' %></span>
                              </label>
                            <% end %>
                          <% else %>
                            <span class="text-sm <%= contrib.paid ? 'status-success' : 'text-neutral-muted' %>">
                              <%= contrib.paid ? 'Paid' : 'Not paid' %>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center">
              <svg class="mx-auto h-12 w-12 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-neutral-base">No expenses yet</h3>
              <p class="mt-1 text-sm text-neutral-muted">Get started by adding your first expense.</p>
              <% if @project.owner_id == Current.user.id %>
                <%= link_to "Add Expense", 
                    new_project_expense_path(@project), 
                    id: "project-expense-add-empty-link",
                    class: "mt-4 btn-primary" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

