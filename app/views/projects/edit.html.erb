<% content_for :title, "Edit Project - Projects - Vantura" %>
<% content_for :page_header_title, "Edit Project" %>
<% content_for :page_header_subtitle, "Update project details and members" %>

<main>
  <!-- Breadcrumb Navigation -->
  <div class="surface-breadcrumb">
    <%= content_wrapper class: "py-2" do %>
      <div class="flex items-center gap-2">
        <%= link_to projects_path, class: "text-sm text-neutral-600 dark:text-neutral-400 hover-link-primary font-medium" do %>
          Projects
        <% end %>
        <span class="text-sm text-neutral-400 dark:text-neutral-500">/</span>
        <span class="text-sm text-neutral-base font-medium">Edit Project</span>
      </div>
    <% end %>
  </div>

  <%= content_wrapper class: "py-6" do %>
    <div class="surface-form-container">
      <%= render "form" %>
    </div>
  <% end %>
</main>

