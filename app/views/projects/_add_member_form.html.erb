<% project = local_assigns[:project] || @project %>
<%= form_with model: [project, ProjectMembership.new], url: project_memberships_path(project), local: false, data: { turbo: true }, id: "add-member-form", class: "space-y-4", html: { "data-modal-target": "form" } do |f| %>
  <% if defined?(error) && error.present? %>
    <div class="p-3 form-error-bg form-error-border rounded-lg">
      <p class="text-sm form-error-text"><%= error %></p>
    </div>
  <% end %>

  <% if defined?(membership) && membership&.errors&.any? %>
    <div class="p-3 form-error-bg form-error-border rounded-lg">
      <ul class="list-disc list-inside form-error">
        <% membership.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label for="membership_user_id" class="label-base">Select User</label>
    <select name="user_id" id="membership_user_id" required class="input-full">
      <option value="">Choose a user...</option>
      <% User.order(:email_address).limit(100).each do |user| %>
        <% next if user.id == Current.user.id || project.owner_id == user.id || project.members.exists?(id: user.id) %>
        <option value="<%= user.id %>"><%= user_display_name(user) %> (<%= user.email_address %>)</option>
      <% end %>
    </select>
    <p class="mt-1 text-xs text-neutral-muted">Owner and existing members are excluded</p>
  </div>

  <div>
    <label for="membership_access_level" class="label-base">Access Level</label>
    <select name="access_level" id="membership_access_level" class="input-full">
      <option value="limited" <%= (defined?(membership) && membership&.limited?) ? 'selected' : '' %>>Limited access</option>
      <option value="full" <%= (defined?(membership) && membership&.full?) ? 'selected' : '' %>>Full access</option>
    </select>
    <p class="mt-1 text-xs text-neutral-muted">Full access allows editing expenses and managing members</p>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit "Add Member", class: "btn-primary" %>
    <button type="button" data-action="click->modal#close" class="btn-secondary">Cancel</button>
  </div>
<% end %>

