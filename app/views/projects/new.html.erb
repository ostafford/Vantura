<% content_for :title, "New Project - Projects - Vantura" %>

<main>
  <!-- Breadcrumb Navigation -->
  <div class="bg-gradient-to-r from-cream-100 to-white dark:from-primary-900 dark:to-primary-950 border-b border-primary-700/20 dark:border-primary-900/30">
    <%= content_wrapper class: "py-2" do %>
      <div class="flex items-center gap-2">
        <%= link_to projects_path, class: "text-sm text-gray-600 dark:text-gray-400 hover:text-primary-700 dark:hover:text-primary-400 font-medium transition-colors" do %>
          Projects
        <% end %>
        <span class="text-sm text-gray-400 dark:text-gray-500">/</span>
        <span class="text-sm text-gray-900 dark:text-white font-medium">New Project</span>
      </div>
    <% end %>
  </div>

  <!-- Page Header -->
  <%= render 'shared/page_header_simple', title: "New Project", subtitle: "Create a new shared expense project", hide_quick_actions: true %>

  <%= content_wrapper class: "py-6" do %>
    <div class="bg-gradient-to-br from-neutral-100 to-white dark:from-gray-800 dark:to-gray-900 rounded-lg shadow-deep p-6">
      <%= render "form" %>
    </div>
  <% end %>
</main>
