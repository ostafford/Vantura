<!-- Hero Card (2x2) -->
<%= render 'shared/bento_cards/hero_card',
    title: @project.name,
    subtitle: @project_show_data[:total_expenses_cents] > 0 ? format_cents(@project_show_data[:total_expenses_cents]) : "No expenses yet",
    description: "Overview of project expenses, participants, and activity. Track shared costs and monitor contributions across all project expenses.",
    icon: 'chart',
    size: 'col-span-1 md:col-span-2 row-span-2',
    color: 'primary' do %>
  <div class="mt-6 space-y-4">
    <!-- Owner Section -->
    <div class="pb-3 border-b border-white/20">
      <div class="text-white/80 text-xs font-medium mb-2 uppercase tracking-wider">Owner</div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-lg border border-white/30">
        <div class="w-8 h-8 rounded-full bg-white/30 flex items-center justify-center text-white font-semibold text-sm">
          <%= user_display_name(@project.owner).first.upcase %>
        </div>
        <span class="text-white font-semibold"><%= user_display_name(@project.owner) %></span>
      </div>
    </div>
    
    <!-- Members Section -->
    <%= turbo_frame_tag "project-members-section" do %>
      <div>
        <div class="flex items-center justify-between mb-2">
          <div class="text-white/80 text-xs font-medium uppercase tracking-wider">Members</div>
          <% if can_manage_members?(@project) %>
            <button type="button" data-action="click->modal#open" class="text-white/80 hover:text-white text-xs font-medium uppercase tracking-wider transition-colors">
              + Add Member
            </button>
          <% end %>
        </div>
        <% if @project.members.any? %>
          <div id="project-members-list" class="flex flex-wrap gap-2">
            <% membership_by_user = @project.project_memberships.index_by(&:user_id) %>
            <% @project.members.each do |member| %>
              <% membership = membership_by_user[member.id] %>
              <% level = membership&.access_level || 'limited' %>
              <div id="<%= dom_id(membership || member) %>" class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-lg border border-white/25">
                <div class="w-7 h-7 rounded-full bg-white/25 flex items-center justify-center text-white font-medium text-xs">
                  <%= user_display_name(member).first.upcase %>
                </div>
                <span class="text-white/90 text-sm"><%= user_display_name(member) %></span>
                <span class="ml-2 text-[10px] uppercase tracking-wide px-2 py-0.5 rounded bg-white/20 text-white/90 border border-white/30">
                  <%= level == 'full' ? 'Full' : 'Limited' %>
                </span>
                <% if can_manage_members?(@project) && membership %>
                  <%= button_to project_membership_path(@project, membership), method: :delete, form: { data: { turbo: true }, class: "ml-2" }, class: "text-white/60 hover:text-white transition-colors", title: "Remove member" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div id="project-members-empty" class="text-white/60 text-sm italic">
            No additional members
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Add Member Modal -->
    <% if can_manage_members?(@project) %>
      <div data-modal-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Overlay: absolute, behind content -->
        <div class="absolute inset-0 bg-gray-500 bg-opacity-75 transition-opacity z-0" data-action="click->modal#closeOnBackground" data-modal-target="overlay" aria-hidden="true"></div>
        <!-- Content: relative, above overlay -->
        <div class="relative z-10 inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full mx-4">
          <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white" id="modal-title">Add Member</h3>
              <button type="button" data-action="click->modal#close" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            <%= render "projects/add_member_form", project: @project %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Current Month Total Card -->
<%= render 'shared/bento_cards/stat_card',
    id: 'project_current_month_card',
    title: "This Month",
    value: format_cents(@project_show_data[:project_stats][:current_month_total_cents]),
    subtitle: "<span class='font-semibold text-gray-900 dark:text-white'>#{@project_show_data[:expense_count]}</span> #{'expense'.pluralize(@project_show_data[:expense_count])}".html_safe,
    detail: @project_show_data[:date].strftime("%B %Y"),
    icon: 'dollar',
    color: 'red',
    size: 'col-span-1 row-span-1' do %>
  <%= render_top_categories(@project_show_data[:project_stats][:top_categories_current_month], @project_show_data[:project_stats][:current_month_total_cents]) %>
<% end %>

<!-- Month Over Month Card -->
<% 
  mom_change_pct = @project_show_data[:project_stats][:mom_change_pct]
  mom_is_positive = mom_change_pct >= 0
  mom_icon = mom_is_positive ? 'arrow-up' : 'arrow-down'
  mom_color = mom_is_positive ? 'green' : 'red'
  mom_change_display = format_percentage_change(mom_change_pct)
%>
<%= render 'shared/bento_cards/stat_card',
    id: 'project_mom_card',
    title: "Month Over Month",
    value: mom_change_display,
    subtitle: "vs Last Month: <span class='font-semibold text-gray-900 dark:text-white'>#{format_cents(@project_show_data[:project_stats][:last_month_total_cents])}</span>".html_safe,
    detail: format_cents(@project_show_data[:project_stats][:mom_change_cents].abs) + (mom_is_positive ? " increase" : " decrease"),
    icon: mom_icon,
    color: mom_color,
    size: 'col-span-1 row-span-1' do %>
  <%= render_top_categories(@project_show_data[:project_stats][:top_categories_current_month], @project_show_data[:project_stats][:current_month_total_cents]) %>
<% end %>

<!-- Year Over Year Card -->
<% 
  yoy_change_pct = @project_show_data[:project_stats][:yoy_change_pct]
  yoy_is_positive = yoy_change_pct >= 0
  yoy_icon = yoy_is_positive ? 'arrow-up' : 'arrow-down'
  yoy_color = 'blue'
  yoy_change_display = format_percentage_change(yoy_change_pct)
  ytd_period = "Jan-#{@project_show_data[:date].strftime('%b')}"
%>
<%= render 'shared/bento_cards/stat_card',
    id: 'project_yoy_card',
    title: "Year Over Year",
    value: yoy_change_display,
    subtitle: "YTD vs Last Year: <span class='font-semibold text-gray-900 dark:text-white'>#{format_cents(@project_show_data[:project_stats][:ytd_last_year_cents])}</span>".html_safe,
    detail: "#{ytd_period} comparison",
    icon: 'calendar',
    color: yoy_color,
    size: 'col-span-1 row-span-1' do %>
  <%= render_top_categories(@project_show_data[:project_stats][:top_categories_ytd_this_year], @project_show_data[:project_stats][:ytd_this_year_cents]) %>
<% end %>

<!-- Next Month Projection Card -->
<% 
  projection_cents = @project_show_data[:project_stats][:projected_next_month_cents]
  next_month_name = @project_show_data[:date].next_month.strftime("%B")
%>
<%= render 'shared/bento_cards/stat_card',
    id: 'project_projection_card',
    title: "Next Month Projection",
    value: format_cents(projection_cents),
    subtitle: "Based on last 3 months",
    detail: "Weighted average for #{next_month_name}",
    icon: 'chart',
    color: 'blue',
    size: 'col-span-1 row-span-1' do %>
  <%= render_top_categories(@project_show_data[:project_stats][:top_categories_last_month], @project_show_data[:project_stats][:last_month_total_cents]) %>
<% end %>
    
<!-- Monthly Bar Chart Card (bento 4x2) -->
<%= render 'shared/bento_cards/bar_chart_card', 
    project: @project, 
    title: 'Monthly Expenses', 
    year: @project_show_data[:date].year, 
    month: @project_show_data[:date].month,
    current_date: @project_show_data[:date],
    month_title: @project_show_data[:date].strftime("%B %Y"),
    prev_path: project_path(@project, year: (@project_show_data[:date].prev_month.year), month: (@project_show_data[:date].prev_month.month)),
    turbo_frame: 'calendar_content' %>


