<% project ||= local_assigns[:project] %>
<% current_user ||= local_assigns[:current_user] %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Members</h3>
    <% if project.can_edit?(current_user) %>
      <button type="button"
          class="text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
          data-action="click->project-modal#openMembersModal">
        Manage Members
      </button>
    <% end %>
  </div>

  <div class="space-y-3">
    <%# Owner %>
    <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
          <span class="text-blue-600 dark:text-blue-300 font-medium">
            <%= (project.owner.name || project.owner.email_address).first.upcase %>
          </span>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900 dark:text-white">
            <%= project.owner.name || project.owner.email_address %>
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Owner</p>
        </div>
      </div>
      <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded dark:bg-blue-900 dark:text-blue-200">
        Can manage everything
      </span>
    </div>

    <%# Members %>
    <% project.members.each do |member| %>
      <% member_record = project.project_members.find_by(user: member) %>
      <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-600 flex items-center justify-center">
            <span class="text-gray-600 dark:text-gray-300 font-medium">
              <%= (member.name || member.email_address).first.upcase %>
            </span>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">
              <%= member.name || member.email_address %>
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              <%= member_record&.role&.capitalize || "Member" %>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <% if member_record&.can_create? %>
            <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded dark:bg-green-900 dark:text-green-200">Can add expenses</span>
          <% end %>
          <% if member_record&.can_edit? %>
            <span class="px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded dark:bg-blue-900 dark:text-blue-200">Can edit</span>
          <% end %>
          <% if !member_record&.can_edit? && !member_record&.can_create? %>
            <span class="px-2 py-1 text-xs bg-gray-100 text-gray-800 rounded dark:bg-gray-700 dark:text-gray-200">View only</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if project.members.empty? %>
      <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">
        No additional members yet.
      </p>
    <% end %>
  </div>
</div>

