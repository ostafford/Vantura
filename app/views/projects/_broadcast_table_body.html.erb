<tbody id="projects-table-body" class="bg-white dark:bg-neutral-800 divide-table-divider divide-y">
  <% if projects.any? %>
    <% projects.each do |project| %>
      <tr>
        <td class="px-6 py-4 whitespace-nowrap">
          <%= link_to project.name, project_path(project), class: "link-primary font-medium" %>
        </td>
        <td class="px-6 py-4">
          <div class="text-sm text-neutral-900 dark:text-neutral-100">
            <%= (project.participants.map { |u| user_display_name(u) }).join(", ") %>
          </div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
          <%= link_to "View", project_path(project), class: "link-primary" %>
        </td>
      </tr>
    <% end %>
  <% else %>
    <tr>
      <td colspan="3" class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-neutral-base">No projects</h3>
        <p class="mt-1 text-sm text-neutral-muted">Get started by creating your first project.</p>
        <%= link_to "New Project", new_project_path, class: "mt-4 btn-primary" %>
      </td>
    </tr>
  <% end %>
</tbody>

