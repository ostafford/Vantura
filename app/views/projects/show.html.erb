<% content_for :title, "#{@project.name} - Projects - Vantura" %>
<% content_for :page_header_title, @project.name %>
<% content_for :page_header_subtitle, "View project details and expenses" %>

<main>
  <!-- Breadcrumb Navigation -->
  <nav class="surface-breadcrumb" aria-label="Breadcrumb">
    <%= content_wrapper class: "py-2" do %>
      <div class="flex items-center gap-2">
        <%= link_to projects_path, class: "text-sm text-neutral-600 dark:text-neutral-400 hover-link-primary font-medium" do %>
          Projects
        <% end %>
        <span class="text-sm text-neutral-400 dark:text-neutral-500" aria-hidden="true">/</span>
        <span class="text-sm text-neutral-base font-medium"><%= @project.name %></span>
      </div>
    <% end %>
  </nav>

  <%= content_wrapper class: "py-6" do %>
    <!-- Bento Grid Statistics Section -->
    <section id="project-statistics-bento-section" class="bento-grid mb-6" aria-label="Project statistics">
      <%= render partial: "projects/project_bento_cards" %>
    </section>

    <!-- Expenses Table Section -->
    <%= render partial: "projects/expenses_table" %>
  <% end %>
</main>
