<%= form_with(
  model: @expense,
  url: (@expense.persisted? ? expense_path(@expense) : project_expenses_path(@project)),
  method: (@expense.persisted? ? :patch : :post),
  local: true,
  html: { 
    id: (@expense.persisted? ? "project-expense-edit-form" : "project-expense-create-form"),
    data: { turbo: false }
  }
) do |f| %>
  <div <% if @expense.new_record? %>
         data-controller="expense-template"
         data-expense-template-url-value="<%= templates_project_expenses_path(@project) %>"
       <% end %>>
    <% if @expense.errors.any? %>
      <div class="mb-6 p-4 form-error-bg form-error-border rounded-lg">
        <h3 class="text-sm font-medium form-error-text mb-2">Please fix the following errors:</h3>
        <ul class="list-disc list-inside text-sm form-error-text">
          <% @expense.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @expense.new_record? %>
      <div class="mb-6 p-4 rounded-lg surface-info surface-info-border space-y-3">
      <label class="block text-sm font-medium mb-2">
        Quick fill from previous expense
      </label>
      <p class="text-xs leading-relaxed">
        Search for a previous expense to automatically fill in merchant, category, and notes. You can still edit all fields before saving.
      </p>
      <div class="relative">
        <input type="text" 
               data-expense-template-target="input"
               placeholder="Search by merchant or category (e.g., Gas bill, Utilities...)"
               class="input-full focus-ring-info focus:border-transparent">
        <div data-expense-template-target="results" 
             class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-600 rounded-lg shadow-lg max-h-60 overflow-y-auto">
          <ul class="py-1"></ul>
        </div>
      </div>
      </div>
    <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :merchant, "Merchant", for: "project-expense-merchant-input", class: "label-base" %>
      <%= f.text_field :merchant, 
            id: "project-expense-merchant-input",
            data: { expense_template_target: "merchant" },
            class: "input-full" %>
    </div>
    <div>
      <%= f.label :category, "Category", for: "project-expense-category-input", class: "label-base" %>
      <%= f.text_field :category, 
            id: "project-expense-category-input",
            data: { expense_template_target: "category" },
            class: "input-full" %>
    </div>
    <div>
      <%= label_tag "project-expense-total-input", "Total", class: "label-base" %>
      <% 
        # Determine the value to display: prefer params (on validation error), then saved cents (if > 0), else nil
        total_dollars_value = if params.dig(:project_expense, :total_dollars).present?
          params.dig(:project_expense, :total_dollars)
        elsif @expense.total_cents.present? && @expense.total_cents > 0
          @expense.total_cents / 100.0
        else
          nil
        end
      %>
      <div class="relative">
        <span class="absolute left-4 top-2.5 text-neutral-500 dark:text-neutral-400 text-lg font-semibold">$</span>
        <%= number_field_tag "project_expense[total_dollars]", 
            total_dollars_value,
            id: "project-expense-total-input",
            min: 0, 
            step: 0.01,
            class: "input-full pl-8 pr-4",
            placeholder: "0.00" %>
      </div>
    </div>
    <div>
      <%= f.label :due_on, "Due on", for: "project-expense-due-on-input", class: "label-base" %>
      <%= f.date_field :due_on, 
            id: "project-expense-due-on-input",
            class: "input-full" %>
    </div>
  </div>

  <div class="mt-6">
    <%= f.label :notes, "Notes", for: "project-expense-notes-textarea", class: "label-base" %>
    <%= f.text_area :notes, 
          id: "project-expense-notes-textarea",
          rows: 3, 
          data: { expense_template_target: "notes" },
          class: "input-full" %>
  </div>

  <div class="mt-6">
    <label class="label-base">Participants</label>
    <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-4">Select who contributes to this expense. Amount will be split equally among selected participants. Owner receives any remainder.</p>
    <div class="border border-neutral-200 dark:border-neutral-700 rounded-lg overflow-hidden bg-neutral-50 dark:bg-neutral-800/50">
      <% 
        participants = @project.participants
        existing_contributor_ids = @expense.persisted? ? @expense.expense_contributions.pluck(:user_id) : []
      %>
      <% participants.each do |participant| %>
        <% 
          is_checked = if @expense.persisted?
            existing_contributor_ids.include?(participant.id)
          else
            true # Default to all checked for new expenses
          end
          
          # Calculate preview share if expense has total_cents
          # Note: Preview uses cents for accuracy, display uses format_cents helper
          preview_share = nil
          if @expense.total_cents.present? && @expense.total_cents > 0
            selected_count = participants.size # Simplified preview - actual count handled by JS or server
            base_share = @expense.total_cents / participants.size
            remainder = @expense.total_cents % participants.size
            preview_share = base_share
            preview_share += remainder if participant.id == @project.owner_id
          end
        %>
        <label class="flex items-center gap-3 px-4 py-3 border-b border-neutral-200 dark:border-neutral-700 last:border-b-0 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 cursor-pointer transition-colors">
          <input type="checkbox" name="contributor_user_ids[]" value="<%= participant.id %>" class="w-4 h-4 rounded border-neutral-300 dark:border-neutral-600 input-accent-primary" <%= 'checked' if is_checked %>>
          <div class="flex-1">
            <div class="text-sm font-medium text-neutral-900 dark:text-neutral-100">
              <%= user_display_name(participant) %>
              <% if participant.id == @project.owner_id %>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 ml-1">(Owner)</span>
              <% end %>
            </div>
            <% if preview_share.present? %>
              <div class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">Share: <%= format_cents(preview_share) %></div>
            <% end %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex gap-3 mt-8 pt-6 border-t border-neutral-200 dark:border-neutral-700">
    <%= f.submit (@expense.persisted? ? "Update Expense" : "Create Expense"), class: "action-primary px-6 py-2.5" %>
    <%= link_to "Cancel", project_path(@project), class: "btn-secondary" %>
  </div>
  </div>
<% end %>


