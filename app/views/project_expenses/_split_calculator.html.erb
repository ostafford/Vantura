<% project ||= local_assigns[:project] %>
<% form ||= local_assigns[:form] %>

<% all_members = (project.members + [project.owner]).uniq %>

<div class="mb-4 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg"
     data-split-calculator-target="calculator">
  <label class="block mb-3 text-sm font-medium text-gray-900 dark:text-white">Contributors:</label>
  
  <div class="space-y-3" data-split-calculator-target="contributorsList">
    <% all_members.each_with_index do |member, index| %>
      <div class="flex items-center justify-between p-2 bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-600"
           data-split-calculator-target="contributorRow"
           data-user-id="<%= member.id %>"
           data-index="<%= index %>">
        <div class="flex items-center gap-3 flex-1">
          <%= check_box_tag "contributors[]", member.id, true,
              class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600",
              data: {
                split_calculator_target: "contributorCheckbox",
                action: "change->split-calculator#updateSplit"
              } %>
          <label class="text-sm text-gray-900 dark:text-white">
            <%= member.name || member.email_address %>
            <% if member == project.owner %>
              <span class="text-xs text-gray-500 dark:text-gray-400">(Owner)</span>
            <% end %>
          </label>
        </div>
        
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-500 dark:text-gray-400"
                data-split-calculator-target="percentage">
            (0%)
          </span>
          <div class="relative w-24">
            <span class="absolute left-2 top-1/2 transform -translate-y-1/2 text-gray-500 dark:text-gray-400 text-xs">$</span>
            <%# Use fields_for with index to create proper nested attributes %>
            <%= form.fields_for :expense_contributions, ExpenseContribution.new(user: member), child_index: index do |contrib_form| %>
              <%= contrib_form.hidden_field :user_id, value: member.id, data: { user_id_field: true } %>
              <%= contrib_form.hidden_field :amount_currency, value: "AUD" %>
              <%# Hidden field for actual cents value %>
              <%= contrib_form.hidden_field :amount_cents, value: 0, data: { split_calculator_target: "amountCents", user_id: member.id, index: index } %>
              <%# Display field for dollars (converted to cents on input) %>
              <%= number_field_tag "amount_display_#{member.id}", nil,
                  step: 0.01,
                  min: 0,
                  placeholder: "0.00",
                  class: "w-full pl-6 pr-2 py-1 text-sm text-gray-900 bg-white border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                  data: {
                    split_calculator_target: "amountInput",
                    action: "input->split-calculator#updateSplit",
                    user_id: member.id,
                    amount_field: true,
                    index: index
                  } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-600">
    <div class="flex justify-between items-center">
      <span class="text-sm font-medium text-gray-900 dark:text-white">Total:</span>
      <span class="text-sm font-bold text-gray-900 dark:text-white"
            data-split-calculator-target="total">
        $0.00
      </span>
    </div>
    <div class="mt-1">
      <span class="text-xs <%= 'text-red-600 dark:text-red-400' if false %>"
            data-split-calculator-target="validationMessage">
        <!-- Validation message will appear here -->
      </span>
    </div>
  </div>
</div>

