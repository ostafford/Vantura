<% project ||= local_assigns[:project] || @project %>

<!-- Modal backdrop -->
<div id="add-expense-modal"
     class="hidden fixed inset-0 z-50 overflow-y-auto"
     data-project-modal-target="addExpenseModal"
     data-controller="modal"
     aria-labelledby="add-expense-modal-title"
     aria-modal="true"
     role="dialog">
  <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <!-- Background overlay -->
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"
         data-action="click->project-modal#close"
         aria-hidden="true"></div>

    <!-- Modal panel -->
    <div class="relative z-10 inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-3xl sm:w-full">
      <!-- Modal Header -->
      <div class="flex items-center justify-between p-4 md:p-5 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white" id="add-expense-modal-title">
          Add Expense to <%= project.name %>
        </h3>
        <button type="button"
            class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white"
            data-action="click->project-modal#close">
          <svg class="w-3 h-3" aria-hidden="true" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
          </svg>
          <span class="sr-only">Close modal</span>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-4 md:p-5">
        <%= turbo_frame_tag "project-expense-form",
            data: {
              action: "turbo:submit-end->project-modal#formSubmitted"
            } do %>
          <%# Form will be loaded here via Turbo Frame %>
          <div class="text-center py-8">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
            <p class="mt-4 text-gray-600 dark:text-gray-400">Loading form...</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

