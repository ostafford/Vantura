<% content_for :title, "Edit Expense - #{@project.name} - Projects - Vantura" %>
<% content_for :page_header_title, "Edit Expense" %>
<% content_for :page_header_subtitle, "Update expense details for #{@project.name}" %>

<main>
  <!-- Breadcrumb Navigation -->
  <div class="surface-breadcrumb">
    <%= content_wrapper class: "py-2" do %>
      <div class="flex items-center gap-2">
        <%= link_to projects_path, class: "text-sm text-neutral-600 dark:text-neutral-400 hover-link-primary font-medium" do %>
          Projects
        <% end %>
        <span class="text-sm text-neutral-400 dark:text-neutral-500">/</span>
        <%= link_to @project.name, project_path(@project), class: "text-sm text-neutral-600 dark:text-neutral-400 hover-link-primary font-medium" %>
        <span class="text-sm text-neutral-400 dark:text-neutral-500">/</span>
        <span class="text-sm text-neutral-900 dark:text-white font-medium">Edit Expense</span>
      </div>
    <% end %>
  </div>

  <%= content_wrapper class: "py-6" do %>
    <div class="surface-form-container">
      <%= render "form" %>
    </div>
  <% end %>
</main>

