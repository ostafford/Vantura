<%# If request is from modal (Turbo Frame), render form wrapped in Turbo Frame %>
<% if request.headers["Turbo-Frame"] == "project-expense-form" %>
  <%= turbo_frame_tag "project-expense-form" do %>
    <%= render "project_expenses/form", project: @project, project_expense: @project_expense %>
  <% end %>
<% else %>
  <div class="container mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-4">
        <%= link_to project_project_expenses_path(@project),
            class: "text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">New Project Expense</h1>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <%= turbo_frame_tag "project-expense-form" do %>
        <%= render "project_expenses/form", project: @project, project_expense: @project_expense %>
      <% end %>
    </div>
  </div>
<% end %>
