<h1>New Project Expense</h1>

<%= form_with model: [@project, @project_expense], local: true do |form| %>
  <% if @project_expense.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@project_expense.errors.count, "error") %> prohibited this expense from being saved:</h2>
      <ul>
        <% @project_expense.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :description %>
    <%= form.text_field :description %>
  </div>

  <div>
    <%= form.label :total_amount_cents, "Amount (cents)" %>
    <%= form.number_field :total_amount_cents %>
  </div>

  <div>
    <%= form.label :expense_date %>
    <%= form.date_field :expense_date %>
  </div>

  <div>
    <%= form.submit "Create Expense" %>
  </div>
<% end %>

<%= link_to "Back to Expenses", project_project_expenses_path(@project) %>

